@page "/"
@page "/fridge"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ProductWebManager.Data.ProductManagerContext DbContext
@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Models

<PageTitle>Холодильник</PageTitle>

<div class="page-bg">
    <div class="container-fluid p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold m-0 page-title">📦 Холодильник</h2>
                <small class="page-subtitle">Управление продуктами</small>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-add" @onclick="OpenAddModal">
                    ➕ Добавить продукт
                </button>
            </div>
        </div>

        <div class="row mb-4">
            <div class="col-md-4 mb-3">
                <div class="stat-card">
                    <div class="stat-label">ВСЕГО ПРОДУКТОВ</div>
                    <div class="stat-value" style="color: #6c5ce7;">@products.Count</div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="stat-card stat-card-danger">
                    <div class="stat-label">ИСТЕКАЮТ СЕГОДНЯ</div>
                    <div class="stat-value" style="color: #e74c3c;">@expiringToday</div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="stat-card stat-card-warning">
                    <div class="stat-label">ИСТЕКАЮТ ЗА НЕДЕЛЮ</div>
                    <div class="stat-value" style="color: #f39c12;">@expiringThisWeek</div>
                </div>
            </div>
        </div>

        <div class="filter-bar">
            <div class="row g-3">
                <div class="col-md-5">
                    <input type="text" class="form-control filter-input"
                           placeholder="🔍 Поиск продуктов..."
                           @bind="searchQuery"
                           @bind:event="oninput"
                           @bind:after="ApplyFilters" />
                </div>
                <div class="col-md-3">
                    <select class="form-control filter-input" @bind="sortBy" @bind:after="ApplyFilters">
                        <option value="expiry">⏰ По сроку</option>
                        <option value="name">📋 По названию</option>
                        <option value="date">🕐 По дате</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <select class="form-control filter-input" @bind="filterCategory" @bind:after="ApplyFilters">
                        <option value="">🗂️ Все категории</option>
                        @if (categories != null)
                        {
                            @foreach (var cat in categories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        }
                    </select>
                </div>
            </div>
        </div>

        @if (filteredProducts.Any())
        {
            <div class="row">
                @foreach (var item in filteredProducts)
                {
                    var daysLeft = item.ExpirationDate.HasValue ? (item.ExpirationDate.Value - DateTime.Now).TotalDays : 999;
                    var statusColor = daysLeft <= 0 ? "#e74c3c" : daysLeft <= 3 ? "#f39c12" : "#27ae60";
                    var progressWidth = daysLeft > 14 ? 100 : Math.Max(0, Math.Min(100, (daysLeft / 14) * 100));
                    var expiryText = !item.ExpirationDate.HasValue ? "Без срока" :
                    daysLeft <= 0 ? "Просрочен" :
                    daysLeft <= 1 ? "Истекает сегодня" :
                    daysLeft <= 3 ? $"Истекает через {Math.Ceiling(daysLeft)} дн." :
                    $"Годен ещё {Math.Ceiling(daysLeft)} дн.";

                    var cardClass = !item.ExpirationDate.HasValue ? "product-card" :
                    daysLeft <= 0 ? "product-card expired" :
                    daysLeft <= 3 ? "product-card expiring" : "product-card";

                    <div class="col-md-6 col-lg-4 col-xl-3 mb-3">
                        <div class="@cardClass">
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="flex-grow-1" style="min-width: 0;">
                                    <div class="d-flex align-items-center gap-2 mb-1">
                                        <h6 class="product-name">@item.Product?.Name</h6>
                                        @if (item.ExpirationDate.HasValue && daysLeft <= 0)
                                        {
                                            <span class="status-badge status-expired">Просрочен</span>
                                        }
                                        else if (item.ExpirationDate.HasValue && daysLeft <= 3)
                                        {
                                            <span class="status-badge status-expiring">Истекает</span>
                                        }
                                    </div>
                                    <span class="category-tag">@(item.Product?.Category?.Name ?? "Без категории")</span>
                                </div>
                                <div class="d-flex gap-1 ms-2">
                                    <button type="button" class="btn-icon edit" @onclick="() => OpenEditModal(item)">Изменить</button>
                                    <button type="button" class="btn-icon delete" @onclick="() => ConfirmDeleteProduct(item)">Удалить</button>
                                </div>
                            </div>

                            <div class="mb-3">
                                <span class="quantity-value">@(item.Quanity?.ToString() ?? "0")</span>
                                <span class="quantity-unit">@(item.Product?.Unit?.Name ?? "шт.")</span>
                            </div>

                            @if (item.ExpirationDate.HasValue)
                            {
                                <div class="expiry-section">
                                    <div class="d-flex justify-content-between align-items-center mb-2">
                                        <span class="expiry-date">@item.ExpirationDate.Value.ToString("dd.MM.yyyy")</span>
                                        <span class="expiry-status" style="color: @statusColor;">@expiryText</span>
                                    </div>
                                    <div class="progress-bar-bg">
                                        <div class="progress-bar-fill" style="width: @progressWidth%; background: @statusColor;"></div>
                                    </div>
                                </div>
                            }
                            else
                            {
                                <div class="expiry-section" style="background: #f0f4ff;">
                                    <span class="expiry-date" style="color: #6c5ce7;">Без срока годности</span>
                                </div>
                            }

                            <div class="d-flex gap-2 mt-3">
                                <button type="button" class="btn-qty minus" @onclick="() => UpdateQuantity(item, -1)"
                                        disabled="@(item.Quanity <= 1)">
                                    −
                                </button>
                                <button type="button" class="btn-qty plus" @onclick="() => UpdateQuantity(item, 1)">+</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">🛒</div>
                <h4 class="empty-title">Холодильник пуст</h4>
                <p class="empty-text">Добавьте продукты, чтобы начать</p>
                <button type="button" class="btn btn-add" @onclick="OpenAddModal">➕ Добавить первый продукт</button>
            </div>
        }
    </div>
</div>

@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-dialog" @onclick:stopPropagation="true">
            <h4 class="modal-title">@(isEditing ? "✏️ Изменить" : "➕ Добавить") продукт</h4>
            <div class="mb-3">
                <label class="form-label">Продукт</label>
                <select class="form-control modal-input" @bind="selectedProductId">
                    <option value="0">-- Выберите продукт --</option>
                    @if (allProducts != null)
                    {
                        @foreach (var p in allProducts)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Количество</label>
                    <input type="number" class="form-control modal-input" @bind="editQuantity" min="0.1" step="0.1" />
                </div>
            </div>
            <div class="mb-4">
                <label class="form-label">Срок годности</label>
                <input type="date" class="form-control modal-input" @bind="editExpiryDate" />
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn-modal-save" @onclick="SaveProduct">💾 Сохранить</button>
                <button type="button" class="btn-modal-cancel" @onclick="CloseModal">Отмена</button>
            </div>
        </div>
    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-dialog" @onclick:stopPropagation="true" style="max-width: 380px;">
            <h4 class="modal-title">🗑️ Подтверждение</h4>
            <p class="delete-text">Удалить <strong class="delete-name">@productToDelete?.Product?.Name</strong>?</p>
            <div class="d-flex gap-2">
                <button type="button" class="btn-modal-delete" @onclick="DeleteProduct">Удалить</button>
                <button type="button" class="btn-modal-cancel" @onclick="CancelDelete">Отмена</button>
            </div>
        </div>
    </div>
}

