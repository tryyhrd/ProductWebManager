@page "/fridge"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Models

@inject ProductWebManager.Data.ProductManagerContext DbContext
@inject ProductWebManager.Services.AuthService AuthService

<PageTitle>Холодильник</PageTitle>

<div class="max-w-[1440px] mx-auto p-4 lg:p-6 font-sans min-h-screen text-slate-800 selection:bg-indigo-100">

    <header class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 border-b border-slate-100 pb-4 mb-4">
        <div>
            <h1 class="text-2xl font-black tracking-tight text-slate-900">Холодильник</h1>

            <div class="flex flex-wrap gap-x-4 gap-y-1 text-xs font-semibold text-slate-400 mt-1.5">
                <span class="flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-indigo-500"></span> Всего: <strong class="text-slate-700">@products.Count</strong>
                </span>
                <span class="flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-rose-500"></span> Просрочено: <strong class="text-slate-700">@expiredProducts</strong>
                </span>
                <span class="flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-amber-500"></span> Истекает скоро: <strong class="text-slate-700">@expiringSoon</strong>
                </span>
                <span class="flex items-center gap-1.5">
                    <span class="w-2 h-2 rounded-full bg-slate-300"></span> Без срока: <strong class="text-slate-700">@products.Count(x => !x.ExpirationDate.HasValue)</strong>
                </span>
            </div>
        </div>

        <button class="flex items-center justify-center gap-1.5 bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold px-4 py-2.5 rounded-xl transition-all shadow-sm"
                @onclick="OpenAddModal">
            <i class="fas fa-plus text-[10px]"></i>
            <span>Добавить продукт</span>
        </button>
    </header>

    <div class="flex flex-col sm:flex-row gap-2.5 mb-4">
        <div class="relative flex-1">
            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs"><i class="fas fa-search"></i></span>
            <input type="text"
                   class="w-full pl-8 pr-3 py-1.5 bg-slate-50 border border-slate-200 focus:border-indigo-500 focus:bg-white rounded-lg outline-none text-xs transition-all placeholder:text-slate-400 font-medium"
                   placeholder="Поиск продукта..."
                   @bind="searchQuery"
                   @bind:event="oninput"
                   @bind:after="ApplyFilters" />
        </div>

        <div class="w-full sm:w-44 relative">
            <select class="w-full px-3 py-1.5 bg-slate-50 border border-slate-200 focus:border-indigo-500 rounded-lg outline-none text-xs text-slate-600 cursor-pointer appearance-none font-medium"
                    @bind="sortBy"
                    @bind:after="ApplyFilters">
                <option value="expiry">⏱️ По сроку годности</option>
                <option value="name">🔤 По названию</option>
                <option value="date">📅 По дате добавления</option>
            </select>
        </div>

        <div class="w-full sm:w-44 relative">
            <select class="w-full px-3 py-1.5 bg-slate-50 border border-slate-200 focus:border-indigo-500 rounded-lg outline-none text-xs text-slate-600 cursor-pointer appearance-none font-medium"
                    @bind="filterCategory"
                    @bind:after="ApplyFilters">
                <option value="">📂 Все категории</option>
                @foreach (var category in categories)
                {
                    <option value="@category.Id">@category.Name</option>
                }
            </select>
        </div>
    </div>

    @if (filteredProducts.Any())
    {
        <div class="hidden md:block border border-slate-100 rounded-xl overflow-hidden bg-white shadow-sm">
            <div class="overflow-x-auto">
                <table class="w-full text-left border-collapse whitespace-nowrap text-xs">
                    <thead>
                        <tr class="bg-slate-50 border-b border-slate-100 text-slate-400 font-bold uppercase tracking-wider select-none">
                            <th class="py-2 px-3 w-8 text-center"></th>
                            <th class="py-2 px-3 text-slate-600 font-semibold">Название продукта</th>
                            <th class="py-2 px-3 text-slate-600 font-semibold">Категория</th>
                            <th class="py-2 px-3 text-slate-600 font-semibold text-center w-28">Количество</th>
                            <th class="py-2 px-3 text-slate-600 font-semibold w-48">Срок годности</th>
                            <th class="py-2 px-3 text-slate-600 font-semibold text-right w-20"></th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100 text-slate-700 font-medium">
                        @foreach (var item in filteredProducts)
                        {
                            var status = GetStatus(item);
                            var daysLeft = GetDaysLeft(item);

                            <tr class="hover:bg-slate-50/60 transition-colors group">
                                <td class="py-1.5 px-3 text-center">
                                    <span class="inline-block w-2 h-2 rounded-full @(status switch {
                                        "expired" => "bg-rose-500 animate-pulse",
                                        "warning" => "bg-amber-500",
                                        "fresh" => "bg-emerald-500",
                                        _ => "bg-slate-300"
                                    })" title="@GetStatusText(item)"></span>
                                </td>

                                <td class="py-1.5 px-3 font-semibold text-slate-900">
                                    <span class="mr-1.5">@(item.ExpirationDate.HasValue ? "🥗" : "🥫")</span>
                                    @item.Product?.Name
                                </td>

                                <td class="py-1.5 px-3 text-slate-400 font-normal">
                                    @(item.Product?.Category?.Name ?? "—")
                                </td>

                                <td class="py-1.5 px-3 text-center font-bold text-slate-800">
                                    @(item.Quantity ?? 0) <span class="text-slate-400 font-normal text-[10px]">@(item.Product?.Unit?.Name ?? "шт.")</span>
                                </td>

                                <td class="py-1.5 px-3">
                                    @if (item.ExpirationDate.HasValue)
                                    {
                                        <div class="flex items-center gap-2">
                                            <span class="font-mono text-slate-600">@item.ExpirationDate?.ToString("dd.MM.yyyy")</span>
                                            <span class="text-[10px] font-bold px-1.5 py-0.5 rounded @(status switch {
                                                "expired" => "bg-rose-50 text-rose-600",
                                                "warning" => "bg-amber-50 text-amber-700",
                                                "fresh" => "bg-emerald-50 text-emerald-700",
                                                _ => "bg-slate-100 text-slate-500"
                                            })">
                                                @if (status == "expired")
                                                {
                                                    <span>Просрочен</span>
                                                }
                                                else if (status == "warning")
                                                {
                                                    <span>Осталось: @daysLeft дн.</span>
                                                }
                                                else
                                                {
                                                    <span>Ещё: @daysLeft дн.</span>
                                                }
                                            </span>
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-slate-400 italic text-[11px] font-normal">Срок не ограничен</span>
                                    }
                                </td>

                                <td class="py-1.5 px-3 text-right">
                                    <div class="flex justify-end gap-1 opacity-0 group-hover:opacity-100 transition-opacity">
                                        <button class="p-1 text-slate-400 hover:text-indigo-600 transition-colors" title="Изменить" @onclick="() => OpenEditModal(item)">
                                            <i class="fas fa-pen text-[10px]"></i>
                                        </button>
                                        <button class="p-1 text-slate-400 hover:text-rose-600 transition-colors" title="Удалить" @onclick="() => OpenDelete(item)">
                                            <i class="fas fa-trash text-[10px]"></i>
                                        </button>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="space-y-1 block md:hidden">
            @foreach (var item in filteredProducts)
            {
                var status = GetStatus(item);
                var daysLeft = GetDaysLeft(item);

                <div class="flex items-center justify-between p-2 bg-white border border-slate-100 rounded-xl text-xs gap-2 shadow-sm">
                    <div class="flex items-center gap-2 min-w-0">
                        <span class="w-2 h-2 rounded-full flex-shrink-0 @(status switch {
                            "expired" => "bg-rose-500",
                            "warning" => "bg-amber-500",
                            "fresh" => "bg-emerald-500",
                            _ => "bg-slate-300"
                        })"></span>
                        <div class="truncate">
                            <div class="font-semibold text-slate-900 truncate">@item.Product?.Name</div>
                            <div class="text-[10px] text-slate-400 truncate">@(item.Product?.Category?.Name ?? "—")</div>
                        </div>
                    </div>

                    <div class="flex items-center gap-2 flex-shrink-0 text-right">
                        <div>
                            <div class="font-bold text-slate-800">@(item.Quantity ?? 0) <span class="text-slate-400 font-normal text-[10px]">@(item.Product?.Unit?.Name ?? "")</span></div>
                            <div class="text-[10px] font-bold @(status switch {
                                "expired" => "text-rose-500",
                                "warning" => "text-amber-600",
                                "fresh" => "text-emerald-600",
                                _ => "text-slate-400"
                            })">
                                @if (item.ExpirationDate.HasValue)
                                {
                                    @(status == "expired" ? "Просрочен" : $"{daysLeft} дн.")
                                }
                                else
                                {
                                    <span class="font-normal italic">∞</span>
                                }
                            </div>
                        </div>

                        <div class="flex gap-0.5 border-l border-slate-100 pl-1.5 ml-1">
                            <button class="w-6 h-6 text-slate-400 flex items-center justify-center text-[10px]" @onclick="() => OpenEditModal(item)">
                                <i class="fas fa-pen"></i>
                            </button>
                            <button class="w-6 h-6 text-rose-400 flex items-center justify-center text-[10px]" @onclick="() => OpenDelete(item)">
                                <i class="fas fa-trash"></i>
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-12 bg-slate-50 rounded-xl border border-dashed border-slate-200 max-w-sm mx-auto mt-6">
            <span class="text-2xl">🧊</span>
            <h3 class="text-sm font-bold text-slate-800 mt-2">Холодильник пуст</h3>
            <p class="text-xs text-slate-400 mt-0.5 mb-4">Здесь пока нет добавленных продуктов.</p>
            <button class="bg-indigo-600 hover:bg-indigo-700 text-white text-xs font-bold px-4 py-2 rounded-lg"
                    @onclick="OpenAddModal">
                Добавить продукт
            </button>
        </div>
    }
</div>

@if (showModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 backdrop-blur-xs bg-slate-900/30 animate-fade-in"
         @onclick="CloseModal">

        <div class="bg-white rounded-2xl p-5 w-full max-w-sm shadow-xl border border-slate-100"
             @onclick:stopPropagation="true">

            <div class="flex justify-between items-center mb-4">
                <h3 class="text-base font-bold text-slate-900">
                    @(isEditing ? "Изменить параметры" : "Добавить в холодильник")
                </h3>
                <button class="w-7 h-7 bg-slate-50 hover:bg-slate-100 rounded-lg flex items-center justify-center text-slate-400"
                        @onclick="CloseModal">
                    ✕
                </button>
            </div>

            <div class="space-y-3 text-xs">
                <div class="flex flex-col">
                    <label class="font-bold text-slate-500 mb-1">Продукт</label>
                    <select class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg outline-none text-slate-700 appearance-none cursor-pointer"
                            @bind="selectedProductId">
                        <option value="0">-- Выберите продукт --</option>
                        @foreach (var p in allProducts.OrderBy(x => x.Name))
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>

                <div class="flex flex-col">
                    <label class="font-bold text-slate-500 mb-1">Количество</label>
                    <input type="number"
                           class="w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-lg outline-none text-slate-800 font-semibold"
                           min="0.1"
                           step="0.1"
                           @bind="editQuantity" />
                </div>

                <div class="flex flex-col bg-slate-50 p-3 rounded-xl border border-slate-100">
                    <div class="flex justify-between items-center mb-2">
                        <label class="font-bold text-slate-500">Срок годности</label>
                        <label class="flex items-center gap-1.5 font-semibold text-slate-600 cursor-pointer">
                            <input type="checkbox" class="w-3.5 h-3.5 text-indigo-600 border-slate-300 rounded"
                                   @bind="hasExpiryDate" />
                            <span>Указать срок</span>
                        </label>
                    </div>
                    <InputDate TValue="DateTime?"
                               class="w-full px-3 py-2 bg-white border border-slate-200 rounded-lg outline-none text-slate-800 disabled:opacity-40"
                               @bind-Value="editExpiryDate"
                               disabled="@(!hasExpiryDate)" />
                </div>
            </div>

            <div class="flex gap-2 mt-5 text-xs">
                <button class="flex-1 bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-2.5 rounded-lg"
                        @onclick="SaveProduct">
                    Сохранить
                </button>
                <button class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold py-2.5 rounded-lg"
                        @onclick="CloseModal">
                    Отмена
                </button>
            </div>
        </div>
    </div>
}

@if (showDeleteModal)
{
    <div class="fixed inset-0 z-50 flex items-center justify-center p-4 backdrop-blur-xs bg-slate-900/30"
         @onclick="CloseDelete">

        <div class="bg-white rounded-2xl p-5 w-full max-w-xs shadow-xl border border-slate-100 text-center text-xs"
             @onclick:stopPropagation="true">

            <h3 class="text-sm font-bold text-slate-900">Убрать продукт?</h3>
            <p class="text-slate-500 mt-1">
                Вы действительно хотите удалить <strong class="text-slate-700">@productToDelete?.Product?.Name</strong>?
            </p>

            <div class="flex gap-2 mt-4">
                <button class="flex-1 bg-rose-600 hover:bg-rose-700 text-white font-bold py-2 rounded-lg"
                        @onclick="DeleteProduct">
                    Удалить
                </button>
                <button class="flex-1 bg-slate-100 hover:bg-slate-200 text-slate-600 font-bold py-2 rounded-lg"
                        @onclick="CloseDelete">
                    Отмена
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<FridgeItem> products = new();
    private List<FridgeItem> filteredProducts = new();
    private List<Product> allProducts = new();
    private List<Category> categories = new();
    private string searchQuery = "";
    private string sortBy = "expiry";
    private string filterCategory = "";

    private bool showModal;
    private bool showDeleteModal;
    private bool isEditing;
    private int selectedProductId;
    private double editQuantity = 1;
    private bool hasExpiryDate = true;
    private DateTime? editExpiryDate = DateTime.Today.AddDays(7);
    private FridgeItem currentProduct = new();
    private FridgeItem? productToDelete;

    private int expiredProducts;
    private int expiringSoon;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        products = await DbContext.FridgeItems
            .Include(x => x.Product)
                .ThenInclude(x => x.Unit)
            .Include(x => x.Product)
                .ThenInclude(x => x.Category)
            .Where(x => x.UserId == AuthService.CurrentUserId)
            .OrderBy(x => x.ExpirationDate)
            .ToListAsync();

        allProducts = await DbContext.Products
            .OrderBy(x => x.Name)
            .ToListAsync();

        categories = await DbContext.Categories
            .OrderBy(x => x.Name)
            .ToListAsync();

        UpdateStats();
        ApplyFilters();
    }

    private void UpdateStats()
    {
        expiredProducts = products.Count(x => x.ExpirationDate.HasValue && x.ExpirationDate.Value.Date <= DateTime.Today);
        expiringSoon = products.Count(x => x.ExpirationDate.HasValue && x.ExpirationDate.Value.Date > DateTime.Today && x.ExpirationDate.Value.Date <= DateTime.Today.AddDays(7));
    }

    private void ApplyFilters()
    {
        IEnumerable<FridgeItem> query = products;

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            query = query.Where(x => x.Product != null && x.Product.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrWhiteSpace(filterCategory) && int.TryParse(filterCategory, out var categoryId))
        {
            query = query.Where(x => x.Product?.CategoryId == categoryId);
        }

        filteredProducts = sortBy switch
        {
            "name" => query.OrderBy(x => x.Product!.Name).ToList(),
            "date" => query.OrderByDescending(x => x.AddedAt).ToList(),
            _ => query.OrderBy(x => x.ExpirationDate ?? DateTime.MaxValue).ToList()
        };
    }

    private string GetStatus(FridgeItem item)
    {
        if (!item.ExpirationDate.HasValue) return "neutral";
        var days = (item.ExpirationDate.Value.Date - DateTime.Today).TotalDays;

        if (days <= 0) return "expired";
        if (days <= 3) return "warning";
        return "fresh";
    }

    private string GetStatusText(FridgeItem item)
    {
        if (!item.ExpirationDate.HasValue) return "Без срока";
        var days = (item.ExpirationDate.Value.Date - DateTime.Today).TotalDays;

        if (days <= 0) return "Просрочен";
        if (days <= 3) return "Скоро закончится";
        return "Свежий";
    }

    private int GetDaysLeft(FridgeItem item)
    {
        if (!item.ExpirationDate.HasValue) return 999;
        return (int)(item.ExpirationDate.Value.Date - DateTime.Today).TotalDays;
    }

    private void OpenAddModal()
    {
        currentProduct = new FridgeItem();
        selectedProductId = 0;
        editQuantity = 1;
        hasExpiryDate = true;
        editExpiryDate = DateTime.Today.AddDays(7);
        isEditing = false;
        showModal = true;
    }

    private void OpenEditModal(FridgeItem item)
    {
        currentProduct = item;
        selectedProductId = item.ProductId;
        editQuantity = item.Quantity ?? 1;
        hasExpiryDate = item.ExpirationDate.HasValue;
        editExpiryDate = item.ExpirationDate;
        isEditing = true;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task SaveProduct()
    {
        if (selectedProductId == 0) return;

        DateTime? finalExpiry = hasExpiryDate ? editExpiryDate : null;

        if (isEditing)
        {
            var existing = await DbContext.FridgeItems.FindAsync(currentProduct.Id);
            if (existing != null)
            {
                existing.ProductId = selectedProductId;
                existing.Quantity = editQuantity;
                existing.ExpirationDate = finalExpiry;
            }
        }
        else
        {
            DbContext.FridgeItems.Add(new FridgeItem
                {
                    UserId = AuthService.CurrentUserId,
                    ProductId = selectedProductId,
                    Quantity = editQuantity,
                    ExpirationDate = finalExpiry,
                    AddedAt = DateTime.UtcNow
                });
        }

        await DbContext.SaveChangesAsync();
        await LoadData();
        CloseModal();
    }

    private void OpenDelete(FridgeItem item)
    {
        productToDelete = item;
        showDeleteModal = true;
    }

    private void CloseDelete()
    {
        productToDelete = null;
        showDeleteModal = false;
    }

    private async Task DeleteProduct()
    {
        if (productToDelete == null) return;

        var existing = await DbContext.FridgeItems.FindAsync(productToDelete.Id);
        if (existing != null)
        {
            DbContext.FridgeItems.Remove(existing);
            await DbContext.SaveChangesAsync();
        }

        await LoadData();
        CloseDelete();
    }
}