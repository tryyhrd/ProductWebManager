@code {

    private List<FridgeItem> products = new();
    private List<FridgeItem> filteredProducts = new();

    private List<Product> allProducts = new();
    private List<Category> categories = new();

    private string searchQuery = "";
    private string sortBy = "expiry";
    private string filterCategory = "";

    private bool showModal = false;
    private bool isEditing = false;

    private bool showDeleteConfirm = false;

    private bool hasExpiryDate = true;

    private bool collapseExpiry = false;
    private bool collapseNoExpiry = false;

    private FridgeItem currentProduct = new();
    private FridgeItem? productToDelete;

    private int expiringToday = 0;
    private int expiringThisWeek = 0;

    private int selectedProductId;

    private double editQuantity = 1;

    private DateTime? editExpiryDate = DateTime.Now.AddDays(7);

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        products = await DbContext.FridgeItems
            .Include(f => f.Product).ThenInclude(p => p.Unit)
            .Include(f => f.Product).ThenInclude(p => p.Category)
            .Where(f => f.UserId == AuthService.CurrentUserId)
            .ToListAsync();

        allProducts = await DbContext.Products
            .Include(p => p.Unit)
            .Include(p => p.Category)
            .ToListAsync();

        categories = await DbContext.Categories.ToListAsync();

        UpdateStats();
        ApplyFilters();
    }

    private void UpdateStats()
    {
        expiringToday = products.Count(p =>
            p.ExpirationDate.HasValue &&
            p.ExpirationDate.Value.Date <= DateTime.Now.Date);

        expiringThisWeek = products.Count(p =>
            p.ExpirationDate.HasValue &&
            p.ExpirationDate.Value.Date <= DateTime.Now.AddDays(7).Date);
    }

    private void ApplyFilters()
    {
        var query = products.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            query = query.Where(p =>
                p.Product?.Name != null &&
                p.Product.Name.Contains(searchQuery,
                StringComparison.OrdinalIgnoreCase));
        }

        if (!string.IsNullOrEmpty(filterCategory)
            && int.TryParse(filterCategory, out int catId))
        {
            query = query.Where(p =>
                p.Product?.CategoryId == catId);
        }

        filteredProducts = sortBy switch
        {
            "name" => query.OrderBy(p => p.Product?.Name).ToList(),
            "date" => query.OrderByDescending(p => p.AddetAt).ToList(),
            _ => query.OrderBy(p => p.ExpirationDate ?? DateTime.MaxValue).ToList()
        };
    }

    private void OpenAddModal()
    {
        currentProduct = new FridgeItem();

        selectedProductId = 0;

        editQuantity = 1;

        hasExpiryDate = true;

        editExpiryDate = DateTime.Now.AddDays(7);

        isEditing = false;

        showModal = true;
    }

    private void OpenEditModal(FridgeItem item)
    {
        currentProduct = item;

        selectedProductId = item.ProductId;

        editQuantity = item.Quanity ?? 1;

        hasExpiryDate = item.ExpirationDate.HasValue;

        editExpiryDate = item.ExpirationDate;

        isEditing = true;

        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task SaveProduct()
    {
        if (selectedProductId == 0)
            return;

        var finalExpiry =
        hasExpiryDate ? editExpiryDate : null;

        if (isEditing)
        {
            var existing =
            await DbContext.FridgeItems.FindAsync(currentProduct.Id);

            if (existing != null)
            {
                existing.ProductId = selectedProductId;
                existing.Quanity = editQuantity;
                existing.ExpirationDate = finalExpiry;
            }
        }
        else
        {
            DbContext.FridgeItems.Add(new FridgeItem
                {
                    UserId = AuthService.CurrentUserId,
                    ProductId = selectedProductId,
                    Quanity = editQuantity,
                    ExpirationDate = finalExpiry,
                    AddetAt = DateTime.UtcNow
                });
        }

        await DbContext.SaveChangesAsync();

        await LoadData();

        CloseModal();
    }

    private void ConfirmDeleteProduct(FridgeItem item)
    {
        productToDelete = item;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        productToDelete = null;
    }

    private async Task DeleteProduct()
    {
        if (productToDelete == null)
            return;

        var item =
        await DbContext.FridgeItems.FindAsync(productToDelete.Id);

        if (item != null)
        {
            DbContext.FridgeItems.Remove(item);
            await DbContext.SaveChangesAsync();
        }

        await LoadData();

        CancelDelete();
    }

}