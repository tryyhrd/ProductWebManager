@page "/fridge"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Models

@inject ProductWebManager.Data.ProductManagerContext DbContext
@inject ProductWebManager.Services.AuthService AuthService

<PageTitle>Холодильник</PageTitle>

<div class="fridge-layout">

    <!-- HEADER -->
    <div class="header-block">

        <div>
            <h1 class="page-title">
                Холодильник
            </h1>

            <div class="page-subtitle">
                Управление продуктами и сроками хранения
            </div>
        </div>

        <button class="add-button"
                @onclick="OpenAddModal">
            + Добавить продукт
        </button>

    </div>

    <!-- STATS -->
    <div class="stats-grid">

        <div class="stat-card purple">
            <div class="stat-value">
                @products.Count
            </div>

            <div class="stat-label">
                Всего продуктов
            </div>
        </div>

        <div class="stat-card red">
            <div class="stat-value">
                @expiredProducts
            </div>

            <div class="stat-label">
                Просрочено
            </div>
        </div>

        <div class="stat-card orange">
            <div class="stat-value">
                @expiringSoon
            </div>

            <div class="stat-label">
                Заканчивается скоро
            </div>
        </div>

        <div class="stat-card gray">
            <div class="stat-value">
                @products.Count(x => !x.ExpirationDate.HasValue)
            </div>

            <div class="stat-label">
                Без срока
            </div>
        </div>

    </div>

    <!-- FILTERS -->
    <div class="filters-card">

        <div class="filters-grid">

            <input type="text"
                   class="filter-input"
                   placeholder="Поиск продукта..."
                   @bind="searchQuery"
                   @bind:event="oninput"
                   @bind:after="ApplyFilters" />

            <select class="filter-input"
                    @bind="sortBy"
                    @bind:after="ApplyFilters">

                <option value="expiry">
                    По сроку
                </option>

                <option value="name">
                    По названию
                </option>

                <option value="date">
                    По дате
                </option>

            </select>

            <select class="filter-input"
                    @bind="filterCategory"
                    @bind:after="ApplyFilters">

                <option value="">
                    Все категории
                </option>

                @foreach (var category in categories)
                {
                    <option value="@category.Id">
                        @category.Name
                    </option>
                }

            </select>

        </div>

    </div>

    <!-- PRODUCTS -->
    @if (filteredProducts.Any())
    {
        <div class="products-container">

            @foreach (var item in filteredProducts)
            {
                var status = GetStatus(item);
                var daysLeft = GetDaysLeft(item);

                <div class="product-card @status">

                    <div class="status-line @status"></div>

                    <div class="product-icon">
                        @(item.ExpirationDate.HasValue ? "🥗" : "🥫")
                    </div>

                    <div class="product-content">

                        <div class="product-top">

                            <div>

                                <div class="product-name">
                                    @item.Product?.Name
                                </div>

                                <div class="product-category">
                                    @(item.Product?.Category?.Name ?? "Без категории")
                                </div>

                            </div>

                            <div class="status-badge @status">
                                @GetStatusText(item)
                            </div>

                        </div>

                        <div class="product-bottom">

                            <div class="quantity-box">
                                @(item.Quantity ?? 0)
                                @(item.Product?.Unit?.Name ?? "шт.")
                            </div>

                            @if (item.ExpirationDate.HasValue)
                            {
                                <div class="expiry-box">
                                    @item.ExpirationDate?.ToString("dd.MM.yyyy")
                                </div>
                            }

                            <div class="actions">

                                <button class="edit-btn"
                                        @onclick="() => OpenEditModal(item)">
                                    Изменить
                                </button>

                                <button class="delete-btn"
                                        @onclick="() => OpenDelete(item)">
                                    Удалить
                                </button>

                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>
    }
    else
    {
        <div class="empty-state">

            <div class="empty-icon">
                🧊
            </div>

            <div class="empty-title">
                Холодильник пуст
            </div>

            <div class="empty-subtitle">
                Добавьте продукты
            </div>

        </div>
    }

</div>

<!-- ADD / EDIT MODAL -->
@if (showModal)
{
    <div class="modal-overlay"
         @onclick="CloseModal">

        <div class="modal-window"
             @onclick:stopPropagation="true">

            <div class="modal-header">

                <h3>
                    @(isEditing ? "Изменить продукт" : "Добавить продукт")
                </h3>

                <button class="close-btn"
                        @onclick="CloseModal">
                    ✕
                </button>

            </div>

            <div class="modal-body">

                <div class="field">

                    <label>
                        Продукт
                    </label>

                    <select class="modal-input"
                            @bind="selectedProductId">

                        <option value="0">
                            -- Выберите продукт --
                        </option>

                        @foreach (var p in allProducts.OrderBy(x => x.Name))
                        {
                            <option value="@p.Id">
                                @p.Name
                            </option>
                        }

                    </select>

                </div>

                <div class="field">

                    <label>
                        Количество
                    </label>

                    <input type="number"
                           class="modal-input"
                           min="0.1"
                           step="0.1"
                           @bind="editQuantity" />

                </div>

                <div class="field">

                    <div class="expiry-header">

                        <label>
                            Срок годности
                        </label>

                        <div class="checkbox-row">

                            <input type="checkbox"
                                   @bind="hasExpiryDate" />

                            <span>
                                Есть срок
                            </span>

                        </div>

                    </div>

                    <InputDate TValue="DateTime?"
                               class="modal-input"
                               @bind-Value="editExpiryDate"
                               disabled="@(!hasExpiryDate)" />

                </div>

            </div>

            <div class="modal-footer">

                <button class="save-btn"
                        @onclick="SaveProduct">
                    Сохранить
                </button>

                <button class="cancel-btn"
                        @onclick="CloseModal">
                    Отмена
                </button>

            </div>

        </div>

    </div>
}

<!-- DELETE MODAL -->
@if (showDeleteModal)
{
    <div class="modal-overlay"
         @onclick="CloseDelete">

        <div class="delete-modal"
             @onclick:stopPropagation="true">

            <h3>
                Удалить продукт?
            </h3>

            <div class="delete-product-name">
                @productToDelete?.Product?.Name
            </div>

            <div class="modal-footer">

                <button class="confirm-delete-btn"
                        @onclick="DeleteProduct">
                    Удалить
                </button>

                <button class="cancel-btn"
                        @onclick="CloseDelete">
                    Отмена
                </button>

            </div>

        </div>

    </div>
}

