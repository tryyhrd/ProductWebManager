@page "/fridge"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Models

@inject ProductWebManager.Data.ProductManagerContext DbContext
@inject ProductWebManager.Services.AuthService AuthService

<PageTitle>Холодильник</PageTitle>

<div class="max-w-[1100px] mx-auto px-4 py-4 sm:p-6 font-sans min-h-screen text-slate-800">

    <header class="flex items-center justify-between pb-4 border-b border-slate-100 mb-4 sm:mb-6">
        <div>
            <h1 class="text-lg sm:text-xl font-bold tracking-tight text-slate-900">Холодильник</h1>
        </div>

        <button class="bg-slate-900 hover:bg-slate-800 text-white text-xs font-semibold px-3.5 py-2 rounded-lg transition-colors shadow-sm active:scale-95"
                @onclick="OpenAddModal">
            <span>Добавить продукт</span>
        </button>
    </header>

    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 sm:gap-4 py-2 border-b border-slate-100 mb-4 sm:mb-6 text-sm">
        <div>
            <div class="text-lg font-bold text-slate-900 leading-none">@products.Count</div>
            <div class="text-[11px] text-slate-400 font-medium mt-1">Всего в наличии</div>
        </div>

        <div>
            <div class="text-lg font-bold text-rose-600 leading-none">@expiredProducts</div>
            <div class="text-[11px] text-slate-400 font-medium mt-1">Просрочено</div>
        </div>

        <div>
            <div class="text-lg font-bold text-amber-600 leading-none">
                @products.Count(p => p.ExpirationDate.HasValue && (p.ExpirationDate.Value.Date - DateTime.Today).Days >= 0 && (p.ExpirationDate.Value.Date - DateTime.Today).Days <= 3)
            </div>
            <div class="text-[11px] text-slate-400 font-medium mt-1">Истекают скоро</div>
        </div>
    </div>

    <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 pb-4 mb-2">
        <div class="relative flex-1 max-w-md w-full">
            <input type="text"
                   @bind="searchQuery"
                   @bind:event="oninput"
                   placeholder="Поиск по названию или категории..."
                   class="w-full bg-slate-50 text-xs px-3 py-2 rounded-lg border border-slate-100 focus:outline-none focus:border-slate-200 focus:bg-white placeholder-slate-400 transition-all" />
            @if (!string.IsNullOrEmpty(searchQuery))
            {
                <button @onclick="() => searchQuery = string.Empty" class="absolute right-2.5 top-2.5 text-slate-400 hover:text-slate-600 text-xs">
                    <i class="fas fa-times"></i>
                </button>
            }
        </div>

        <div class="flex items-center gap-2 text-xs text-slate-400 self-end sm:self-center">
            <span>Сортировка:</span>
            <select @bind="sortBy" class="bg-transparent font-medium text-slate-700 focus:outline-none cursor-pointer border-none p-0 pr-4 text-xs">
                <option value="expiry">Срок годности</option>
                <option value="name">Название (А-Я)</option>
                <option value="quantity">Количество</option>
            </select>
        </div>
    </div>

    <div class="divide-y divide-slate-100">
        @{
            var displayedProducts = GetFilteredAndSortedProducts();
        }

        @if (!displayedProducts.Any())
        {
            <div class="py-12 text-center text-slate-400 text-xs font-medium">
                @(string.IsNullOrEmpty(searchQuery) ? "Холодильник пуст. Самое время заполнить его!" : "Ничего не найдено по вашему запросу.")
            </div>
        }
        else
        {
            @foreach (var product in displayedProducts)
            {
                <div class="flex flex-col sm:flex-row sm:items-center justify-between py-3 gap-2 text-sm group animate-fade-in">

                    <div class="flex items-center gap-3 min-w-0 flex-1">
                        <div class="truncate">
                            <span class="font-medium text-slate-900">@product.Product?.Name</span>
                            <span class="text-slate-400 text-xs ml-2 font-normal">@product.Product?.Category?.Name</span>
                        </div>
                    </div>

                    <div class="flex flex-wrap items-center justify-between sm:justify-end gap-3 sm:gap-6 text-xs w-full sm:w-auto">

                        <div class="text-slate-600 font-medium whitespace-nowrap">
                            @product.Quantity <span class="text-slate-400 text-[11px]">@product.Product?.Unit?.Name</span>
                        </div>

                        @{
                            var status = GetExpirationStatus(product.ExpirationDate);
                        }
                        <div class="flex items-center gap-2 whitespace-nowrap @status.ColorClass">
                            <span class="w-1.5 h-1.5 rounded-full flex-shrink-0 @status.DotClass"></span>
                            <span>@status.Text</span>
                            @if (product.ExpirationDate.HasValue)
                            {
                                <span class="text-slate-400 text-[11px] font-normal">(@product.ExpirationDate.Value.ToString("dd.MM"))</span>
                            }
                        </div>

                        <div class="flex items-center gap-3 sm:pl-3 sm:border-l sm:border-slate-100 mt-1 sm:mt-0">
                            <button @onclick="() => OpenEditModal(product)"
                                    class="text-indigo-600 hover:text-indigo-800 font-medium transition-colors text-xs flex items-center gap-1.5 bg-indigo-50 sm:bg-transparent px-2 sm:px-0 py-1 sm:py-0 rounded">
                                <i class="fas fa-pen sm:hidden"></i>
                                <span>Изменить</span>
                            </button>

                            <button @onclick="() => OpenDelete(product)"
                                    class="text-rose-500 hover:text-rose-700 font-medium transition-colors text-xs flex items-center gap-1.5 bg-rose-50 sm:bg-transparent px-2 sm:px-0 py-1 sm:py-0 rounded"
                                    title="Удалить">
                                <i class="fas fa-trash sm:hidden"></i>
                                <span>Удалить</span>
                            </button>
                        </div>

                    </div>
                </div>
            }
        }
    </div>
</div>

@if (showModal)
{
    <div class="fixed inset-0 bg-slate-900/20 backdrop-blur-[2px] flex items-center justify-center p-4 z-50">
        <div class="bg-white border border-slate-100 rounded-xl p-5 w-full max-w-sm shadow-lg">
            <h3 class="text-sm font-bold text-slate-900 mb-4">
                @(isEditing ? "Редактировать запись" : "Добавить в холодильник")
            </h3>

            <div class="space-y-3">
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Продукт</label>
                    <select @bind="selectedProductId" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-2.5 py-1.5 text-xs font-medium focus:outline-none focus:border-slate-400">
                        @foreach (var p in allProducts)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    </select>
                </div>

                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Количество</label>
                    <input type="number" step="any" @bind="editQuantity" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-2.5 py-1.5 text-xs font-medium focus:outline-none focus:border-slate-400" />
                </div>

                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1">Срок годности</label>
                    <input type="date" @bind="editExpirationDate" class="w-full bg-slate-50 border border-slate-200 rounded-lg px-2.5 py-1.5 text-xs font-medium focus:outline-none focus:border-slate-400" />
                </div>
            </div>

            <div class="flex items-center justify-end gap-2 mt-5 pt-3 border-t border-slate-50">
                <button @onclick="CloseModal" class="px-2.5 py-1.5 text-slate-400 hover:text-slate-600 text-xs font-medium transition-all">Отмена</button>
                <button @onclick="SaveProduct" class="px-3.5 py-1.5 bg-slate-900 hover:bg-slate-800 text-white rounded-lg text-xs font-medium transition-all shadow-sm">Сохранить</button>
            </div>
        </div>
    </div>
}

@if (showDeleteModal && productToDelete != null)
{
    <div class="fixed inset-0 bg-slate-900/20 backdrop-blur-[2px] flex items-center justify-center p-4 z-50">
        <div class="bg-white border border-slate-100 rounded-xl p-5 w-full max-w-xs shadow-lg">
            <h3 class="text-sm font-bold text-slate-900 mb-1">Удалить продукт?</h3>
            <p class="text-xs text-slate-400 mb-4">Убрать @productToDelete.Product?.Name из холодильника?</p>

            <div class="flex items-center justify-end gap-2">
                <button @onclick="CloseDelete" class="px-2.5 py-1.5 text-slate-400 hover:text-slate-600 text-xs font-medium transition-all">Отмена</button>
                <button @onclick="DeleteProduct" class="px-3.5 py-1.5 bg-rose-600 hover:bg-rose-700 text-white rounded-lg text-xs font-medium transition-all shadow-sm">Удалить</button>
            </div>
        </div>
    </div>
}

@code {
    private List<FridgeItem> products = new();
    private List<Product> allProducts = new();
    private int expiredProducts = 0;

    // Состояния фильтрации
    private string searchQuery = string.Empty;
    private string sortBy = "expiry";

    private bool showModal = false;
    private bool isEditing = false;
    private FridgeItem currentProduct = new();
    private int selectedProductId;
    private double? editQuantity;
    private DateTime? editExpirationDate;

    private bool showDeleteModal = false;
    private FridgeItem? productToDelete;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
        allProducts = await DbContext.Products.OrderBy(p => p.Name).ToListAsync();
    }

    private async Task LoadData()
    {
        products = await DbContext.FridgeItems
            .Include(f => f.Product).ThenInclude(p => p.Category)
            .Include(f => f.Product).ThenInclude(p => p.Unit)
            .Where(f => f.UserId == AuthService.CurrentUserId)
            .ToListAsync();

        expiredProducts = products.Count(p => p.ExpirationDate.HasValue && p.ExpirationDate.Value.Date < DateTime.Today);
    }

    // Логика фильтрации и сортировки на клиенте (без лишних запросов к бд)
    private IEnumerable<FridgeItem> GetFilteredAndSortedProducts()
    {
        var result = products.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            result = result.Where(p =>
                (p.Product?.Name ?? "").Contains(searchQuery, StringComparison.OrdinalIgnoreCase) ||
                (p.Product?.Category?.Name ?? "").Contains(searchQuery, StringComparison.OrdinalIgnoreCase)
            );
        }

        return sortBy switch
        {
            "name" => result.OrderBy(p => p.Product?.Name),
            "quantity" => result.OrderByDescending(p => p.Quantity),
            "expiry" or _ => result.OrderBy(p => p.ExpirationDate ?? DateTime.MaxValue)
        };
    }

    private (string Text, string ColorClass, string DotClass) GetExpirationStatus(DateTime? expiryDate)
    {
        if (!expiryDate.HasValue)
        {
            return ("Срок не указан", "text-slate-500", "bg-slate-300");
        }

        var daysLeft = (expiryDate.Value.Date - DateTime.Today).Days;

        if (daysLeft < 0)
        {
            return ($"Просрочено на {Math.Abs(daysLeft)} дн.", "text-rose-600 font-medium", "bg-rose-500");
        }
        if (daysLeft == 0)
        {
            return ("Истекает сегодня!", "text-amber-600 font-semibold", "bg-amber-500");
        }
        if (daysLeft <= 3)
        {
            return ($"Осталось {daysLeft} дн.", "text-orange-600 font-medium", "bg-orange-500");
        }

        return ($"Еще {daysLeft} дн.", "text-emerald-600", "bg-emerald-500");
    }

    private void OpenAddModal()
    {
        isEditing = false;
        currentProduct = new FridgeItem();
        selectedProductId = allProducts.FirstOrDefault()?.Id ?? 0;
        editQuantity = 1;
        editExpirationDate = DateTime.Today.AddDays(7);
        showModal = true;
    }

    private void OpenEditModal(FridgeItem item)
    {
        isEditing = true;
        currentProduct = item;
        selectedProductId = item.ProductId;
        editQuantity = item.Quantity;
        editExpirationDate = item.ExpirationDate;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private async Task SaveProduct()
    {
        if (selectedProductId == 0 || editQuantity <= 0) return;

        var finalExpiry = editExpirationDate;

        if (isEditing)
        {
            var existing = await DbContext.FridgeItems.FindAsync(currentProduct.Id);
            if (existing != null)
            {
                existing.ProductId = selectedProductId;
                existing.Quantity = editQuantity;
                existing.ExpirationDate = finalExpiry;
            }
        }
        else
        {
            DbContext.FridgeItems.Add(new FridgeItem
                {
                    UserId = AuthService.CurrentUserId,
                    ProductId = selectedProductId,
                    Quantity = editQuantity,
                    ExpirationDate = finalExpiry,
                    AddedAt = DateTime.UtcNow
                });
        }

        await DbContext.SaveChangesAsync();
        await LoadData();
        CloseModal();
    }

    private void OpenDelete(FridgeItem item)
    {
        productToDelete = item;
        showDeleteModal = true;
    }

    private void CloseDelete()
    {
        productToDelete = null;
        showDeleteModal = false;
    }

    private async Task DeleteProduct()
    {
        if (productToDelete == null) return;

        var existing = await DbContext.FridgeItems.FindAsync(productToDelete.Id);
        if (existing != null)
        {
            DbContext.FridgeItems.Remove(existing);
            await DbContext.SaveChangesAsync();
        }

        await LoadData();
        CloseDelete();
    }
}