@page "/fridge"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ProductWebManager.Data.ProductManagerContext DbContext
@inject ProductWebManager.Services.AuthService AuthService
@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Models

<PageTitle>Холодильник</PageTitle>

<div class="page-bg">

    <div class="container-fluid p-4">

        <!-- HEADER -->
        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h2 class="fw-bold m-0 page-title">
                    Холодильник
                </h2>

                <small class="page-subtitle">
                    Управление продуктами
                </small>
            </div>

            <button class="btn btn-add"
                    @onclick="OpenAddModal">
                + Добавить продукт
            </button>

        </div>

        <!-- OVERVIEW -->
        <div class="top-overview">

            <div class="overview-card purple">
                <div class="overview-value">
                    @products.Count
                </div>

                <div class="overview-label">
                    Всего продуктов
                </div>
            </div>

            <div class="overview-card red">
                <div class="overview-value">
                    @expiringToday
                </div>

                <div class="overview-label">
                    Просрочено / сегодня
                </div>
            </div>

            <div class="overview-card orange">
                <div class="overview-value">
                    @expiringThisWeek
                </div>

                <div class="overview-label">
                    Истекает за неделю
                </div>
            </div>

            <div class="overview-card gray">
                <div class="overview-value">
                    @products.Count(x => !x.ExpirationDate.HasValue)
                </div>

                <div class="overview-label">
                    Без срока
                </div>
            </div>

        </div>

        <!-- FILTERS -->
        <div class="filter-bar">

            <div class="row g-3">

                <div class="col-md-5">

                    <input type="text"
                           class="form-control filter-input"
                           placeholder="🔍 Поиск продуктов..."
                           @bind="searchQuery"
                           @bind:event="oninput"
                           @bind:after="ApplyFilters" />

                </div>

                <div class="col-md-3">

                    <select class="form-control filter-input"
                            @bind="sortBy"
                            @bind:after="ApplyFilters">

                        <option value="expiry">
                            ⏰ По сроку
                        </option>

                        <option value="name">
                            📋 По названию
                        </option>

                        <option value="date">
                            🕐 По дате
                        </option>

                    </select>

                </div>

                <div class="col-md-4">

                    <select class="form-control filter-input"
                            @bind="filterCategory"
                            @bind:after="ApplyFilters">

                        <option value="">
                            🗂️ Все категории
                        </option>

                        @foreach (var cat in categories)
                        {
                            <option value="@cat.Id">
                                @cat.Name
                            </option>
                        }

                    </select>

                </div>

            </div>

        </div>

        @if (filteredProducts.Any())
        {
            <!-- EXPIRY SECTION -->
            @if (filteredProducts.Any(x => x.ExpirationDate.HasValue))
            {
                <div class="list-section-header"
                     @onclick="() => collapseExpiry = !collapseExpiry">

                    <div class="list-section-left">

                        <span class="section-arrow">
                            @(collapseExpiry ? "▶" : "▼")
                        </span>

                        <span>
                            Со сроком годности
                        </span>

                    </div>

                    <div class="section-counter">
                        @filteredProducts.Count(x => x.ExpirationDate.HasValue)
                    </div>

                </div>

                @if (!collapseExpiry)
                {
                    <div class="mb-4">

                        @foreach (var item in filteredProducts.Where(x => x.ExpirationDate.HasValue))
                        {
                            var daysLeft =
                            (item.ExpirationDate!.Value.Date - DateTime.Now.Date).TotalDays;

                            var totalDays = 14.0;

                            var progress =
                            Math.Max(0,
                            Math.Min(100,
                            (daysLeft / totalDays) * 100));

                            var statusClass =
                            daysLeft <= 0 ? "expired" :
                            daysLeft <= 3 ? "warning" :
                            "fresh";

                            var expiryText =
                            daysLeft <= 0 ? "Просрочен" :
                            daysLeft == 0 ? "Сегодня" :
                            $"{Math.Ceiling(daysLeft)} дн.";

                            <div class="inventory-item @statusClass">

                                <div class="inventory-accent @statusClass"></div>

                                <div class="inventory-image">
                                    🥛
                                </div>

                                <div class="inventory-content">

                                    <div class="inventory-top">

                                        <div>

                                            <div class="inventory-title">
                                                @item.Product?.Name
                                            </div>

                                            <div class="inventory-category">
                                                @(item.Product?.Category?.Name ?? "Без категории")
                                            </div>

                                        </div>

                                        <div class="inventory-expiry-block">

                                            <div class="inventory-expiry-date">
                                                @item.ExpirationDate?.ToString("dd.MM.yyyy")
                                            </div>

                                            <div class="inventory-status @statusClass">
                                                @expiryText
                                            </div>

                                        </div>

                                    </div>

                                    <div class="inventory-bottom">

                                        <div class="inventory-qty">
                                            @(item.Quanity ?? 0)
                                            @(item.Product?.Unit?.Name ?? "шт.")
                                        </div>

                                        <div class="inventory-progress">

                                            <div class="inventory-progress-fill @statusClass"
                                                 style="width:@($"{progress}%")">
                                            </div>

                                        </div>

                                        <div class="inventory-actions">

                                            <button class="tiny-btn edit"
                                                    @onclick="() => OpenEditModal(item)">
                                                Изменить
                                            </button>

                                            <button class="tiny-btn delete"
                                                    @onclick="() => ConfirmDeleteProduct(item)">
                                                Удалить
                                            </button>

                                        </div>

                                    </div>

                                </div>

                            </div>
                        }

                    </div>
                }
            }

            <!-- NO EXPIRY -->
            @if (filteredProducts.Any(x => !x.ExpirationDate.HasValue))
            {
                <div class="list-section-header"
                     @onclick="() => collapseNoExpiry = !collapseNoExpiry">

                    <div class="list-section-left">

                        <span class="section-arrow">
                            @(collapseNoExpiry ? "▶" : "▼")
                        </span>

                        <span>
                            Без срока годности
                        </span>

                    </div>

                    <div class="section-counter neutral">
                        @filteredProducts.Count(x => !x.ExpirationDate.HasValue)
                    </div>

                </div>

                @if (!collapseNoExpiry)
                {
                    @foreach (var item in filteredProducts.Where(x => !x.ExpirationDate.HasValue))
                    {
                        <div class="inventory-item noexpiry">

                            <div class="inventory-accent neutral"></div>

                            <div class="inventory-image neutral">
                                🥫
                            </div>

                            <div class="inventory-content">

                                <div class="inventory-top">

                                    <div>

                                        <div class="inventory-title">
                                            @item.Product?.Name
                                        </div>

                                        <div class="inventory-category">
                                            @(item.Product?.Category?.Name ?? "Без категории")
                                        </div>

                                    </div>

                                    <div class="inventory-status neutral">
                                        Без срока
                                    </div>

                                </div>

                                <div class="inventory-bottom">

                                    <div class="inventory-qty">
                                        @(item.Quanity ?? 0)
                                        @(item.Product?.Unit?.Name ?? "шт.")
                                    </div>

                                    <div class="inventory-noexpiry-line"></div>

                                    <div class="inventory-actions">

                                        <button class="tiny-btn edit"
                                                @onclick="() => OpenEditModal(item)">
                                            Изменить
                                        </button>

                                        <button class="tiny-btn delete"
                                                @onclick="() => ConfirmDeleteProduct(item)">
                                            Удалить
                                        </button>

                                    </div>

                                </div>

                            </div>

                        </div>
                    }
                }
            }
        }
        else
        {
            <div class="empty-state">

                <div class="empty-icon">
                    🧊
                </div>

                <h4 class="empty-title">
                    Холодильник пуст
                </h4>

                <p class="empty-text">
                    Добавьте продукты
                </p>

                <button class="btn btn-add"
                        @onclick="OpenAddModal">
                    Добавить продукт
                </button>

            </div>
        }

    </div>

</div>

<!-- MODAL -->
@if (showModal)
{
    <div class="modal-overlay">

        <div class="modal-dialog"
             @onclick:stopPropagation="true">

            <h4 class="modal-title">
                @(isEditing ? "Изменить" : "Добавить") продукт
            </h4>

            <div class="mb-3">

                <label class="form-label">
                    Продукт
                </label>

                <select class="form-control modal-input"
                        @bind="selectedProductId">

                    <option value="0">
                        -- Выберите продукт --
                    </option>

                    @foreach (var p in allProducts)
                    {
                        <option value="@p.Id">
                            @p.Name
                        </option>
                    }

                </select>

            </div>

            <div class="mb-3">

                <label class="form-label">
                    Количество
                </label>

                <input type="number"
                       class="form-control modal-input"
                       @bind="editQuantity"
                       min="0.1"
                       step="0.1" />

            </div>

            <div class="mb-4">

                <div class="d-flex justify-content-between align-items-center mb-2">

                    <label class="form-label m-0">
                        Срок годности
                    </label>

                    <div class="form-check">

                        <input class="form-check-input"
                               type="checkbox"
                               id="hasExpiry"
                               @bind="hasExpiryDate" />

                        <label class="form-check-label"
                               for="hasExpiry">
                            Есть срок
                        </label>

                    </div>

                </div>

                <input type="date"
                       class="form-control modal-input"
                       disabled="@(!hasExpiryDate)"
                       @bind="editExpiryDate" />

                @if (!hasExpiryDate)
                {
                    <div class="no-expiry-box mt-2">
                        Продукт без срока годности
                    </div>
                }

            </div>

            <div class="d-flex gap-2">

                <button class="btn-modal-save"
                        @onclick="SaveProduct">
                    Сохранить
                </button>

                <button class="btn-modal-cancel"
                        @onclick="CloseModal">
                    Отмена
                </button>

            </div>

        </div>

    </div>
}

@if (showDeleteConfirm)
{
    <div class="modal-overlay">

        <div class="modal-dialog"
             style="max-width:380px;"
             @onclick:stopPropagation="true">

            <h4 class="modal-title">
                Подтверждение
            </h4>

            <p class="delete-text">

                Удалить

                <strong class="delete-name">
                    @productToDelete?.Product?.Name
                </strong>?

            </p>

            <div class="d-flex gap-2">

                <button class="btn-modal-delete"
                        @onclick="DeleteProduct">
                    Удалить
                </button>

                <button class="btn-modal-cancel"
                        @onclick="CancelDelete">
                    Отмена
                </button>

            </div>

        </div>

    </div>
}

