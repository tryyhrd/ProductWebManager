@code {
    private List<FridgeItem> products = new();
    private List<FridgeItem> filteredProducts = new();
    private List<Product> allProducts = new();
    private List<Category> categories = new();
    private string searchQuery = "";
    private string sortBy = "expiry"; // ← По умолчанию сортировка по сроку
    private string filterCategory = "";
    private bool showModal = false;
    private bool isEditing = false;
    private bool showDeleteConfirm = false;
    private FridgeItem currentProduct = new();
    private FridgeItem? productToDelete;
    private int expiringToday = 0;
    private int expiringThisWeek = 0;
    private int selectedProductId;
    private double editQuantity = 1;
    private DateTime? editExpiryDate = DateTime.Now.AddDays(7);

    private string editExpiryDateString
    {
        get => editExpiryDate?.ToString("yyyy-MM-dd") ?? "";
        set
        {
            if (string.IsNullOrEmpty(value))
                editExpiryDate = null;
            else if (DateTime.TryParse(value, out var date))
                editExpiryDate = date;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            products = await DbContext.FridgeItems
                .Include(f => f.Product).ThenInclude(p => p.Unit)
                .Include(f => f.Product).ThenInclude(p => p.Category)
                .Where(f => f.UserId == 1)
                .ToListAsync();

            allProducts = await DbContext.Products
                .Include(p => p.Unit).Include(p => p.Category)
                .ToListAsync();

            categories = await DbContext.Categories.ToListAsync();
        }
        catch (Exception ex) { Console.WriteLine($"Ошибка загрузки: {ex.Message}"); }

        UpdateStats();
        ApplyFilters();
        StateHasChanged();
    }

    private void UpdateStats()
    {
        expiringToday = products.Count(p => p.ExpirationDate.HasValue && p.ExpirationDate.Value.Date == DateTime.Now.Date);
        expiringThisWeek = products.Count(p => p.ExpirationDate.HasValue && p.ExpirationDate.Value.Date > DateTime.Now.Date && p.ExpirationDate.Value.Date <= DateTime.Now.AddDays(7).Date);
    }

    private void ApplyFilters()
    {
        var query = products.AsEnumerable();

        // Поиск
        if (!string.IsNullOrWhiteSpace(searchQuery))
            query = query.Where(p => p.Product?.Name != null && p.Product.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));

        // Фильтр по категории
        if (!string.IsNullOrEmpty(filterCategory) && int.TryParse(filterCategory, out int catId))
            query = query.Where(p => p.Product?.CategoryId == catId);

        // Сортировка
        filteredProducts = sortBy switch
        {
            "name" => query.OrderBy(p => p.Product?.Name).ToList(),
            "date" => query.OrderByDescending(p => p.AddetAt).ToList(),
            "expiry" => query.OrderBy(p => p.ExpirationDate ?? DateTime.MaxValue).ToList(),
            _ => query.OrderBy(p => p.ExpirationDate ?? DateTime.MaxValue).ToList()
        };

        StateHasChanged();
    }

    private void OpenAddModal()
    {
        currentProduct = new FridgeItem();
        selectedProductId = 0;
        editQuantity = 1;
        editExpiryDate = DateTime.Now.AddDays(7);
        isEditing = false;
        showModal = true;
    }

    private void OpenEditModal(FridgeItem item)
    {
        currentProduct = item;
        selectedProductId = item.ProductId;
        editQuantity = item.Quanity ?? 1;
        editExpiryDate = item.ExpirationDate;
        isEditing = true;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        StateHasChanged();
    }

    private async Task SaveProduct()
    {
        if (selectedProductId == 0) return;

        try
        {
            if (isEditing)
            {
                var existing = await DbContext.FridgeItems.FindAsync(currentProduct.Id);
                if (existing != null)
                {
                    existing.ProductId = selectedProductId;
                    existing.Quanity = editQuantity;
                    existing.ExpirationDate = editExpiryDate;
                }
            }
            else
            {
                DbContext.FridgeItems.Add(new FridgeItem
                    {
                        UserId = 1,
                        ProductId = selectedProductId,
                        Quanity = editQuantity,
                        ExpirationDate = editExpiryDate,
                        AddetAt = DateTime.UtcNow
                    });
            }

            await DbContext.SaveChangesAsync();
            await LoadData();
            CloseModal();
        }
        catch (Exception ex) { Console.WriteLine($"Ошибка сохранения: {ex.Message}"); }
    }

    private void ConfirmDeleteProduct(FridgeItem item)
    {
        productToDelete = item;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        productToDelete = null;
    }

    private async Task DeleteProduct()
    {
        if (productToDelete == null) return;
        try
        {
            var item = await DbContext.FridgeItems.FindAsync(productToDelete.Id);
            if (item != null)
            {
                DbContext.FridgeItems.Remove(item);
                await DbContext.SaveChangesAsync();
            }
            await LoadData();
        }
        catch (Exception ex) { Console.WriteLine($"Ошибка удаления: {ex.Message}"); }
        CancelDelete();
    }

    private async Task UpdateQuantity(FridgeItem item, int delta)
    {
        var newQty = (item.Quanity ?? 0) + delta;
        if (newQty <= 0)
        {
            ConfirmDeleteProduct(item);
            return;
        }

        try
        {
            var existing = await DbContext.FridgeItems.FindAsync(item.Id);
            if (existing != null)
            {
                existing.Quanity = newQty;
                await DbContext.SaveChangesAsync();
                await LoadData();
            }
        }
        catch (Exception ex) { Console.WriteLine($"Ошибка: {ex.Message}"); }
    }
}