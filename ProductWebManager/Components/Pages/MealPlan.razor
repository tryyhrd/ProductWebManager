@code
{
    private static readonly CultureInfo RuCulture = CultureInfo.GetCultureInfo("ru-RU");

    private const double DailyTolerance = 0.05;
    private const int MinMealCalories = 150;

    private static readonly SemaphoreSlim _productCreationLock = new(1, 1);

    private UserProfile profile = new();
    private GoalType selectedGoal = GoalType.Maintain;
    private bool useFridgeProducts = true;
    private int daysToGenerate = 7;
    private bool isGenerating = false;

    private bool showModal = false;
    private string modalTitle = "";
    private string modalMessage = "";
    private ModalType currentModalType = ModalType.Info;
    private int? _lastCreatedShoppingListId;

    private enum ModalType { Info, Warning, Error, Success }

    private int targetCalories;
    private int targetProteins;
    private int targetFats;
    private int targetCarbs;

    private List<MealPlanDay> mealPlanDays = new();

    public class MealPlanDay
    {
        public DateTime Date { get; set; }
        public bool IsExpanded { get; set; }
        public List<MealPlanMeal> Meals { get; set; } = new();
    }

    public class MealPlanMeal
    {
        public MealType MealType { get; set; }
        public Recipe? Recipe { get; set; }
        public string Title { get; set; } = "";
        public string Description { get; set; } = "";
        public bool IsSnack { get; set; }
        public int TargetCalories { get; set; }
        public int Calories { get; set; }
        public int Proteins { get; set; }
        public int Fats { get; set; }
        public int Carbs { get; set; }
    }

    private sealed record CreatedRecipeResult(Recipe Recipe, MealNutrition Nutrition);

    protected override async Task OnInitializedAsync()
    {
        await using var context = await DbContextFactory.CreateDbContextAsync();

        var user = await context.Users
            .Include(x => x.Profile)
            .FirstOrDefaultAsync(x => x.Id == AuthService.CurrentUserId);

        if (user == null)
        {
            Logger.LogWarning("Пользователь {UserId} не найден", AuthService.CurrentUserId);
            return;
        }

        profile = user.Profile ?? new UserProfile();
        selectedGoal = profile.Goal;

        CalculateTargets();
        await LoadExistingPlan();
    }

    private void CalculateTargets()
    {
        double calories =
            profile.Gender == Gender.Male
                ? 10 * profile.Weight + 6.25 * profile.Height - 5 * profile.Age + 5
                : 10 * profile.Weight + 6.25 * profile.Height - 5 * profile.Age - 161;

        calories *= profile.ActivityLevel switch
        {
            ActivityLevel.Low => 1.2,
            ActivityLevel.Medium => 1.55,
            ActivityLevel.High => 1.8,
            _ => 1.2
        };

        calories = selectedGoal switch
        {
            GoalType.LoseWeight => calories - 300,
            GoalType.GainWeight => calories + 300,
            _ => calories
        };

        targetCalories = (int)Math.Round(calories);
        targetProteins = (int)Math.Round(calories * 0.30 / 4.0);
        targetFats = (int)Math.Round(calories * 0.25 / 9.0);
        targetCarbs = (int)Math.Round(calories * 0.45 / 4.0);
    }

    private async Task LoadExistingPlan()
    {
        await using var context = await DbContextFactory.CreateDbContextAsync();

        mealPlanDays.Clear();

        var latestPlan = await context.MealPlans
            .AsNoTracking()
            .Include(x => x.Items)
                .ThenInclude(x => x.Recipe)
            .Where(x => x.UserId == AuthService.CurrentUserId)
            .OrderByDescending(x => x.CreatedAt)
            .FirstOrDefaultAsync();

        if (latestPlan == null || latestPlan.Items == null || latestPlan.Items.Count == 0)
            return;

        foreach (var group in latestPlan.Items
                     .GroupBy(x => x.Date.Date)
                     .OrderBy(x => x.Key))
        {
            var day = new MealPlanDay
                {
                    Date = group.Key,
                    IsExpanded = group.Key == DateTime.Today,
                    Meals = group
                                .OrderBy(x => GetMealSortOrder(x.MealType))
                                .Select(x => new MealPlanMeal
                                {
                                    MealType = x.MealType,
                                    Recipe = x.Recipe,
                                    Title = x.Recipe?.Title ?? string.Empty,
                                    Description = x.Recipe?.Description ?? string.Empty,
                                    IsSnack = x.MealType == MealType.Snack,
                                    Calories = x.Calories,
                                    Proteins = x.Proteins,
                                    Fats = x.Fats,
                                    Carbs = x.Carbs
                                })
                                .ToList()
                };

            mealPlanDays.Add(day);
        }
    }

    private async Task AdjustRecipeForFridgeAsync(Recipe recipe, List<FridgeItem> fridgeItems)
    {
        if (fridgeItems == null || !fridgeItems.Any()) return;

        var fridgeProducts = fridgeItems
            .Where(f => f.Product != null && f.Quantity.HasValue)
            .Select(f => new
            {
                ProductId = f.Product!.Id,
                AvailableQty = f.Quantity.Value,
                FridgeItem = f
            })
            .ToList();

        foreach (var ingredient in recipe.RecipeIngredients)
        {
            var fridgeMatch = fridgeProducts.FirstOrDefault(f => f.ProductId == ingredient.ProductId);
            if (fridgeMatch == null) continue;

            double currentQty = ingredient.Quantity;
            double availableQty = fridgeMatch.AvailableQty;

            if (currentQty < availableQty && availableQty <= 500)
            {
                ingredient.Quantity = Math.Min(availableQty, currentQty * 1.5);
                Logger.LogDebug("Скорректирован ингредиент {Name}: {Old} → {New} г (холодильник)",
                    ingredient.Product?.Name, currentQty, ingredient.Quantity);
            }
        }

        await Task.CompletedTask;
    }

    private bool IsFridgeValid(List<FridgeItem> fridgeItems, int daysCount)
    {
        if (!useFridgeProducts) return true;

        if (fridgeItems == null || !fridgeItems.Any())
            return false;

        var uniqueProducts = fridgeItems
            .Where(f => f.Product != null && f.Quantity > 0)
            .Select(f => f.Product!.Id)
            .Distinct()
            .Count();

        int requiredProducts = Math.Max(5, daysCount * 5);

        return uniqueProducts >= requiredProducts;
    }

    private bool IsProfileValid(UserProfile p)
    {
        if (p == null) return false;

        if (p.Age is not (> 0 and < 120)) return false;
        if (p.Height is not (> 50 and < 250)) return false;
        if (p.Weight is not (> 20 and < 300)) return false;

        if (!Enum.IsDefined(typeof(Gender), p.Gender)) return false;
        if (!Enum.IsDefined(typeof(ActivityLevel), p.ActivityLevel)) return false;

        return true;
    }

    private async Task GenerateMealPlanAsync()
    {
        if (isGenerating) return;

        if (!IsProfileValid(profile))
        {
            ShowModal("Профиль не заполнен",
                "Для генерации плана питания заполните профиль: возраст, вес, рост, пол и уровень активности.",
                ModalType.Warning);
            return;
        }

        var fridgeItems = new List<FridgeItem>();
        if (useFridgeProducts)
        {
            await using var context = await DbContextFactory.CreateDbContextAsync();

            fridgeItems = await context.FridgeItems
                .Include(x => x.Product)
                    .ThenInclude(x => x.Unit)
                .Where(x => x.UserId == AuthService.CurrentUserId && x.Quantity > 0)
                .ToListAsync();

            if (!IsFridgeValid(fridgeItems, daysToGenerate))
            {
                int uniqueCount = fridgeItems
                    .Where(f => f.Product != null && f.Quantity > 0)
                    .Select(f => f.Product!.Id)
                    .Distinct()
                    .Count();
                int required = Math.Max(5, daysToGenerate * 5);

                ShowModal("Недостаточно продуктов",
                    $"Для плана на {daysToGenerate} дн. нужно минимум {required} уникальных продуктов в холодильнике.\n" +
                    $"Сейчас доступно: {uniqueCount}.\n\n" +
                    "Добавьте продукты или отключите опцию «Использовать продукты из холодильника».",
                    ModalType.Warning);
                return;
            }
        }

        isGenerating = true;
        StateHasChanged();

        try
        {
            Logger.LogInformation("Начало генерации плана: {Days} дней, цель {Goal}", daysToGenerate, selectedGoal);

            CalculateTargets();
            mealPlanDays.Clear();

            await using var context = await DbContextFactory.CreateDbContextAsync();

            var oldPlans = await context.MealPlans
                .Include(x => x.Items)
                .Where(x => x.UserId == AuthService.CurrentUserId)
                .ToListAsync();

            if (oldPlans.Any())
            {
                context.MealPlanItems.RemoveRange(oldPlans.SelectMany(x => x.Items));
                context.MealPlans.RemoveRange(oldPlans);
                await context.SaveChangesAsync();
                Logger.LogInformation("Удалено {Count} старых планов", oldPlans.Count);
            }

            var recipeTitles = await context.Recipes
                .Where(x => x.Title != null)
                .Select(x => x.Title!)
                .ToListAsync();

            var fridgeProductNames = fridgeItems
                .Where(x => x.Product != null && !string.IsNullOrWhiteSpace(x.Product.Name))
                .Select(x => x.Product!.Name)
                .Distinct()
                .ToList();

            Logger.LogInformation("Запрос структуры плана к ИИ...");
            var structure = await GigaChatHelper.GenerateMealPlanStructureAsync(
                profile, daysToGenerate, selectedGoal,
                targetCalories, targetProteins, targetFats, targetCarbs,
                useFridgeProducts, "balanced", recipeTitles, fridgeProductNames);

            if (structure?.Days == null || structure.Days.Count == 0)
            {
                ShowModal("Ошибка генерации",
                    "Не удалось получить структуру плана от ИИ. Попробуйте позже.",
                    ModalType.Error);
                return;
            }

            Logger.LogInformation("Получена структура: {DaysCount} дней", structure.Days.Count);

            var mealPlan = new Models.MealPlan
                {
                    UserId = AuthService.CurrentUserId,
                    Name = string.IsNullOrWhiteSpace(structure.Name)
                                ? $"План питания {DateTime.Today:dd.MM.yyyy}"
                                : structure.Name.Trim(),
                    CreatedAt = DateTime.UtcNow
                };

            context.MealPlans.Add(mealPlan);
            await context.SaveChangesAsync();

            foreach (var generatedDay in structure.Days.OrderBy(x => x.DayNumber))
            {
                var date = DateTime.Today.AddDays(Math.Max(0, generatedDay.DayNumber - 1));
                var day = new MealPlanDay { Date = date, IsExpanded = date.Date == DateTime.Today };
                await ProcessDayAIFirst(day, generatedDay.Meals, mealPlan, date, fridgeItems);
                Logger.LogInformation("Обработан день {Date}: {MealsCount} приёмов пищи", date, day.Meals.Count);
            }

            ShowModal("План готов!",
                $"План питания на {daysToGenerate} дней успешно сгенерирован.",
                ModalType.Success);
            Logger.LogInformation("Генерация плана завершена успешно");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Ошибка при генерации плана питания");
            ShowModal("Ошибка",
                $"Произошла ошибка: {ex.Message}\nПопробуйте ещё раз.",
                ModalType.Error);
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }

