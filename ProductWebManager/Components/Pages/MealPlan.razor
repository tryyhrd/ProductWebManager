    private MealType ParseMealType(string mealType)
    {
        return NormalizeForSearch(mealType) switch
        {
            var s when s.Contains("завтрак") || s.Contains("breakfast") => MealType.Breakfast,
            var s when s.Contains("обед") || s.Contains("lunch") => MealType.Lunch,
            var s when s.Contains("ужин") || s.Contains("dinner") => MealType.Dinner,
            var s when s.Contains("перекус") || s.Contains("snack") => MealType.Snack,
            _ => MealType.Snack
        };
    }

    private static int GetMealSortOrder(MealType mealType)
    {
        return mealType switch
        {
            MealType.Breakfast => 0,
            MealType.Lunch => 1,
            MealType.Dinner => 2,
            MealType.Snack => 3,
            _ => 4
        };
    }

    private string GetMealTypeText(MealType type)
    {
        return type switch
        {
            MealType.Breakfast => "Завтрак",
            MealType.Lunch => "Обед",
            MealType.Dinner => "Ужин",
            MealType.Snack => "Перекус",
            _ => ""
        };
    }

    private string GetMealIcon(MealType type)
    {
        return type switch
        {
            MealType.Breakfast => "🌅",
            MealType.Lunch => "🍲",
            MealType.Dinner => "🌙",
            MealType.Snack => "🍎",
            _ => "🍽️"
        };
    }

    private static string NormalizeForSearch(string? value)
    {
        if (string.IsNullOrWhiteSpace(value)) return string.Empty;

        return string.Join(" ",
            value
                .ToLowerInvariant()
                .Replace("ё", "е")
                .Replace("-", " ")
                .Replace(",", " ")
                .Replace(".", " ")
                .Replace("(", " ")
                .Replace(")", " ")
                .Split(' ', StringSplitOptions.RemoveEmptyEntries)
                .OrderBy(x => x)
        );
    }

    private static string NormalizeUnit(string? value)
    {
        var unit = NormalizeForSearch(value);

        return unit switch
        {
            var s when s.Contains("гр") || s.Contains("грамм") => "г",
            var s when s.Contains("шт") || s.Contains("штука") => "шт",
            var s when s.Contains("мл") || s.Contains("миллилитр") => "мл",
            var s when s.Contains("л") || s.Contains("литр") => "л",
            _ => unit
        };
    }

    private async Task CreateShoppingListAsync()
    {
        if (!mealPlanDays.Any())
        {
            ShowModal("Нет плана", "Сначала сгенерируйте план питания.", ModalType.Warning);
            return;
        }

        try
        {
            await using var context = await DbContextFactory.CreateDbContextAsync();

            // Создаем новый список покупок
            var shoppingList = new Models.ShoppingList
                {
                    UserId = AuthService.CurrentUserId,
                    Name = $"План питания {DateTime.Today:dd.MM.yyyy}",
                    CreatedAt = DateTime.UtcNow,
                    IsCompleted = false
                };

            context.ShoppingList.Add(shoppingList);
            await context.SaveChangesAsync();

            // Собираем все ID рецептов из плана
            var recipeIds = mealPlanDays
                .SelectMany(d => d.Meals)
                .Where(m => m.Recipe != null)
                .Select(m => m.Recipe!.Id)
                .Distinct()
                .ToList();

            // Загружаем рецепты с ингредиентами из БД
            var recipesWithIngredients = await context.Recipes
                .Include(r => r.RecipeIngredients)
                    .ThenInclude(ri => ri.Product)
                        .ThenInclude(p => p.Unit)
                .Where(r => recipeIds.Contains(r.Id))
                .ToListAsync();  // Сначала получаем данные

            var recipeDict = recipesWithIngredients.ToDictionary(r => r.Id);  // Потом создаем словарь

            // Собираем все ингредиенты из плана
            var ingredientGroups = new Dictionary<int, (string ProductName, double TotalQuantity, string UnitName)>();

            foreach (var day in mealPlanDays)
            {
                foreach (var meal in day.Meals)
                {
                    if (meal.Recipe == null) continue;

                    // Получаем рецепт с ингредиентами из загруженных данных
                    if (!recipeDict.TryGetValue(meal.Recipe.Id, out var recipeWithIngredients))
                        continue;

                    if (recipeWithIngredients.RecipeIngredients == null)
                        continue;

                    foreach (var ingredient in recipeWithIngredients.RecipeIngredients)
                    {
                        if (ingredient.Product == null) continue;

                        var productId = ingredient.ProductId;
                        var quantity = ingredient.Quantity;

                        if (ingredientGroups.ContainsKey(productId))
                        {
                            var existing = ingredientGroups[productId];
                            ingredientGroups[productId] = (
                                existing.ProductName,
                                existing.TotalQuantity + quantity,
                                existing.UnitName
                            );
                        }
                        else
                        {
                            ingredientGroups[productId] = (
                                ingredient.Product.Name,
                                quantity,
                                ingredient.Product.Unit?.Name ?? "шт."
                            );
                        }
                    }
                }
            }

            if (!ingredientGroups.Any())
            {
                ShowModal("Нет ингредиентов",
                    "В плане питания не найдено ингредиентов для создания списка покупок.",
                    ModalType.Warning);
                return;
            }

            // Добавляем ингредиенты в список покупок
            foreach (var group in ingredientGroups)
            {
                var shoppingItem = new ShoppingListItem
                    {
                        ShoppingListId = shoppingList.Id,
                        ProductId = group.Key,
                        Quantity = Math.Round(group.Value.TotalQuantity, 1),
                        IsPurchased = false
                    };

                context.ShoppingListItems.Add(shoppingItem);
            }

            await context.SaveChangesAsync();

            Logger.LogInformation("Создан список покупок из {MealsCount} приемов пищи, {ProductsCount} продуктов",
                mealPlanDays.Sum(d => d.Meals.Count), ingredientGroups.Count);

            ShowModal("Список покупок создан!",
                $"Создан список покупок \"{shoppingList.Name}\"\n" +
                $"Содержит {ingredientGroups.Count} продуктов.\n\n" +
                "Перейти к списку покупок?",
                ModalType.Success);

            // Сохраняем ID списка для возможного перехода
            _lastCreatedShoppingListId = shoppingList.Id;
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Ошибка при создании списка покупок из плана питания");
            ShowModal("Ошибка",
                $"Не удалось создать список покупок: {ex.Message}",
                ModalType.Error);
        }
    }

    private bool isReplacing = false;

    private async Task ReplaceMeal(MealPlanDay day, MealPlanMeal mealToReplace)
    {
        if (isReplacing) return;

        try
        {
            isReplacing = true;
            StateHasChanged();

            Logger.LogInformation("Замена рецепта: {Title} в день {Date}", mealToReplace.Title, day.Date);

            // Получаем список существующих названий для избежания повторов
            var existingTitles = mealPlanDays
                .SelectMany(d => d.Meals)
                .Where(m => m != mealToReplace) // исключаем заменяемое блюдо
                .Select(m => m.Title)
                .Distinct()
                .ToList();

            // Получаем продукты из холодильника (если нужно)
            List<string>? fridgeProductNames = null;
            if (useFridgeProducts)
            {
                await using var context = await DbContextFactory.CreateDbContextAsync();
                fridgeProductNames = await context.FridgeItems
                    .Include(f => f.Product)
                    .Where(f => f.UserId == AuthService.CurrentUserId && f.Quantity > 0)
                    .Select(f => f.Product!.Name)
                    .Distinct()
                    .ToListAsync();
            }

            // Ищем замену через ИИ
            var replacement = await GigaChatHelper.FindReplacementRecipeAsync(
                mealToReplace.Title,
                mealToReplace.MealType,
                mealToReplace.TargetCalories,
                mealToReplace.IsSnack,
                profile,
                selectedGoal,
                existingTitles,
                fridgeProductNames);

            if (replacement == null)
            {
                ShowModal("Не удалось найти замену",
                    "Попробуйте ещё раз или выберите другое блюдо для замены.",
                    ModalType.Warning);
                return;
            }

            // Создаем новый рецепт
            var recipeResult = await BuildRecipeAsync(
                replacement.Title,
                mealToReplace.TargetCalories,
                replacement.IsSnack,
                replacement.MealType,
                profile,
                selectedGoal);

            if (recipeResult == null)
            {
                ShowModal("Ошибка создания рецепта",
                    "Не удалось создать рецепт для замены.",
                    ModalType.Error);
                return;
            }

            // Заменяем блюдо в плане
            var index = day.Meals.IndexOf(mealToReplace);
            if (index >= 0)
            {
                day.Meals[index] = CreateMealPlanMeal(
                    new MealStructureDto
                        {
                            MealType = replacement.MealType,
                            Title = replacement.Title,
                            IsSnack = replacement.IsSnack,
                            TargetCalories = mealToReplace.TargetCalories
                        },
                    recipeResult,
                    mealToReplace.TargetCalories);

                Logger.LogInformation("Рецепт заменён: {OldTitle} → {NewTitle}",
                    mealToReplace.Title, replacement.Title);

                ShowModal("Рецепт заменён!",
                    $"Блюдо \"{mealToReplace.Title}\" заменено на \"{replacement.Title}\"",
                    ModalType.Success);
            }

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Ошибка при замене рецепта \"{Title}\"", mealToReplace.Title);
            ShowModal("Ошибка",
                $"Не удалось заменить рецепт: {ex.Message}",
                ModalType.Error);
        }
        finally
        {
            isReplacing = false;
            StateHasChanged();
        }
    }

    public void Dispose()
    {
        _productCreationLock?.Dispose();
    }
