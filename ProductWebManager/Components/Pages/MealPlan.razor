    private async Task ProcessDayAIFirst(MealPlanDay day, List<MealStructureDto> aiMeals,
        Models.MealPlan mealPlan, DateTime date, List<FridgeItem>? fridgeItems = null)
    {
        if (aiMeals == null || aiMeals.Count == 0) return;

        int aiTotalCalories = aiMeals.Sum(m => m.TargetCalories);

        if (aiTotalCalories <= 0 || Math.Abs(aiTotalCalories - targetCalories) > targetCalories * 0.3)
        {
            Logger.LogWarning("Некорректное распределение калорий от ИИ ({AiTotal} vs {Target}), используем fallback",
                aiTotalCalories, targetCalories);

            var shares = new[] { 0.25, 0.35, 0.25, 0.15 };
            for (int i = 0; i < Math.Min(aiMeals.Count, shares.Length); i++)
            {
                aiMeals[i].TargetCalories = Math.Max(MinMealCalories, (int)(targetCalories * shares[i]));
            }
        }

        foreach (var meal in aiMeals)
        {
            if (meal.IsSnack || ParseMealType(meal.MealType) == MealType.Snack)
            {
                meal.TargetCalories = Math.Min(meal.TargetCalories, (int)(targetCalories * 0.2));
            }
            meal.TargetCalories = Math.Max(MinMealCalories, meal.TargetCalories);
        }

        NormalizeMealTargets(aiMeals);

        var createdMeals = new List<MealPlanMeal>();

        foreach (var meal in aiMeals)
        {
            try
            {
                var recipeResult = await BuildRecipeAsync(
                    meal.Title, meal.TargetCalories, meal.IsSnack, meal.MealType, profile, selectedGoal, fridgeItems);

                if (recipeResult != null)
                {
                    createdMeals.Add(CreateMealPlanMeal(meal, recipeResult, meal.TargetCalories));
                    Logger.LogDebug("Создан рецепт: {Title} ({Calories} ккал)",
                        recipeResult.Recipe.Title, recipeResult.Nutrition.Calories);
                }
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Ошибка при создании рецепта \"{Title}\"", meal.Title);
            }
        }

        if (!createdMeals.Any())
        {
            Logger.LogError("Не удалось создать ни одного рецепта для дня {Date}", date);
            return;
        }

        int actualTotal = createdMeals.Sum(m => m.Calories);
        double error = targetCalories > 0
            ? Math.Abs(actualTotal - targetCalories) / (double)targetCalories
            : 0;

        Logger.LogInformation("Дневная калорийность: {Actual}/{Target} ккал (отклонение {Error}%)",
            actualTotal, targetCalories, error * 100);

        if (error > DailyTolerance)
        {
            Logger.LogWarning("Отклонение {Error}% превышает допуск {Tolerance}%, применяем коррекцию",
                error * 100, DailyTolerance * 100);

            double factor = Math.Clamp((double)targetCalories / actualTotal, 0.9, 1.1);

            foreach (var meal in createdMeals.Where(m => m.Recipe != null))
            {
                int newTarget = Math.Max(MinMealCalories, (int)Math.Round(meal.Calories * factor));
                var nutrition = RecipeNutritionAdjuster.ScaleRecipeToTarget(meal.Recipe!, newTarget);

                meal.Calories = (int)Math.Round(nutrition.Calories);
                meal.Proteins = (int)Math.Round(nutrition.Proteins);
                meal.Fats = (int)Math.Round(nutrition.Fats);
                meal.Carbs = (int)Math.Round(nutrition.Carbs);
            }

            actualTotal = createdMeals.Sum(m => m.Calories);
            error = targetCalories > 0
                ? Math.Abs(actualTotal - targetCalories) / (double)targetCalories
                : 0;

            if (error > DailyTolerance)
            {
                Logger.LogWarning("После коррекции отклонение {Error}% всё ещё велико, заменяем один приём", error * 100);

                var worstMeal = createdMeals
                    .Where(m => m.Recipe != null)
                    .OrderByDescending(m => Math.Abs(m.Calories - m.TargetCalories))
                    .FirstOrDefault();

                if (worstMeal != null)
                {
                    int correctionTarget = worstMeal.Calories + (targetCalories - actualTotal);
                    correctionTarget = Math.Max(MinMealCalories, correctionTarget);

                    var originalMeal = aiMeals.First(m =>
                        ParseMealType(m.MealType) == worstMeal.MealType);

                    var newRecipe = await BuildRecipeAsync(
                        originalMeal.Title, correctionTarget, originalMeal.IsSnack,
                        originalMeal.MealType, profile, selectedGoal);

                    if (newRecipe != null)
                    {
                        int idx = createdMeals.IndexOf(worstMeal);
                        createdMeals[idx] = CreateMealPlanMeal(originalMeal, newRecipe, correctionTarget);
                        Logger.LogInformation("Заменён рецепт: {Title}", newRecipe.Recipe.Title);
                    }
                }
            }
        }

        await using var context = await DbContextFactory.CreateDbContextAsync();

        foreach (var meal in createdMeals.Where(m => m.Recipe != null))
        {
            context.MealPlanItems.Add(new MealPlanItem
                {
                    MealPlanId = mealPlan.Id,
                    RecipeId = meal.Recipe!.Id,
                    Date = date,
                    MealType = meal.MealType,
                    Calories = meal.Calories,
                    Proteins = meal.Proteins,
                    Fats = meal.Fats,
                    Carbs = meal.Carbs
                });
        }

        day.Meals.AddRange(createdMeals.OrderBy(m => GetMealSortOrder(m.MealType)));
        mealPlanDays.Add(day);
        await context.SaveChangesAsync();
    }

    private void NormalizeMealTargets(List<MealStructureDto> meals)
    {
        if (meals == null || meals.Count == 0) return;

        int total = meals.Sum(m => m.TargetCalories);
        if (total == 0 || total == targetCalories) return;

        int diff = targetCalories - total;
        var sortedMeals = meals
            .Select((m, i) => (meal: m, index: i))
            .OrderByDescending(x => x.meal.TargetCalories)
            .ToList();

        foreach (var (meal, _) in sortedMeals)
        {
            if (diff == 0) break;

            int sign = diff > 0 ? 1 : -1;
            int adjustment = sign * Math.Min(Math.Abs(diff), 50);
            adjustment = Math.Clamp(adjustment, -meal.TargetCalories / 4, meal.TargetCalories / 4);

            meal.TargetCalories = Math.Max(MinMealCalories, meal.TargetCalories + adjustment);
            diff -= adjustment;
        }

        if (diff != 0)
        {
            var mainMeal = sortedMeals
                .FirstOrDefault(x => !x.meal.IsSnack && ParseMealType(x.meal.MealType) != MealType.Snack)
                .meal ?? sortedMeals.First().meal;

            mainMeal.TargetCalories = Math.Max(MinMealCalories, mainMeal.TargetCalories + diff);
        }
    }

    private MealPlanMeal CreateMealPlanMeal(
        MealStructureDto meal,
        CreatedRecipeResult recipeResult,
        int targetCalories)
    {
        return new MealPlanMeal
            {
                MealType = ParseMealType(meal.MealType),
                Recipe = recipeResult.Recipe,
                Title = recipeResult.Recipe.Title ?? meal.Title,
                Description = recipeResult.Recipe.Description ?? string.Empty,
                IsSnack = meal.IsSnack,
                TargetCalories = targetCalories,
                Calories = (int)Math.Round(recipeResult.Nutrition.Calories),
                Proteins = (int)Math.Round(recipeResult.Nutrition.Proteins),
                Fats = (int)Math.Round(recipeResult.Nutrition.Fats),
                Carbs = (int)Math.Round(recipeResult.Nutrition.Carbs)
            };
    }

    private async Task<Recipe?> FindExistingRecipeAsync(string title)
    {
        await using var context = await DbContextFactory.CreateDbContextAsync();

        var normalizedTitle = NormalizeForSearch(title);

        var allRecipes = await context.Recipes
            .Include(x => x.RecipeIngredients)
                .ThenInclude(x => x.Product)
            .ToListAsync();

        var exact = allRecipes
            .FirstOrDefault(x => NormalizeForSearch(x.Title) == normalizedTitle);

        if (exact != null) return exact;

        var keywords = normalizedTitle
            .Split(' ', StringSplitOptions.RemoveEmptyEntries)
            .Where(k => k.Length > 3)
            .Take(3)
            .ToList();

        if (keywords.Any())
        {
            foreach (var candidate in allRecipes)
            {
                var candidateNormalized = NormalizeForSearch(candidate.Title);
                if (keywords.All(k => candidateNormalized.Contains(k)))
                    return candidate;
            }
        }

        return null;
    }

    private async Task<CreatedRecipeResult?> BuildRecipeAsync(
    string title,
    int targetCalories,
    bool isSnack,
    string? mealType,
    UserProfile? profile,
    GoalType? goal,
    List<FridgeItem>? fridgeItems = null)
    {
        var existingRecipe = await FindExistingRecipeAsync(title);
        if (existingRecipe != null)
        {
            Logger.LogDebug("Найден существующий рецепт: {Title}", existingRecipe.Title);
            var existingNutrition = RecipeNutritionAdjuster.AdjustRecipeToTarget(existingRecipe, targetCalories);
            return new CreatedRecipeResult(existingRecipe, existingNutrition);
        }

        var meal = await GigaChatHelper.GenerateRecipeByTitleAsync(
            title, targetCalories, isSnack, mealType, profile, goal);

        if (meal == null)
        {
            Logger.LogWarning("ИИ не вернул рецепт для \"{Title}\"", title);
            return null;
        }

        var recipe = new Recipe
            {
                Title = meal.Title,
                Description = meal.Description,
                Instructions = string.Join("\n", meal.Instructions ?? new List<string>()),
                PrepTime = meal.IsSnack ? 5 : 15,
                CookTime = meal.IsSnack ? 0 : 20,
                ImageUrl = "",
                RecipeIngredients = new List<RecipeIngredient>()
            };

        await using var context = await DbContextFactory.CreateDbContextAsync();

        // Загружаем все данные в память перед фильтрацией
        var allUnits = await context.Units.ToListAsync();
        var allCategories = await context.Categories.ToListAsync();
        var allProducts = await context.Products
            .Include(x => x.Unit)
            .Include(x => x.Category)
            .ToListAsync();

        foreach (var ingredient in meal.Ingredients ?? new List<GigaChatHelper.GeneratedIngredientDto>())
        {
            var normalizedIngredientName = NormalizeForSearch(ingredient.Name);
            var normalizedUnit = NormalizeUnit(ingredient.Unit);
            var normalizedCategory = NormalizeForSearch(ingredient.Category);

            // Ищем unit в памяти
            var unit = allUnits.FirstOrDefault(x => NormalizeUnit(x.Name) == normalizedUnit);

            if (unit == null)
            {
                unit = new Unit
                    {
                        Name = string.IsNullOrWhiteSpace(ingredient.Unit) ? "г" : ingredient.Unit.Trim()
                    };
                context.Units.Add(unit);
                await context.SaveChangesAsync();
                allUnits.Add(unit);
            }

            // Ищем category в памяти
            var category = allCategories.FirstOrDefault(x => NormalizeForSearch(x.Name) == normalizedCategory);

            if (category == null)
            {
                category = new Category
                    {
                        Name = string.IsNullOrWhiteSpace(ingredient.Category) ? "Другое" : ingredient.Category.Trim()
                    };
                context.Categories.Add(category);
                await context.SaveChangesAsync();
                allCategories.Add(category);
            }

            Product? product = null;
            await _productCreationLock.WaitAsync();
            try
            {
                // Ищем продукт в памяти
                product = allProducts
                    .FirstOrDefault(x => NormalizeForSearch(x.Name) == normalizedIngredientName);

                if (product == null)
                {
                    product = new Product
                        {
                            Name = ingredient.Name.Trim(),
                            UnitId = unit.Id,
                            Unit = unit,
                            CategoryId = category.Id,
                            Category = category,
                            IsPieceBased = normalizedUnit == "шт",
                            AverageWeightGrams = normalizedUnit == "шт" ? 100 : null,
                            Calories = (int)Math.Round(ingredient.Calories),
                            Proteins = (int)Math.Round(ingredient.Proteins),
                            Fats = (int)Math.Round(ingredient.Fats),
                            Carbohydrates = (int)Math.Round(ingredient.Carbs)
                        };

                    context.Products.Add(product);
                    await context.SaveChangesAsync();
                    allProducts.Add(product);
                    Logger.LogDebug("Создан новый продукт: {Name}", product.Name);
                }
            }
            finally
            {
                _productCreationLock.Release();
            }

            recipe.RecipeIngredients.Add(new RecipeIngredient
                {
                    ProductId = product.Id,
                    Product = product,
                    Quantity = (double)ingredient.Quantity
                });
        }

        context.Recipes.Add(recipe);

        if (useFridgeProducts && fridgeItems?.Any() == true)
        {
            await AdjustRecipeForFridgeAsync(recipe, fridgeItems);
        }

        var newRecipeNutrition = RecipeNutritionAdjuster.AdjustRecipeToTarget(recipe, targetCalories);

        await context.SaveChangesAsync();

        Logger.LogDebug("Создан рецепт: {Title} ({Calories} ккал)", recipe.Title, newRecipeNutrition.Calories);
        return new CreatedRecipeResult(recipe, newRecipeNutrition);
    }

