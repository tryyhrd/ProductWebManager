@page "/meal-plan"
@rendermode InteractiveServer

@using System.Globalization
@using Microsoft.EntityFrameworkCore
@using Microsoft.Extensions.Logging
@using ProductWebManager.Classes.AI
@using ProductWebManager.Classes.Helpers
@using ProductWebManager.Data
@using ProductWebManager.Models
@using ProductWebManager.Services

@inject NavigationManager Navigation
@inject IDbContextFactory<ProductManagerContext> DbContextFactory
@inject AuthService AuthService
@inject GigaChatHelper GigaChatHelper
@inject ILogger<MealPlan> Logger

<PageTitle>План питания</PageTitle>

<div class="mealplan-page">

    <div class="top-header">
        <div>
            <h1 class="main-title">План питания</h1>
            <div class="main-subtitle">
                Персональный рацион на @daysToGenerate дн.
            </div>
        </div>

        <div class="header-buttons">
            @if (mealPlanDays.Any())
            {
                <button class="shopping-list-btn"
                        @onclick="CreateShoppingListAsync">
                    <span>🛒</span>
                    <span>Создать список покупок</span>
                </button>
            }

            <button class="generate-btn"
                    disabled="@(isGenerating || isReplacing)"
                    @onclick="GenerateMealPlanAsync">
                @if (isGenerating)
                {
                    <span>Генерация...</span>
                }
                else if (isReplacing)
                {
                    <span>Замена...</span>
                }
                else
                {
                    <span>Сгенерировать план</span>
                }
            </button>
        </div>
    </div>

    <div class="settings-card">
        <div class="settings-grid">

            <div>
                <label class="setting-label">Цель</label>
                <select class="setting-input"
                        @bind="selectedGoal"
                        @bind:after="CalculateTargets">
                    <option value="@GoalType.Maintain">Поддержание</option>
                    <option value="@GoalType.LoseWeight">Похудение</option>
                    <option value="@GoalType.GainWeight">Набор массы</option>
                </select>
            </div>

            <div>
                <label class="setting-label">Количество дней</label>
                <select class="setting-input" @bind="daysToGenerate">
                    <option value="1">1 день</option>
                    <option value="3">3 дня</option>
                    <option value="5">5 дней</option>
                    <option value="7">7 дней</option>
                </select>
            </div>

            <div>
                <label class="setting-label">Использовать продукты из холодильника</label>
                <div class="toggle-box">
                    <input type="checkbox" @bind="useFridgeProducts" />
                    <span>@(useFridgeProducts ? "Да" : "Нет")</span>
                </div>
            </div>

        </div>
    </div>

    <div class="stats-grid">
        <div class="stat-card calories">
            <div class="stat-label">Калории</div>
            <div class="stat-value">@targetCalories</div>
            <div class="stat-unit">ккал</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Белки</div>
            <div class="stat-value">@targetProteins</div>
            <div class="stat-unit">г</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Жиры</div>
            <div class="stat-value">@targetFats</div>
            <div class="stat-unit">г</div>
        </div>

        <div class="stat-card">
            <div class="stat-label">Углеводы</div>
            <div class="stat-value">@targetCarbs</div>
            <div class="stat-unit">г</div>
        </div>
    </div>

    @if (mealPlanDays.Any())
    {
        <div class="days-wrapper">
            @foreach (var day in mealPlanDays)
            {
                var totalCalories = day.Meals.Sum(x => x.Calories);
                var deviation = targetCalories > 0
                ? Math.Round((double)(totalCalories - targetCalories) / targetCalories * 100, 1)
                : 0;
                var deviationClass = Math.Abs(deviation) <= 5 ? "good" : "warning";

                <div class="day-card">
                    <div class="day-header" @onclick="() => ToggleDay(day)">
                        <div class="day-left">
                            <span class="collapse-icon">
                                @(day.IsExpanded ? "▼" : "▶")
                            </span>

                            <div>
                                <div class="day-title">
                                    @day.Date.ToString("dddd", RuCulture)
                                </div>

                                <div class="day-date">
                                    @day.Date.ToString("dd MMMM yyyy", RuCulture)
                                </div>
                            </div>
                        </div>

                        <div class="day-kcal-container">
                            <div class="day-kcal">
                                @((int)totalCalories) ккал
                            </div>
                            @if (deviation != 0)
                            {
                                <div class="day-deviation @deviationClass">
                                    @(deviation > 0 ? "+" : "")@deviation%
                                </div>
                            }
                        </div>
                    </div>

                    @if (day.IsExpanded)
                    {
                        <div class="meals-list">
                            @foreach (var meal in day.Meals)
                            {
                                <div class="meal-card @(meal.Recipe != null && !meal.IsSnack ? "clickable" : "")">
                                    <div class="meal-left" @onclick="() => OpenMeal(meal)">
                                        <div class="meal-icon">
                                            @GetMealIcon(meal.MealType)
                                        </div>

                                        <div>
                                            <div class="meal-type">
                                                @GetMealTypeText(meal.MealType)
                                            </div>

                                            <div class="meal-title">
                                                @meal.Title
                                            </div>

                                            <div class="meal-description">
                                                @meal.Description
                                            </div>

                                            <div class="meal-macros">
                                                <span>Б: @meal.Proteins г</span>
                                                <span>Ж: @meal.Fats г</span>
                                                <span>У: @meal.Carbs г</span>
                                            </div>
                                        </div>
                                    </div>

                                    <div class="meal-right">
                                        <div class="meal-kcal">
                                            @meal.Calories ккал
                                        </div>

                                        <div class="meal-actions">
                                            @if (meal.Recipe != null && !meal.IsSnack)
                                            {
                                                <button class="btn-replace"
                                                        @onclick="() => ReplaceMeal(day, meal)"
                                                        @onclick:stopPropagation="true"
                                                        title="Заменить блюдо">
                                                    Замена
                                                </button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }

    @if (showModal)
    {
        <div class="modal-overlay" @onclick="CloseModalHandler">
            <div class="modal-content" @onclick:stopPropagation="true">

                <div class="modal-header @GetModalHeaderClass()">
                    <h3>@modalTitle</h3>
                    <button class="modal-close" @onclick="CloseModalHandler" title="Закрыть">&times;</button>
                </div>

                <div class="modal-body">
                    @modalMessage
                </div>

                <div class="modal-footer">
                    <button class="modal-btn" @onclick="CloseModalHandler">Закрыть</button>
                </div>

            </div>
        </div>
    }

</div>

