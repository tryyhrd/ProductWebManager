        border: 2px dashed #e0e0e4;
        border-radius: 16px;
    }

    .empty-icon {
        font-size: 72px;
        opacity: 0.25;
    }

    .empty-title {
        color: #555;
        margin-top: 16px;
    }

    .empty-text {
