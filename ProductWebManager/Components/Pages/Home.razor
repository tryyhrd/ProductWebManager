    }

    .modal-title {
        color: #1a1a2e;
        margin-bottom: 20px;
        font-weight: 600;
    }

    .form-label {
        display: block;
        color: #666;
        font-size: 12px;
        margin-bottom: 6px;
        font-weight: 500;
    }

    .modal-input {
        background: #f8f8fa;
        border: 1px solid #e0e0e4;
        border-radius: 10px;
        padding: 10px 14px;
        color: #333;
        font-size: 14px;
        width: 100%;
        transition: all 0.2s;
    }

        .modal-input:focus {
            border-color: #6c5ce7;
            box-shadow: 0 0 0 3px rgba(108, 92, 231, 0.1);
            outline: none;
            background: white;
        }

    .btn-modal-save {
        flex: 1;
        padding: 12px;
        border: none;
        border-radius: 10px;
        background: #6c5ce7;
        color: white;
        font-weight: 500;
        cursor: pointer;
        font-size: 14px;
    }

        .btn-modal-save:hover {
