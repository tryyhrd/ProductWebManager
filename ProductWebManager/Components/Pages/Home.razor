        color: #1a1a2e;
    }

    .quantity-unit {
        font-size: 14px;
        color: #999;
        margin-left: 4px;
    }

    .expiry-section {
        background: #fafafa;
        border-radius: 10px;
        padding: 12px;
        margin-bottom: 4px;
    }

    .expiry-date {
        font-size: 11px;
        color: #888;
    }

    .expiry-status {
        font-size: 11px;
        font-weight: 600;
    }

    .progress-bar-bg {
        height: 6px;
        background: #e8e8e8;
        border-radius: 10px;
        overflow: hidden;
    }

    .progress-bar-fill {
        height: 100%;
        border-radius: 10px;
        transition: width 0.6s ease;
    }

    /* ========== КНОПКИ ========== */
    .btn-add {
        padding: 9px 20px;
        border: none;
        border-radius: 10px;
        background: #6c5ce7;
        color: white;
        font-weight: 500;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.2s;
