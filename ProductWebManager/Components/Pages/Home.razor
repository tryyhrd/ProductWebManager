@page "/fridge"
@inject NavigationManager Navigation

<PageTitle>Холодильник</PageTitle>

<div class="page-bg">
    <div class="container-fluid p-4">
        <div class="d-flex justify-content-between align-items-center mb-4">
            <div>
                <h2 class="fw-bold m-0 page-title">📦 Холодильник</h2>
                <small class="page-subtitle">Управление продуктами</small>
            </div>
            <div class="d-flex gap-2">
                <button class="btn btn-add" @onclick="OpenAddModal">
                    ➕ Добавить продукт
                </button>
                <button class="btn btn-menu" @onclick="GoToMenu">
                    🍽️ Меню
                </button>
            </div>
        </div>

        <!-- Статистика -->
        <div class="row mb-4">
            <div class="col-md-4 mb-3">
                <div class="stat-card">
                    <div class="stat-label">ВСЕГО ПРОДУКТОВ</div>
                    <div class="stat-value" style="color: #6c5ce7;">@products.Count</div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="stat-card stat-card-danger">
                    <div class="stat-label">ИСТЕКАЮТ СЕГОДНЯ</div>
                    <div class="stat-value" style="color: #e74c3c;">@expiringToday</div>
                </div>
            </div>
            <div class="col-md-4 mb-3">
                <div class="stat-card stat-card-warning">
                    <div class="stat-label">ИСТЕКАЮТ ЗА НЕДЕЛЮ</div>
                    <div class="stat-value" style="color: #f39c12;">@expiringThisWeek</div>
                </div>
            </div>
        </div>

        <!-- Поиск и фильтры -->
        <div class="filter-bar">
            <div class="row g-3">
                <div class="col-md-5">
                    <input type="text"
                           class="form-control filter-input"
                           placeholder="🔍 Поиск продуктов..."
                           @bind="searchQuery"
                           @bind:event="oninput"
                           @onkeyup="FilterProducts" />
                </div>
                <div class="col-md-3">
                    <select class="form-control filter-input"
                            value="@sortBy"
                            @onchange="OnSortChangedHandler">
                        <option value="name">📋 По названию</option>
                        <option value="date">🕐 По дате</option>
                        <option value="expiry">⏰ По сроку</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <select class="form-control filter-input"
                            value="@filterCategory"
                            @onchange="OnFilterChangedHandler">
                        <option value="">🗂️ Все категории</option>
                        <option value="dairy">🥛 Молочные</option>
                        <option value="meat">🥩 Мясо</option>
                        <option value="vegetables">🥬 Овощи</option>
                        <option value="fruits">🍎 Фрукты</option>
                        <option value="other">📦 Другое</option>
                    </select>
                </div>
            </div>
        </div>

        <!-- Список продуктов -->
        @if (filteredProducts.Any())
        {
            <div class="row">
                @foreach (var product in filteredProducts)
                {
                    var daysLeft = (product.ExpiryDate - DateTime.Now).TotalDays;
                    var statusColor = daysLeft <= 0 ? "#e74c3c" : daysLeft <= 3 ? "#f39c12" : "#27ae60";
                    var progressWidth = Math.Max(0, Math.Min(100, (daysLeft / 14) * 100));
                    var expiryText = daysLeft <= 0 ? "Просрочен" :
                    daysLeft <= 1 ? "Сегодня" :
                    daysLeft <= 3 ? $"{Math.Ceiling(daysLeft)} дн." :
                    $"{Math.Ceiling(daysLeft)} дн.";
                    var borderColor = daysLeft <= 0 ? "#e74c3c" :
                    daysLeft <= 3 ? "#f39c12" : "transparent";

                    <div class="col-md-6 col-lg-4 col-xl-3 mb-3">
                        <div class="product-card" style="border-color: @borderColor;">
                            <!-- Заголовок -->
                            <div class="d-flex justify-content-between align-items-start mb-3">
                                <div class="flex-grow-1" style="min-width: 0;">
                                    <h6 class="product-name">@product.Name</h6>
                                    <span class="category-tag">@GetCategoryDisplay(product.Category)</span>
                                </div>
                                <div class="d-flex gap-1 ms-2">
                                    <button class="btn-icon" @onclick="() => OpenEditModal(product)" title="Редактировать">
                                        ✏️
                                    </button>
                                    <button class="btn-icon" @onclick="() => ConfirmDeleteProduct(product)" title="Удалить">
                                        🗑️
                                    </button>
                                </div>
                            </div>

                            <!-- Количество -->
                            <div class="mb-3">
                                <span class="quantity-value">@product.Quantity</span>
                                <span class="quantity-unit">@product.Unit</span>
                            </div>

                            <!-- Срок годности -->
                            <div class="expiry-section">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <span class="expiry-date">📅 @product.ExpiryDate.ToString("dd.MM.yyyy")</span>
                                    <span class="expiry-status" style="color: @statusColor;">
                                        @expiryText
                                    </span>
                                </div>
                                <div class="progress-bar-bg">
                                    <div class="progress-bar-fill" style="width: @progressWidth%; background: @statusColor;"></div>
                                </div>
                            </div>

                            <!-- Кнопки -->
                            <div class="d-flex gap-2 mt-3">
                                <button class="btn-qty" @onclick="() => UpdateQuantity(product, -1)"
                                        disabled="@(product.Quantity <= 1)">
                                    ➖
                                </button>
                                <button class="btn-qty" @onclick="() => UpdateQuantity(product, 1)">
                                    ➕
                                </button>
                                <button class="btn-cook" @onclick="() => QuickAddRecipe(product)">
                                    🍳
                                </button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="empty-state">
                <div class="empty-icon">🛒</div>
                <h4 class="empty-title">Холодильник пуст</h4>
                <p class="empty-text">Добавьте продукты, чтобы начать</p>
                <button class="btn btn-add" @onclick="OpenAddModal">
                    ➕ Добавить первый продукт
                </button>
            </div>
        }
    </div>
</div>

<!-- Модальное окно -->
@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-dialog" @onclick:stopPropagation="true">
            <h4 class="modal-title">@(isEditing ? "✏️ Редактировать" : "➕ Добавить") продукт</h4>

            <div class="mb-3">
                <label class="form-label">Название</label>
                <input type="text" class="form-control modal-input" @bind="currentProduct.Name"
                       placeholder="Например: Молоко" />
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label">Количество</label>
                    <input type="number" class="form-control modal-input" @bind="currentProduct.Quantity" min="1" />
                </div>
                <div class="col-md-6">
                    <label class="form-label">Единица</label>
                    <select class="form-control modal-input" @bind="currentProduct.Unit">
                        <option value="шт.">шт.</option>
                        <option value="кг">кг</option>
                        <option value="г">г</option>
                        <option value="л">л</option>
                        <option value="мл">мл</option>
                    </select>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Категория</label>
                <select class="form-control modal-input" @bind="currentProduct.Category">
                    <option value="dairy">🥛 Молочные</option>
                    <option value="meat">🥩 Мясо</option>
                    <option value="vegetables">🥬 Овощи</option>
                    <option value="fruits">🍎 Фрукты</option>
                    <option value="other">📦 Другое</option>
                </select>
            </div>

            <div class="mb-4">
                <label class="form-label">Срок годности</label>
                <input type="date" class="form-control modal-input" @bind="currentProduct.ExpiryDate" />
            </div>

            <div class="d-flex gap-2">
                <button class="btn-modal-save" @onclick="SaveProduct">💾 Сохранить</button>
                <button class="btn-modal-cancel" @onclick="CloseModal">Отмена</button>
            </div>
        </div>
    </div>
}

<!-- Модальное окно удаления -->
@if (showDeleteConfirm)
{
    <div class="modal-overlay" @onclick="CancelDelete">
        <div class="modal-dialog" @onclick:stopPropagation="true" style="max-width: 380px;">
            <h4 class="modal-title">🗑️ Подтверждение</h4>
            <p class="delete-text">
                Удалить <strong class="delete-name">@productToDelete?.Name</strong> из холодильника?
            </p>
            <div class="d-flex gap-2">
                <button class="btn-modal-delete" @onclick="DeleteProduct">Удалить</button>
                <button class="btn-modal-cancel" @onclick="CancelDelete">Отмена</button>
            </div>
        </div>
    </div>
}

<style>
    /* ========== ФОН СТРАНИЦЫ ========== */
