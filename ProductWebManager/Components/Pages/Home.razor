        }

    .delete-text {
        color: #666;
        margin-bottom: 20px;
    }

    .delete-name {
        color: #e74c3c;
    }
</style>

@code {
    private List<Product> products = new();
    private List<Product> filteredProducts = new();
    private string searchQuery = "";
    private string sortBy = "name";
    private string filterCategory = "";

    private bool showModal = false;
    private bool isEditing = false;
    private bool showDeleteConfirm = false;
    private Product currentProduct = new();
    private Product? productToDelete;

    private int expiringToday = 0;
    private int expiringThisWeek = 0;

    public class Product
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public double Quantity { get; set; } = 1;
        public string Unit { get; set; } = "шт.";
        public DateTime AddedDate { get; set; } = DateTime.Now;
        public DateTime ExpiryDate { get; set; } = DateTime.Now.AddDays(7);
        public string Category { get; set; } = "other";

        public string ExpiryDateString
        {
            get => ExpiryDate.ToString("yyyy-MM-dd");
            set => ExpiryDate = DateTime.Parse(value);
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        await Task.Delay(100);
        products = new List<Product>
        {
            new() { Id = 1, Name = "Молоко", Quantity = 1, Unit = "л", Category = "dairy", ExpiryDate = DateTime.Now.AddDays(2) },
            new() { Id = 2, Name = "Яйца", Quantity = 10, Unit = "шт.", Category = "other", ExpiryDate = DateTime.Now.AddDays(14) },
            new() { Id = 3, Name = "Курица", Quantity = 500, Unit = "г", Category = "meat", ExpiryDate = DateTime.Now },
            new() { Id = 4, Name = "Помидоры", Quantity = 3, Unit = "шт.", Category = "vegetables", ExpiryDate = DateTime.Now.AddDays(5) },
            new() { Id = 5, Name = "Яблоки", Quantity = 5, Unit = "шт.", Category = "fruits", ExpiryDate = DateTime.Now.AddDays(10) },
            new() { Id = 6, Name = "Сыр", Quantity = 200, Unit = "г", Category = "dairy", ExpiryDate = DateTime.Now.AddDays(-1) }
        };
        UpdateStats();
        FilterProducts();
    }

    private void UpdateStats()
    {
        expiringToday = products.Count(p => p.ExpiryDate.Date == DateTime.Now.Date);
        expiringThisWeek = products.Count(p => p.ExpiryDate.Date > DateTime.Now.Date && p.ExpiryDate.Date <= DateTime.Now.AddDays(7).Date);
    }

    private void FilterProducts()
    {
        var query = products.AsEnumerable();
        if (!string.IsNullOrWhiteSpace(searchQuery))
            query = query.Where(p => p.Name.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
        if (!string.IsNullOrEmpty(filterCategory))
            query = query.Where(p => p.Category == filterCategory);
        filteredProducts = SortProductsInternal(query.ToList());
    }

    private void OnSortChangedHandler(ChangeEventArgs e) { sortBy = e.Value?.ToString() ?? "name"; FilterProducts(); }
    private void OnFilterChangedHandler(ChangeEventArgs e) { filterCategory = e.Value?.ToString() ?? ""; FilterProducts(); }

    private List<Product> SortProductsInternal(List<Product> list) => sortBy switch
    {
        "date" => list.OrderByDescending(p => p.AddedDate).ToList(),
        "expiry" => list.OrderBy(p => p.ExpiryDate).ToList(),
        _ => list.OrderBy(p => p.Name).ToList()
    };

    private void OpenAddModal() { currentProduct = new Product(); isEditing = false; showModal = true; }
    private void OpenEditModal(Product product) { currentProduct = new() { Id = product.Id, Name = product.Name, Quantity = product.Quantity, Unit = product.Unit, Category = product.Category, ExpiryDate = product.ExpiryDate, AddedDate = product.AddedDate }; isEditing = true; showModal = true; }
    private void CloseModal() { showModal = false; currentProduct = new Product(); }

    private async Task SaveProduct()
    {
        if (string.IsNullOrWhiteSpace(currentProduct.Name)) return;
        if (isEditing) { var existing = products.FirstOrDefault(p => p.Id == currentProduct.Id); if (existing != null) { existing.Name = currentProduct.Name; existing.Quantity = currentProduct.Quantity; existing.Unit = currentProduct.Unit; existing.Category = currentProduct.Category; existing.ExpiryDate = currentProduct.ExpiryDate; } }
        else { currentProduct.Id = products.Any() ? products.Max(p => p.Id) + 1 : 1; currentProduct.AddedDate = DateTime.Now; products.Add(currentProduct); }
        UpdateStats(); FilterProducts(); CloseModal();
        await Task.CompletedTask;
    }

    private void ConfirmDeleteProduct(Product product) { productToDelete = product; showDeleteConfirm = true; }
    private void CancelDelete() { showDeleteConfirm = false; productToDelete = null; }
    private async Task DeleteProduct() { if (productToDelete != null) { products.Remove(productToDelete); UpdateStats(); FilterProducts(); } CancelDelete(); await Task.CompletedTask; }
    private async Task UpdateQuantity(Product product, int delta) { product.Quantity = Math.Max(0, product.Quantity + delta); if (product.Quantity == 0) ConfirmDeleteProduct(product); FilterProducts(); await Task.CompletedTask; }
    private void QuickAddRecipe(Product product) => Navigation.NavigateTo($"/menu?product={product.Id}");
    private void GoToMenu() => Navigation.NavigateTo("/menu");

    private string GetCategoryDisplay(string category) => category switch
    {
        "dairy" => "🥛 Молочные",
        "meat" => "🥩 Мясо",
        "vegetables" => "🥬 Овощи",
        "fruits" => "🍎 Фрукты",
        _ => "📦 Другое"
    };
}