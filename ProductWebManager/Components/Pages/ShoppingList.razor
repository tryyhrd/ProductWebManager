        cursor: pointer;
        font-size: 14px;
    }

        .btn-modal-save:hover {
            background: #5a4bd1;
        }

    .btn-modal-cancel {
        flex: 1;
        padding: 11px;
        border: 1px solid #e0e0e4;
        border-radius: 10px;
        background: white;
        color: #666;
        font-weight: 500;
        cursor: pointer;
        font-size: 14px;
    }

        .btn-modal-cancel:hover {
            background: #f8f8fa;
        }
</style>

@code {
    private List<ShoppingListItem> shoppingItems = new();
    private List<Product> availableProducts = new();
    private bool showModal = false;
    private int selectedProductId;
    private double editQuantity = 1;
    private decimal estimatedTotal;

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            // Загружаем список покупок
            var list = await DbContext.ShoppingList
                .Include(sl => sl.Items)
                    .ThenInclude(si => si.Product)
                        .ThenInclude(p => p.Unit)
                .FirstOrDefaultAsync(sl => sl.UserId == 1 && !sl.IsCompleted);

            if (list != null)
            {
                shoppingItems = list.Items.ToList();
            }
            else
            {
                shoppingItems = new List<ShoppingListItem>();
            }

            // Загружаем доступные продукты
            availableProducts = await DbContext.Products
                .Include(p => p.Unit)
                .ToListAsync();

            UpdateTotal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки: {ex.Message}");
        }
    }

    private void UpdateTotal()
    {
        estimatedTotal = shoppingItems
            .Where(x => !x.IsPurchased)
            .Sum(x => (x.Product?.Price ?? 0) * (decimal)x.Quantity);
    }

    private async Task TogglePurchased(ShoppingListItem item)
    {
        item.IsPurchased = !item.IsPurchased;
        try
        {
            await DbContext.SaveChangesAsync();
            UpdateTotal();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
    }

    private void OpenAddModal()
    {
        selectedProductId = 0;
        editQuantity = 1;
        showModal = true;
    }

    private void CloseModal() => showModal = false;

    private async Task SaveItem()
    {
        if (selectedProductId == 0) return;

        try
        {
            // Находим или создаём активный список покупок
            var list = await DbContext.ShoppingList
                .Include(sl => sl.Items)
                .FirstOrDefaultAsync(sl => sl.UserId == 1 && !sl.IsCompleted);

            if (list == null)
            {
                list = new Models.ShoppingList
                    {
                        UserId = 1,
                        Name = "Основной",
                        IsCompleted = false,
                        CreatedAt = DateTime.UtcNow,
                        Items = new List<ShoppingListItem>()
                    };
                DbContext.ShoppingList.Add(list);
            }

            // Проверяем, есть ли уже такой продукт в списке
            var existingItem = list.Items.FirstOrDefault(i => i.ProductId == selectedProductId);
            if (existingItem != null)
            {
                existingItem.Quantity += (decimal)editQuantity;
            }
            else
            {
                list.Items.Add(new ShoppingListItem
                    {
                        ProductId = selectedProductId,
                        Quantity = (decimal)editQuantity,
                        IsPurchased = false
                    });
            }

            await DbContext.SaveChangesAsync();
            await LoadData();
            CloseModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка сохранения: {ex.Message}");
        }
    }

    private async Task RemoveItem(ShoppingListItem item)
    {
        try
        {
            DbContext.ShoppingListItems.Remove(item);
            await DbContext.SaveChangesAsync();
            await LoadData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка удаления: {ex.Message}");
        }
    }

    private async Task ClearPurchased()
    {
        try
        {
            var purchased = shoppingItems.Where(x => x.IsPurchased).ToList();
            DbContext.ShoppingListItems.RemoveRange(purchased);
            await DbContext.SaveChangesAsync();
            await LoadData();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
    }

    private async Task ClearAll()
    {
        try
        {
            var list = await DbContext.ShoppingList
                .Include(sl => sl.Items)
                .FirstOrDefaultAsync(sl => sl.UserId == 1 && !sl.IsCompleted);

            if (list != null)
            {
                DbContext.ShoppingListItems.RemoveRange(list.Items);
                await DbContext.SaveChangesAsync();
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
    }
}