@page "/shopping-list"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Models

@inject NavigationManager Navigation
@inject IDbContextFactory<ProductWebManager.Data.ProductManagerContext> DbContextFactory
@inject ProductWebManager.Services.AuthService AuthService

<PageTitle>SmartPlate AI — Список покупок</PageTitle>

<div class="max-w-[1440px] mx-auto px-4 py-4 sm:p-6 lg:p-10 font-sans">

    <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6 sm:mb-10">
        <div>
            <h1 class="text-2xl sm:text-4xl font-black text-slate-900 tracking-tighter">Списки покупок</h1>
            <p class="text-slate-500 font-medium mt-1 text-sm sm:text-base">
                Осталось купить:
                <span class="text-indigo-600 font-bold">@shoppingItems.Count(x => !x.IsPurchased)</span>
                из <span class="text-slate-800 font-bold">@shoppingItems.Count</span>
                @if (isMealPlanList)
                {
                    <span class="ml-2 inline-flex items-center gap-1 px-2.5 py-0.5 rounded-full text-xs font-bold bg-indigo-50 text-indigo-600 border border-indigo-100">
                        <i class="fas fa-robot text-[10px]"></i> Из плана питания
                    </span>
                }
            </p>
        </div>

        <div class="flex flex-wrap gap-3 w-full md:w-auto">
            <button class="flex items-center gap-2 bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 px-6 py-4 rounded-2xl font-bold transition-all shadow-sm"
                    @onclick="OpenListModal">
                <i class="fas fa-layer-group text-slate-400"></i>
                <span>Управление списками</span>
            </button>

            <button class="flex items-center gap-2 bg-slate-900 hover:bg-indigo-600 text-white px-8 py-4 rounded-2xl font-bold transition-all transform hover:-translate-y-1 shadow-xl disabled:opacity-50"
                    disabled="@(currentListId == 0)"
                    @onclick="OpenAddModal">
                <i class="fas fa-plus"></i>
                <span>Добавить продукт</span>
            </button>
        </div>
    </header>

    @if (shoppingLists.Any())
    {
        <div class="flex items-center gap-2 overflow-x-auto pb-4 mb-6 scrollbar-none">
            @foreach (var list in shoppingLists)
            {
                var isSelected = list.Id == currentListId;
                <button @onclick="() => SelectList(list.Id)"
                        class="px-5 py-3 rounded-xl font-bold text-sm whitespace-nowrap transition-all border @(isSelected ? "bg-slate-900 text-white border-slate-900 shadow-md" : "bg-white text-slate-600 border-slate-200 hover:bg-slate-50")">
                    @list.Name
                </button>
            }
        </div>
    }

    <div class="bg-white border border-slate-100 rounded-2xl sm:rounded-[2.5rem] shadow-sm p-4 sm:p-8">
        @if (currentListId == 0)
        {
            <div class="flex flex-col items-center justify-center py-20 text-center">
                <div class="w-16 h-16 bg-slate-50 text-slate-400 rounded-2xl flex items-center justify-center text-2xl mb-4 shadow-inner">
                    <i class="fas fa-folder-plus"></i>
                </div>
                <h3 class="text-xl font-black text-slate-800">Нет активного списка</h3>
                <p class="text-slate-400 font-medium max-w-xs mt-1">Создайте новый список в меню управления списками или сгенерируйте план питания.</p>
            </div>
        }
        else
        {
            <div class="flex flex-wrap gap-2 sm:gap-3 mb-4 sm:mb-6 pb-4 sm:pb-6 border-b border-slate-100">
                <button @onclick="ClearPurchased" disabled="@(!shoppingItems.Any())"
                        class="inline-flex items-center gap-2 text-emerald-700 hover:text-emerald-800 text-sm font-bold bg-emerald-50 hover:bg-emerald-100 border border-emerald-100 px-5 py-3 rounded-xl transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                    <i class="fas fa-check-double text-xs"></i>
                    <span>Удалить купленные</span>
                </button>
                <button @onclick="ClearAll" disabled="@(!shoppingItems.Any())"
                        class="inline-flex items-center gap-2 text-amber-600 hover:text-amber-700 text-sm font-bold bg-amber-50 hover:bg-amber-100 border border-amber-100 px-5 py-3 rounded-xl transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                    <i class="fas fa-eraser text-xs"></i>
                    <span>Очистить весь список</span>
                </button>
                <div class="flex-1"></div>
                <button @onclick="() => DeleteList(currentListId)"
                        class="inline-flex items-center gap-2 text-red-600 hover:text-red-700 text-sm font-bold bg-red-50 hover:bg-red-100 border border-red-100 px-5 py-3 rounded-xl transition-colors ml-auto">
                    <i class="fas fa-trash-alt text-xs"></i>
                    <span>Удалить этот список</span>
                </button>
            </div>

            @if (!shoppingItems.Any())
            {
                <div class="flex flex-col items-center justify-center py-10 text-center">
                    <div class="w-16 h-16 bg-indigo-50 text-indigo-500 rounded-2xl flex items-center justify-center text-2xl mb-4 shadow-inner">
                        <i class="fas fa-shopping-basket"></i>
                    </div>
                    <h3 class="text-xl font-black text-slate-800">Список пока пуст</h3>
                    <p class="text-slate-400 font-medium max-w-xs mt-1">Нажмите кнопку «Добавить продукт», чтобы наполнить ваш корзину покупками.</p>
                </div>
            }
            else
            {
            <div class="space-y-3">
                @foreach (var item in shoppingItems.OrderBy(x => x.IsPurchased))
                {
                    <div @key="item.Id" class="flex flex-wrap sm:flex-nowrap items-center justify-between p-4 gap-3 sm:gap-4 bg-slate-50/50 hover:bg-white hover:shadow-xl hover:shadow-slate-500/5 border border-transparent hover:border-slate-100 rounded-2xl transition-all duration-300 group select-none">
                        <label class="flex items-center gap-3 sm:gap-4 flex-1 cursor-pointer w-full sm:w-auto">
                            <input type="checkbox" checked="@item.IsPurchased" @onchange="@(e => TogglePurchased(item, e))"
                                   class="w-6 h-6 rounded-lg border-slate-300 text-indigo-600 focus:ring-indigo-500 transition-all cursor-pointer" />
                            <span class="font-bold text-slate-800 transition-all @(item.IsPurchased ? "line-through text-slate-400 font-medium" : "")">
                                @item.Product.Name
                            </span>
                        </label>

                        <div class="flex items-center justify-between sm:justify-end gap-4 w-full sm:w-auto pl-9 sm:pl-0">
                            <span class="text-xs font-black px-4 py-2 bg-white rounded-xl text-slate-600 border border-slate-100 transition-all @(item.IsPurchased ? "bg-slate-50/50 text-slate-400 shadow-none border-transparent" : "shadow-sm")">
                                @item.Quantity.ToString("G") @item.Product.Unit?.Name
                            </span>
                            <button @onclick="() => RemoveItem(item)"
                                    class="text-slate-300 hover:text-red-500 transition-colors p-2"
                                    title="Удалить позицию">
                                <i class="fas fa-trash-alt text-sm"></i>
                            </button>
                        </div>
                    </div>
                }
            </div>
            }
        }
    </div>
</div>

@if (showModal && modalType == "add")
{
    <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 flex items-center justify-center p-4 animate-fade-in">
        <div class="bg-white rounded-[2rem] max-w-md w-full shadow-2xl overflow-hidden border border-slate-100 flex flex-col transform transition-all">
            <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center shadow-inner">
                        <i class="fas fa-cart-plus"></i>
                    </div>
                    <h2 class="text-xl font-black text-slate-800 tracking-tight">Добавить в список</h2>
                </div>
                <button @onclick="CloseModal" class="w-8 h-8 rounded-full bg-slate-100 hover:bg-slate-200 text-slate-500 flex items-center justify-center transition-colors">
                    <i class="fas fa-times text-xs"></i>
                </button>
            </div>

            <div class="p-6 space-y-4 flex-1">
                <div class="space-y-1.5">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Продукт</label>
                    <select @bind="newItemProductId" class="w-full bg-slate-50 border-2 border-transparent focus:border-indigo-500 focus:bg-white rounded-xl p-3 font-bold text-sm outline-none transition-all">
                        <option value="0">-- Выберите из базы --</option>
                        @foreach (var p in availableProducts)
                        {
                            <option value="@p.Id">@p.Name (@p.Unit?.Name)</option>
                        }
                    </select>
                </div>

                <div class="space-y-1.5">
                    <label class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Количество</label>
                    <input type="number" step="any" min="0.1" @bind-value="newItemQuantity" class="w-full bg-slate-50 border-2 border-transparent focus:border-indigo-500 focus:bg-white rounded-xl p-3 font-bold outline-none transition-all" />
                </div>
            </div>

            <div class="p-6 border-t border-slate-100 bg-slate-50/50 flex justify-end gap-3">
                <button @onclick="CloseModal" class="bg-slate-200 hover:bg-slate-300 text-slate-700 font-bold px-5 py-3 rounded-xl text-sm transition-colors shadow-sm">
                    Отмена
                </button>
                <button @onclick="AddItem" class="bg-slate-900 hover:bg-indigo-600 text-white font-bold px-6 py-3 rounded-xl text-sm transition-all shadow-md">
                    Добавить
                </button>
            </div>
        </div>
    </div>
}

@if (showModal && modalType == "lists")
{
    <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm z-50 flex items-center justify-center p-4 animate-fade-in">
        <div class="bg-white rounded-[2rem] max-w-lg w-full max-h-[85vh] shadow-2xl overflow-hidden border border-slate-100 flex flex-col transform transition-all">
            <div class="p-6 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-indigo-50 text-indigo-600 rounded-xl flex items-center justify-center shadow-inner">
                        <i class="fas fa-layer-group"></i>
                    </div>
                    <h2 class="text-xl font-black text-slate-800 tracking-tight">Управление списками</h2>
                </div>
                <button @onclick="CloseModal" class="w-8 h-8 rounded-full bg-slate-100 hover:bg-slate-200 text-slate-500 flex items-center justify-center transition-colors">
                    <i class="fas fa-times text-xs"></i>
                </button>
            </div>

            <div class="p-6 overflow-y-auto flex-1 space-y-6">
                <div class="bg-slate-50/60 border border-slate-100 p-4 rounded-2xl space-y-3">
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest block">Новый список</span>
                    <div class="flex gap-2">
                        <input type="text" @bind-value="newListName" placeholder="Название (например, Закупка на Пятницу)"
                               class="flex-1 bg-white border border-slate-200 focus:border-indigo-500 rounded-xl px-4 py-2.5 font-bold text-sm outline-none transition-all" />
                        <button @onclick="CreateList" class="bg-slate-900 hover:bg-indigo-600 text-white font-bold px-4 py-2.5 rounded-xl text-sm transition-colors whitespace-nowrap shadow-sm">
                            Создать
                        </button>
                    </div>
                </div>

                <div class="space-y-2">
                    <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest block px-1">Доступные списки</span>
                    @if (!shoppingLists.Any())
                    {
                        <p class="text-xs font-medium text-slate-400 italic p-2">Списки отсутствуют</p>
                    }
                    else
                    {
                        @foreach (var list in shoppingLists)
                        {
                            <div class="flex items-center justify-between p-3 bg-white border border-slate-100 hover:border-slate-200 rounded-xl transition-all group">
                                <span class="font-bold text-sm text-slate-700 @(list.Id == currentListId ? "text-indigo-600 font-black" : "")">
                                    @list.Name @(list.Id == currentListId ? " (Активный)" : "")
                                </span>
                                <div class="flex items-center gap-2">
                                    @if (list.Id != currentListId)
                                    {
                                        <button @onclick="() => SelectList(list.Id)" class="text-xs font-bold text-slate-500 hover:text-slate-900 px-2.5 py-1.5 bg-slate-50 rounded-lg border border-slate-100 transition-colors">
                                            Выбрать
                                        </button>
                                    }
                                    <button @onclick="() => DeleteList(list.Id)" class="text-slate-300 hover:text-red-500 p-1.5 transition-colors">
                                        <i class="fas fa-trash-alt text-xs"></i>
                                    </button>
                                </div>
                            </div>
                        }
                    }
                </div>
            </div>

            <div class="p-6 border-t border-slate-100 bg-slate-50/50 flex justify-end">
                <button @onclick="CloseModal" class="w-full sm:w-auto bg-slate-900 hover:bg-slate-800 text-white font-bold px-6 py-3 rounded-xl text-sm transition-colors shadow-sm">
                    Готово
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<Models.ShoppingList> shoppingLists = new();
    private List<ShoppingListItem> shoppingItems = new();
    private List<Product> availableProducts = new();

    private int currentListId = 0;
    private bool isMealPlanList = false;

    // Modal state
    private bool showModal = false;
    private string modalType = ""; // "add" or "lists"

    // Form fields
    private string newListName = "";
    private int newItemProductId = 0;
    private double newItemQuantity = 1.0;

    protected override async Task OnInitializedAsync()
    {
        await LoadLists();
        await LoadProducts();

        if (shoppingLists.Any())
        {
            await SelectList(shoppingLists.First().Id);
        }
    }

    private async Task LoadLists()
    {
        await using var context = await DbContextFactory.CreateDbContextAsync();
        shoppingLists = await context.ShoppingList
            .Where(l => l.UserId == AuthService.CurrentUserId)
            .OrderByDescending(l => l.CreatedAt)
            .ToListAsync();
    }

    private async Task LoadProducts()
    {
        await using var context = await DbContextFactory.CreateDbContextAsync();
        availableProducts = await context.Products
            .Include(p => p.Unit)
            .OrderBy(p => p.Name)
            .ToListAsync();
    }

    private async Task SelectList(int listId)
    {
        currentListId = listId;
        await LoadCurrentList();
    }

    private async Task LoadCurrentList()
    {
        if (currentListId == 0)
        {
            shoppingItems = new List<ShoppingListItem>();
            isMealPlanList = false;
            return;
        }

        await using var context = await DbContextFactory.CreateDbContextAsync();

        var currentList = await context.ShoppingList
            .FirstOrDefaultAsync(l => l.Id == currentListId);

        if (currentList != null)
        {
            isMealPlanList = currentList.Name.Contains("План питания");
        }

        shoppingItems = await context.ShoppingListItems
            .Include(i => i.Product)
                .ThenInclude(p => p.Unit)
            .Where(i => i.ShoppingListId == currentListId)
            .ToListAsync();
    }

    private async Task TogglePurchased(ShoppingListItem item, ChangeEventArgs e)
    {
        bool isChecked = (bool)(e.Value ?? false);
        item.IsPurchased = isChecked;

        await using var context = await DbContextFactory.CreateDbContextAsync();
        var dbItem = await context.ShoppingListItems.FindAsync(item.Id);
        if (dbItem != null)
        {
            dbItem.IsPurchased = isChecked;
            await context.SaveChangesAsync();
        }

        await LoadCurrentList();
    }

    private void OpenAddModal()
    {
        modalType = "add";
        newItemProductId = 0;
        newItemQuantity = 1.0;
        showModal = true;
    }

    private void OpenListModal()
    {
        modalType = "lists";
        newListName = "";
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
        modalType = "";
    }

    private async Task CreateList()
    {
        if (string.IsNullOrWhiteSpace(newListName)) return;

        await using var context = await DbContextFactory.CreateDbContextAsync();
        var newList = new Models.ShoppingList
            {
                UserId = AuthService.CurrentUserId,
                Name = newListName.Trim(),
                CreatedAt = DateTime.UtcNow,
                IsCompleted = false
            };

        context.ShoppingList.Add(newList);
        await context.SaveChangesAsync();

        await LoadLists();
        await SelectList(newList.Id);
        newListName = "";
    }

    private async Task DeleteList(int listId)
    {
        await using var context = await DbContextFactory.CreateDbContextAsync();
        var list = await context.ShoppingList.FindAsync(listId);
        if (list != null)
        {
            context.ShoppingList.Remove(list);
            await context.SaveChangesAsync();
        }

        await LoadLists();

        if (currentListId == listId)
        {
            if (shoppingLists.Any())
            {
                await SelectList(shoppingLists.First().Id);
            }
            else
            {
                await SelectList(0);
            }
        }
    }

    private async Task AddItem()
    {
        if (newItemProductId == 0 || newItemQuantity <= 0 || currentListId == 0) return;

        await using var context = await DbContextFactory.CreateDbContextAsync();

        var existingItem = await context.ShoppingListItems
            .FirstOrDefaultAsync(i => i.ShoppingListId == currentListId && i.ProductId == newItemProductId);

        if (existingItem != null)
        {
            existingItem.Quantity += newItemQuantity;
        }
        else
        {
            context.ShoppingListItems.Add(new ShoppingListItem
                {
                    ShoppingListId = currentListId,
                    ProductId = newItemProductId,
                    Quantity = newItemQuantity,
                    IsPurchased = false
                });
        }

        await context.SaveChangesAsync();
        await LoadCurrentList();
        showModal = false;
    }

    private async Task RemoveItem(ShoppingListItem item)
    {
        await using var context = await DbContextFactory.CreateDbContextAsync();
        var dbItem = await context.ShoppingListItems.FindAsync(item.Id);
        if (dbItem != null)
        {
            context.ShoppingListItems.Remove(dbItem);
            await context.SaveChangesAsync();
        }

        await LoadCurrentList();
    }

    private async Task ClearPurchased()
    {
        if (currentListId == 0) return;

        await using var context = await DbContextFactory.CreateDbContextAsync();
        var purchased = await context.ShoppingListItems
            .Where(i => i.ShoppingListId == currentListId && i.IsPurchased)
            .ToListAsync();

        context.ShoppingListItems.RemoveRange(purchased);
        await context.SaveChangesAsync();

        await LoadCurrentList();
    }

    private async Task ClearAll()
    {
        if (currentListId == 0) return;

        await using var context = await DbContextFactory.CreateDbContextAsync();
        var items = await context.ShoppingListItems
            .Where(i => i.ShoppingListId == currentListId)
            .ToListAsync();

        context.ShoppingListItems.RemoveRange(items);
        await context.SaveChangesAsync();

        await LoadCurrentList();
    }
}