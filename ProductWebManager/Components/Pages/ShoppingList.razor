        font-weight: 500;
        cursor: pointer;
    }
</style>

@code {
    private List<ShoppingItem> shoppingItems = new();
    private bool showModal = false;
    private bool isEditing = false;
    private ShoppingItem currentItem = new();

    public class ShoppingItem
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public double Quantity { get; set; } = 1;
        public string Unit { get; set; } = "шт.";
        public string Category { get; set; } = "Другое";
        public bool IsPurchased { get; set; }
        public bool IsOnSale { get; set; }
        public double EstimatedPrice { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadItems();
    }

    private async Task LoadItems()
    {
        await Task.Delay(100);
        shoppingItems = new List<ShoppingItem>
        {
            new() { Id = 1, Name = "Хлеб", Quantity = 1, Unit = "шт.", Category = "Бакалея", EstimatedPrice = 50 },
            new() { Id = 2, Name = "Молоко", Quantity = 1, Unit = "л", Category = "Молочные", EstimatedPrice = 80, IsOnSale = true },
            new() { Id = 3, Name = "Курица", Quantity = 500, Unit = "г", Category = "Мясо и рыба", EstimatedPrice = 200 },
            new() { Id = 4, Name = "Помидоры", Quantity = 3, Unit = "шт.", Category = "Овощи и фрукты", EstimatedPrice = 120 },
            new() { Id = 5, Name = "Яблоки", Quantity = 5, Unit = "шт.", Category = "Овощи и фрукты", EstimatedPrice = 150 }
        };
    }

    private void TogglePurchased(ShoppingItem item) => item.IsPurchased = !item.IsPurchased;

    private void OpenAddModal() { currentItem = new ShoppingItem(); isEditing = false; showModal = true; }
    private void EditItem(ShoppingItem item) { currentItem = new ShoppingItem { Id = item.Id, Name = item.Name, Quantity = item.Quantity, Unit = item.Unit, Category = item.Category, IsOnSale = item.IsOnSale, EstimatedPrice = item.EstimatedPrice }; isEditing = true; showModal = true; }
    private void CloseModal() { showModal = false; }

    private void SaveItem()
    {
        if (string.IsNullOrWhiteSpace(currentItem.Name)) return;
        if (isEditing)
        {
            var existing = shoppingItems.FirstOrDefault(x => x.Id == currentItem.Id);
            if (existing != null) { existing.Name = currentItem.Name; existing.Quantity = currentItem.Quantity; existing.Unit = currentItem.Unit; existing.Category = currentItem.Category; existing.IsOnSale = currentItem.IsOnSale; existing.EstimatedPrice = currentItem.EstimatedPrice; }
        }
        else { currentItem.Id = shoppingItems.Any() ? shoppingItems.Max(x => x.Id) + 1 : 1; shoppingItems.Add(currentItem); }
        CloseModal();
    }

    private void RemoveItem(ShoppingItem item) => shoppingItems.Remove(item);
    private void ClearPurchased() => shoppingItems.RemoveAll(x => x.IsPurchased);
    private void ClearAll() => shoppingItems.Clear();
    private void ExportList() { /* TODO */ }

    private string GetCategoryIcon(string category) => category switch
    {
        "Бакалея" => "🌾",
        "Молочные" => "🥛",
        "Мясо и рыба" => "🥩",
        "Овощи и фрукты" => "🥬",
        "Напитки" => "🥤",
        "Заморозка" => "❄️",
        _ => "📦"
    };
}