    .shopping-checkbox {
        width: 20px;
        height: 20px;
        cursor: pointer;
    }

    .item-name {
        color: #1a1a2e;
        font-weight: 500;
        font-size: 14px;
    }

    .item-details {
        color: #999;
        font-size: 12px;
    }

    .sale-badge {
        background: #ffe8e8;
        color: #e74c3c;
        padding: 2px 8px;
        border-radius: 4px;
        font-size: 10px;
        font-weight: 600;
    }

    .btn-icon {
        background: #f8f8fa;
        border: 1px solid #eee;
        color: #999;
        font-size: 12px;
        padding: 4px 6px;
        cursor: pointer;
        border-radius: 6px;
    }

        .btn-icon:hover {
            background: #f0edff;
            border-color: #d5ccff;
            color: #6c5ce7;
        }

