@code {
    private List<Models.ShoppingList> shoppingLists = new();
    private List<Models.ShoppingListItem> shoppingItems = new();
    private List<Models.Product> availableProducts = new();
    private int currentListId;
    private bool showModal = false;
    private bool showListModal = false;
    private int selectedProductId;
    private double editQuantity = 1;
    private decimal estimatedTotal;
    private string newListName = "";

    protected override async Task OnInitializedAsync()
    {
        await LoadLists();
        await LoadProducts();
    }

    private async Task LoadLists()
    {
        try
        {
            shoppingLists = await DbContext.ShoppingList
                .Include(sl => sl.Items)
                    .ThenInclude(si => si.Product)
                        .ThenInclude(p => p.Unit)
                .Where(sl => sl.UserId == 1 && !sl.IsCompleted)
                .OrderByDescending(sl => sl.CreatedAt)
                .ToListAsync();

            if (!shoppingLists.Any())
            {
                var defaultList = new Models.ShoppingList
                    {
                        UserId = 1,
                        Name = "Основной",
                        IsCompleted = false,
                        CreatedAt = DateTime.UtcNow,
                        Items = new List<ShoppingListItem>()
                    };
                DbContext.ShoppingList.Add(defaultList);
                await DbContext.SaveChangesAsync();
                shoppingLists = await DbContext.ShoppingList
                    .Include(sl => sl.Items)
                        .ThenInclude(si => si.Product)
                            .ThenInclude(p => p.Unit)
                    .Where(sl => sl.UserId == 1 && !sl.IsCompleted)
                    .ToListAsync();
            }

            currentListId = shoppingLists.First().Id;
            await LoadCurrentList();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки списков: {ex.Message}");
        }
    }

    private async Task LoadCurrentList()
    {
        var currentList = shoppingLists.FirstOrDefault(sl => sl.Id == currentListId);
        if (currentList != null)
        {
            shoppingItems = currentList.Items?.ToList() ?? new List<ShoppingListItem>();
            UpdateTotal();
            StateHasChanged();
        }
    }

    private async Task LoadProducts()
    {
        try
        {
            availableProducts = await DbContext.Products
                .Include(p => p.Unit)
                .ToListAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки продуктов: {ex.Message}");
        }
    }

    private async Task SwitchList(int listId)
    {
        currentListId = listId;
        await LoadCurrentList();
    }

    private void UpdateTotal()
    {
        estimatedTotal = shoppingItems
            .Where(x => !x.IsPurchased)
            .Sum(x => (x.Product?.Price ?? 0) * (decimal)x.Quantity);
    }

    private async Task TogglePurchased(ShoppingListItem item)
    {
        item.IsPurchased = !item.IsPurchased;
        try
        {
            await DbContext.SaveChangesAsync();
            UpdateTotal();
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
    }

    private void OpenAddModal()
    {
        selectedProductId = 0;
        editQuantity = 1;
        showModal = true;
        StateHasChanged();
    }

    private void CloseModal()
    {
        showModal = false;
        StateHasChanged();
    }

    private void OpenListModal()
    {
        showListModal = true;
        newListName = "";
        StateHasChanged();
    }

    private void CloseListModal()
    {
        showListModal = false;
        StateHasChanged();
    }

    private async Task CreateNewList()
    {
        if (string.IsNullOrWhiteSpace(newListName)) return;

        try
        {
            var newList = new Models.ShoppingList
                {
                    UserId = 1,
                    Name = newListName.Trim(),
                    IsCompleted = false,
                    CreatedAt = DateTime.UtcNow,
                    Items = new List<ShoppingListItem>()
                };
            DbContext.ShoppingList.Add(newList);
            await DbContext.SaveChangesAsync();
            await LoadLists();
            CloseListModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка создания списка: {ex.Message}");
        }
    }

    private async Task SetActiveList(int listId)
    {
        await SwitchList(listId);
        CloseListModal();
    }

    private async Task DeleteList(int listId)
    {
        try
        {
            var list = await DbContext.ShoppingList
                .Include(sl => sl.Items)
                .FirstOrDefaultAsync(sl => sl.Id == listId);

            if (list != null)
            {
                DbContext.ShoppingListItems.RemoveRange(list.Items);
                DbContext.ShoppingList.Remove(list);
                await DbContext.SaveChangesAsync();
                await LoadLists();

                if (currentListId == listId && shoppingLists.Any())
                {
                    currentListId = shoppingLists.First().Id;
                    await LoadCurrentList();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка удаления списка: {ex.Message}");
        }
    }

    private async Task SaveItem()
    {
        if (selectedProductId == 0) return;

        try
        {
            var list = await DbContext.ShoppingList
                .Include(sl => sl.Items)
                .FirstOrDefaultAsync(sl => sl.Id == currentListId);

            if (list == null) return;

            var existingItem = list.Items.FirstOrDefault(i => i.ProductId == selectedProductId);
            if (existingItem != null)
            {
                existingItem.Quantity += (decimal)editQuantity;
            }
            else
            {
                list.Items.Add(new ShoppingListItem
                    {
                        ProductId = selectedProductId,
                        Quantity = (decimal)editQuantity,
                        IsPurchased = false
                    });
            }

            await DbContext.SaveChangesAsync();
            await LoadLists();
            CloseModal();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка сохранения: {ex.Message}");
        }
    }

    private async Task RemoveItem(ShoppingListItem item)
    {
        try
        {
            DbContext.ShoppingListItems.Remove(item);
            await DbContext.SaveChangesAsync();
            await LoadLists();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка удаления: {ex.Message}");
        }
    }

    private async Task ClearPurchased()
    {
        try
        {
            var purchased = shoppingItems.Where(x => x.IsPurchased).ToList();
            DbContext.ShoppingListItems.RemoveRange(purchased);
            await DbContext.SaveChangesAsync();
            await LoadLists();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
    }

    private async Task ClearAll()
    {
        try
        {
            var list = await DbContext.ShoppingList
                .Include(sl => sl.Items)
                .FirstOrDefaultAsync(sl => sl.Id == currentListId);

            if (list != null)
            {
                DbContext.ShoppingListItems.RemoveRange(list.Items);
                await DbContext.SaveChangesAsync();
                await LoadLists();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
    }
}