@page "/shopping-list"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ProductWebManager.Data.ProductManagerContext DbContext
@inject ProductWebManager.Services.AuthService AuthService
@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Models

<PageTitle>Список покупок</PageTitle>

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold m-0" style="color: #1a1a2e;">Список покупок</h2>
            <small style="color: #888;">
                Осталось купить: @shoppingItems.Count(x => !x.IsPurchased) из @shoppingItems.Count
            </small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-menu" @onclick="OpenListModal">
                Управление списками
            </button>
            @* <button class="btn btn-menu" @onclick="ClearPurchased">
                🧹 Очистить купленные
            </button> *@
            <button class="btn btn-add" @onclick="OpenAddModal">
                Добавить
            </button>
        </div>
    </div>

    @if (shoppingLists.Any())
    {
        <div class="lists-tabs mb-4">
            @foreach (var list in shoppingLists)
            {
                <button class="list-tab @(currentListId == list.Id ? "active" : "")"
                        @onclick="() => SwitchList(list.Id)">
                    @list.Name
                    @if (list.Items?.Count(x => !x.IsPurchased) > 0)
                    {
                        <span class="badge">@list.Items.Count(x => !x.IsPurchased)</span>
                    }
                </button>
            }
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="stat-card">
                <div class="stat-label">ВСЕГО</div>
                <div class="stat-value" style="color: #6c5ce7;">@shoppingItems.Count</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card stat-card-success">
                <div class="stat-label">КУПЛЕНО</div>
                <div class="stat-value" style="color: #27ae60;">@shoppingItems.Count(x => x.IsPurchased)</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card stat-card-warning">
                <div class="stat-label">ОСТАЛОСЬ</div>
                <div class="stat-value" style="color: #f39c12;">@shoppingItems.Count(x => !x.IsPurchased)</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card">
                <div class="stat-label">ПРИМЕРНАЯ СУММА</div>
                <div class="stat-value" style="color: #6c5ce7;">@estimatedTotal ₽</div>
            </div>
        </div>
    </div>

    @if (shoppingItems.Any())
    {
        <div class="category-section mb-3">
            @foreach (var item in shoppingItems)
            {
                <div class="shopping-item @(item.IsPurchased ? "purchased" : "")">
                    <div class="d-flex align-items-center gap-3">
                        <input type="checkbox"
                               class="form-check-input shopping-checkbox"
                               checked="@item.IsPurchased"
                               @onchange="() => TogglePurchased(item)" />

                        <div class="flex-grow-1">
                            <div class="item-name @(item.IsPurchased ? "text-decoration-line-through" : "")">
                                @item.Product?.Name
                            </div>
                            <div class="item-details">
                                @item.Quantity @(item.Product?.Unit?.Name ?? "шт.")
                                @if (item.Product?.Price > 0)
                                {
                                    <span>• ~@(item.Product.Price * item.Quantity) ₽</span>
                                }
                            </div>
                        </div>

                        <div class="d-flex gap-1">
                            <button class="btn-icon-delete" @onclick="() => RemoveItem(item)">✖ Удалить</button>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="d-flex gap-2 justify-content-end mt-4">
            <button class="btn btn-danger" @onclick="ClearAll">Очистить всё</button>
        </div>
    }
    else
    {
        <div class="empty-state">
            <h4 style="color: #555;">Список пуст</h4>
            <p style="color: #999;">Добавьте продукты для покупки</p>
            <button class="btn btn-add" @onclick="OpenAddModal">Добавить</button>
        </div>
    }
</div>

<!-- Модальное окно добавления продукта -->
@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-dialog" @onclick:stopPropagation="true">
            <h4 class="modal-title">Добавить покупку</h4>
            <div class="mb-3">
                <label class="form-label">Продукт</label>
                <select class="form-control modal-input" @bind="selectedProductId">
                    <option value="0">-- Выберите продукт --</option>
                    @if (availableProducts != null)
                    {
                        @foreach (var p in availableProducts)
                        {
                            <option value="@p.Id">@p.Name</option>
                        }
                    }
                </select>
            </div>
            <div class="row mb-4">
                <div class="col-md-6">
                    <label class="form-label">Количество</label>
                    <input type="number" class="form-control modal-input" @bind="editQuantity" min="0.1" step="0.1" />
                </div>
            </div>
            <div class="d-flex gap-2">
                <button type="button" class="btn-modal-save" @onclick="SaveItem">Сохранить</button>
                <button type="button" class="btn-modal-cancel" @onclick="CloseModal">Отмена</button>
            </div>
        </div>
    </div>
}

@if (showListModal)
{
    <div class="modal-overlay" @onclick="CloseListModal">
        <div class="modal-dialog" @onclick:stopPropagation="true" style="max-width: 500px;">
            <h4 class="modal-title">Управление списками покупок</h4>

            <div class="mb-3">
                <label class="form-label">Новый список</label>
                <div class="d-flex gap-2">
                    <input type="text" class="form-control modal-input" @bind="newListName" placeholder="Название списка" />
                    <button type="button" class="btn-modal-save" @onclick="CreateNewList" style="flex: 0 0 auto;">Создать</button>
                </div>
            </div>

            <div class="lists-container">
                @foreach (var list in shoppingLists)
                {
                    <div class="list-manager-item">
                        <div class="list-info">
                            <div class="list-name">@list.Name</div>
                            <div class="list-stats">
                                @(list.Items?.Count ?? 0) товаров,
                                @(list.Items?.Count(x => !x.IsPurchased) ?? 0) осталось
                            </div>
                        </div>
                        <div class="d-flex gap-1">
                            <button class="btn-icon-sm delete" @onclick="() => DeleteList(list.Id)">✖ Удалить</button>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

