@code {

    private List<Models.ShoppingList> shoppingLists = new();

    private List<ShoppingListItem> shoppingItems = new();

    private List<Product> availableProducts = new();

    private int currentListId;

    private bool showModal;

    private bool showListModal;

    private int selectedProductId;

    private double editQuantity = 1;

    private decimal estimatedTotal;

    private string newListName = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        await LoadLists();
        await LoadProducts();
    }

    private async Task LoadLists()
    {
        var userId = AuthService.CurrentUserId;

        shoppingLists = await DbContext.ShoppingList

            .Include(sl => sl.Items)
                .ThenInclude(i => i.Product)
                    .ThenInclude(p => p.Unit)

            .Where(sl =>
                sl.UserId == userId &&
                !sl.IsCompleted)

            .OrderByDescending(sl => sl.CreatedAt)

            .ToListAsync();

        if (!shoppingLists.Any())
        {
            var defaultList = new Models.ShoppingList
                {
                    UserId = userId,
                    Name = "Основной",
                    CreatedAt = DateTime.UtcNow,
                    IsCompleted = false
                };

            DbContext.ShoppingList.Add(defaultList);

            await DbContext.SaveChangesAsync();

            shoppingLists.Add(defaultList);
        }

        currentListId = shoppingLists.First().Id;

        await LoadCurrentList();
    }

    private async Task LoadCurrentList()
    {
        var list = await DbContext.ShoppingList

            .Include(sl => sl.Items)
                .ThenInclude(i => i.Product)
                    .ThenInclude(p => p.Unit)

            .FirstOrDefaultAsync(sl =>
                sl.Id == currentListId);

        shoppingItems = list?.Items?.ToList()
            ?? new List<ShoppingListItem>();

        UpdateTotal();
    }

    private async Task LoadProducts()
    {
        availableProducts = await DbContext.Products

            .Include(p => p.Unit)

            .OrderBy(p => p.Name)

            .ToListAsync();
    }

    private async Task DeleteList(int listId)
    {
        var list = await DbContext.ShoppingList

            .Include(sl => sl.Items)

            .FirstOrDefaultAsync(sl =>
                sl.Id == listId);

        if (list == null)
            return;

        DbContext.ShoppingListItems
            .RemoveRange(list.Items);

        DbContext.ShoppingList.Remove(list);

        await DbContext.SaveChangesAsync();

        await LoadLists();

        if (shoppingLists.Any())
        {
            currentListId = shoppingLists.First().Id;

            await LoadCurrentList();
        }
    }

    private async Task SwitchList(int listId)
    {
        currentListId = listId;

        await LoadCurrentList();
    }

    private void UpdateTotal()
    {
        estimatedTotal = shoppingItems

            .Where(i => !i.IsPurchased)

            .Sum(i =>
                (i.Product?.Price ?? 0)
                * (decimal)i.Quantity);
    }

    private async Task TogglePurchased(
        ShoppingListItem item)
    {
        item.IsPurchased = !item.IsPurchased;

        await DbContext.SaveChangesAsync();

        UpdateTotal();
    }

    private void OpenAddModal()
    {
        selectedProductId = 0;
        editQuantity = 1;
        showModal = true;
    }

    private void CloseModal()
    {
        showModal = false;
    }

    private void OpenListModal()
    {
        newListName = string.Empty;
        showListModal = true;
    }

    private void CloseListModal()
    {
        showListModal = false;
    }

    private async Task CreateNewList()
    {
        if (string.IsNullOrWhiteSpace(newListName))
            return;

        var list = new Models.ShoppingList
            {
                UserId = AuthService.CurrentUserId,
                Name = newListName.Trim(),
                CreatedAt = DateTime.UtcNow,
                IsCompleted = false
            };

        DbContext.ShoppingList.Add(list);

        await DbContext.SaveChangesAsync();

        await LoadLists();

        showListModal = false;
    }

    private async Task SaveItem()
    {
        if (selectedProductId == 0)
            return;

        var list = await DbContext.ShoppingList

            .Include(sl => sl.Items)

            .FirstOrDefaultAsync(sl =>
                sl.Id == currentListId);

        if (list == null)
            return;

        var existing = list.Items
            .FirstOrDefault(i =>
                i.ProductId == selectedProductId);

        if (existing != null)
        {
            existing.Quantity += editQuantity;
        }
        else
        {
            list.Items.Add(new ShoppingListItem
                {
                    ProductId = selectedProductId,
                    Quantity = editQuantity,
                    IsPurchased = false
                });
        }

        await DbContext.SaveChangesAsync();

        await LoadCurrentList();

        showModal = false;
    }

    private async Task RemoveItem(
        ShoppingListItem item)
    {
        DbContext.ShoppingListItems.Remove(item);

        await DbContext.SaveChangesAsync();

        await LoadCurrentList();
    }

    private async Task ClearPurchased()
    {
        var purchased = shoppingItems
            .Where(i => i.IsPurchased)
            .ToList();

        DbContext.ShoppingListItems
            .RemoveRange(purchased);

        await DbContext.SaveChangesAsync();

        await LoadCurrentList();
    }

    private async Task ClearAll()
    {
        DbContext.ShoppingListItems
            .RemoveRange(shoppingItems);

        await DbContext.SaveChangesAsync();

        await LoadCurrentList();
    }

}