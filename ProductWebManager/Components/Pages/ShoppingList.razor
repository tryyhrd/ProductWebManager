        background: #f5fff5;
        border-color: #d4ffd4;
    }

    .stat-card-warning {
        background: #fffcf0;
        border-color: #ffe8a0;
    }

    .stat-label {
        color: #999;
        font-size: 10px;
        font-weight: 600;
    }

    .stat-value {
        font-size: 26px;
        font-weight: 700;
    }

    .category-section {
        background: white;
        border: 1px solid #e8e8ec;
        border-radius: 14px;
        padding: 20px;
    }

    .category-title {
        color: #1a1a2e;
        font-size: 16px;
        font-weight: 600;
        margin-bottom: 12px;
    }

    .category-count {
        font-size: 12px;
        color: #999;
        font-weight: 400;
    }

    .shopping-item {
        padding: 12px 0;
        border-bottom: 1px solid #f0f0f0;
