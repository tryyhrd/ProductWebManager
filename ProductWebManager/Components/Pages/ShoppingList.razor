@page "/shopping-list"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Models

@inject NavigationManager Navigation
@inject ProductWebManager.Data.ProductManagerContext DbContext
@inject ProductWebManager.Services.AuthService AuthService

<PageTitle>Список покупок</PageTitle>

<div class="shopping-page">

    <!-- HEADER -->

    <div class="page-header">

        <div>
            <h1 class="page-title">
                🛒 Список покупок
            </h1>

            <div class="page-subtitle">
                Осталось купить:
                <strong>@shoppingItems.Count(x => !x.IsPurchased)</strong>
                из
                <strong>@shoppingItems.Count</strong>
            </div>
        </div>

        <div class="header-actions">

            <button class="btn-outline"
                    @onclick="OpenListModal">

                📋 Списки

            </button>

            <button class="btn-primary"
                    @onclick="OpenAddModal">

                ➕ Добавить

            </button>

        </div>

    </div>

    <!-- LIST TABS -->
    @if (shoppingLists.Any())
    {
        <div class="lists-tabs">

            @foreach (var list in shoppingLists)
            {
                <button class="list-tab @(currentListId == list.Id ? "active" : "")"
                        @onclick="() => SwitchList(list.Id)">

                    @list.Name

                    @if ((list.Items?.Count(x => !x.IsPurchased) ?? 0) > 0)
                    {
                        <span class="tab-badge">
                            @list.Items!.Count(x => !x.IsPurchased)
                        </span>
                    }

                </button>
            }

        </div>
    }

    <!-- STATS -->

    <div class="stats-grid">

        <div class="stat-card">
            <div class="stat-label">ВСЕГО</div>
            <div class="stat-value">@shoppingItems.Count</div>
        </div>

        <div class="stat-card success">
            <div class="stat-label">КУПЛЕНО</div>
            <div class="stat-value">
                @shoppingItems.Count(x => x.IsPurchased)
            </div>
        </div>

        <div class="stat-card warning">
            <div class="stat-label">ОСТАЛОСЬ</div>
            <div class="stat-value">
                @shoppingItems.Count(x => !x.IsPurchased)
            </div>
        </div>

        <div class="stat-card">
            <div class="stat-label">СУММА</div>
            <div class="stat-value">
                @estimatedTotal.ToString("0.##") ₽
            </div>
        </div>

    </div>

    <!-- ITEMS -->
    @if (shoppingItems.Any())
    {
        <div class="shopping-container">

            @foreach (var item in shoppingItems)
            {
                <div class="shopping-item @(item.IsPurchased ? "purchased" : "")">

                    <div class="item-left">

                        <input type="checkbox"
                               checked="@item.IsPurchased"
                               @onchange="async _ => await TogglePurchased(item)"
                               class="shopping-checkbox" />

                        <div>

                            <div class="item-name">

                                @if (item.IsPurchased)
                                {
                                    <s>@item.Product?.Name</s>
                                }
                                else
                                {
                                    @item.Product?.Name
                                }

                            </div>

                            <div class="item-details">

                                @item.Quantity
                                @(item.Product?.Unit?.Name ?? "шт.")

                                @if ((item.Product?.Price ?? 0) > 0)
                                {
                                    <span>
                                        • ~@(((item.Product?.Price ?? 0m) * (decimal)item.Quantity).ToString("0.##")) ₽
                                    </span>
                                }

                            </div>

                        </div>

                    </div>

                    <button class="btn-delete"
                            @onclick="() => RemoveItem(item)">

                        ✖ Удалить

                    </button>

                </div>
            }

        </div>

        <div class="footer-actions">

            <button class="btn-danger"
                    @onclick="ClearPurchased">

                🧹 Очистить купленные

            </button>

            <button class="btn-danger"
                    @onclick="ClearAll">

                ❌ Очистить всё

            </button>

        </div>
    }
    else
    {
        <div class="empty-state">

            <div class="empty-icon">
                🛒
            </div>

            <h3>
                Список покупок пуст
            </h3>

            <p>
                Добавьте товары для покупки
            </p>

            <button class="btn-primary"
                    @onclick="OpenAddModal">

                ➕ Добавить товар

            </button>

        </div>
    }

</div>

<!-- ADD MODAL -->
@if (showModal)
{
    <div class="modal-overlay"
         @onclick="CloseModal">

        <div class="modal-box"
             @onclick:stopPropagation="true">

            <h3 class="modal-title">
                Добавить продукт
            </h3>

            <div class="form-group">

                <label>
                    Продукт
                </label>

                <select class="form-input"
                        @bind="selectedProductId">

                    <option value="0">
                        -- Выберите продукт --
                    </option>

                    @foreach (var product in availableProducts)
                    {
                        <option value="@product.Id">
                            @product.Name
                        </option>
                    }

                </select>

            </div>

            <div class="form-group">

                <label>
                    Количество
                </label>

                <input type="number"
                       class="form-input"
                       min="0.1"
                       step="0.1"
                       @bind="editQuantity" />

            </div>

            <div class="modal-actions">

                <button class="btn-primary"
                        @onclick="SaveItem">

                    Сохранить

                </button>

                <button class="btn-outline"
                        @onclick="CloseModal">

                    Отмена

                </button>

            </div>

        </div>

    </div>
}

<!-- LIST MODAL -->
@if (showListModal)
{
    <div class="modal-overlay"
         @onclick="CloseListModal">

        <div class="modal-box large"
             @onclick:stopPropagation="true">

            <h3 class="modal-title">
                Управление списками
            </h3>

            <div class="form-group">

                <label>
                    Новый список
                </label>

                <div class="create-list-row">

                    <input type="text"
                           class="form-input"
                           placeholder="Название списка"
                           @bind="newListName" />

                    <button class="btn-primary"
                            @onclick="CreateNewList">

                        Создать

                    </button>

                </div>

            </div>

            <div class="lists-manager">

                @foreach (var list in shoppingLists)
                {
                    <div class="manager-item">

                        <div>

                            <div class="manager-title">
                                @list.Name
                            </div>

                            <div class="manager-subtitle">

                                @(list.Items?.Count ?? 0)
                                товаров

                            </div>

                        </div>

                        <div class="manager-actions">

                            <button class="btn-outline small"
                                    @onclick="() => SwitchList(list.Id)">

                                Открыть

                            </button>

                            <button class="btn-danger small"
                                    @onclick="() => DeleteList(list.Id)">

                                Удалить

                            </button>

                        </div>

                    </div>
                }

            </div>

        </div>

    </div>
}

