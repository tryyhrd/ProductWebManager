@page "/shopping-list"
@inject NavigationManager Navigation

<PageTitle>Список покупок</PageTitle>

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold m-0" style="color: #1a1a2e;">Список покупок</h2>
            <small style="color: #888;">
                Осталось купить: @shoppingItems.Count(x => !x.IsPurchased) из @shoppingItems.Count
            </small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-menu" @onclick="ClearPurchased">
                Очистить купленные
            </button>
            <button class="btn btn-add" @onclick="OpenAddModal">
                Добавить
            </button>
        </div>
    </div>

    <div class="row mb-4">
        <div class="col-md-3 mb-3">
            <div class="stat-card">
                <div class="stat-label">ВСЕГО</div>
                <div class="stat-value" style="color: #6c5ce7;">@shoppingItems.Count</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card stat-card-success">
                <div class="stat-label">КУПЛЕНО</div>
                <div class="stat-value" style="color: #27ae60;">@shoppingItems.Count(x => x.IsPurchased)</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card stat-card-warning">
                <div class="stat-label">ОСТАЛОСЬ</div>
                <div class="stat-value" style="color: #f39c12;">@shoppingItems.Count(x => !x.IsPurchased)</div>
            </div>
        </div>
        <div class="col-md-3 mb-3">
            <div class="stat-card">
                <div class="stat-label">ПРИМЕРНАЯ СУММА</div>
                <div class="stat-value" style="color: #6c5ce7;">@shoppingItems.Sum(x => x.EstimatedPrice) ₽</div>
            </div>
        </div>
    </div>

    @if (shoppingItems.Any())
    {
        @foreach (var group in shoppingItems.GroupBy(x => x.Category))
        {
            <div class="category-section mb-3">
                <h5 class="category-title">
                    @* @GetCategoryIcon(group.Key) @group.Key *@
                    <span class="category-count">@group.Count(x => !x.IsPurchased) ост.</span>
                </h5>

                @foreach (var item in group)
                {
                    <div class="shopping-item @(item.IsPurchased ? "purchased" : "")">
                        <div class="d-flex align-items-center gap-3">
                            <input type="checkbox"
                                   class="form-check-input shopping-checkbox"
                                   checked="@item.IsPurchased"
                                   @onchange="() => TogglePurchased(item)" />

                            <div class="flex-grow-1">
                                <div class="item-name @(item.IsPurchased ? "text-decoration-line-through" : "")">
                                    @item.Name
                                </div>
                                <div class="item-details">
                                    @item.Quantity @item.Unit
                                    @if (item.EstimatedPrice > 0)
                                    {
                                        <span>• ~@item.EstimatedPrice ₽</span>
                                    }
                                    @if (item.IsOnSale)
                                    {
                                        <span class="sale-badge">АКЦИЯ</span>
                                    }
                                </div>
                            </div>

                            <div class="d-flex gap-1">
                                <button class="btn-icon" @onclick="() => EditItem(item)">Редактировать</button>
                                <button class="btn-icon" @onclick="() => RemoveItem(item)">Удалить</button>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }

        <div class="d-flex gap-2 justify-content-end mt-4">
            <button class="btn btn-menu" @onclick="ExportList">Экспорт</button>
            <button class="btn btn-menu" @onclick="ClearAll">Очистить всё</button>
        </div>
    }
    else
    {
        <div class="empty-state">
            @* <div class="empty-icon">🛒</div> *@
            <h4 style="color: #555;">Список пуст</h4>
            <p style="color: #999;">Добавьте продукты для покупки</p>
            <button class="btn btn-add" @onclick="OpenAddModal">Добавить</button>
        </div>
    }
</div>

@if (showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-dialog" @onclick:stopPropagation="true">
            <h4 style="color: #1a1a2e; margin-bottom: 20px; font-weight: 600;">
                @(isEditing ? "✏️ Редактировать" : "➕ Добавить") покупку
            </h4>

            <div class="mb-3">
                <label class="form-label">Название</label>
                <input type="text" class="form-control modal-input" @bind="currentItem.Name" placeholder="Например: Хлеб" />
            </div>

            <div class="row mb-3">
                <div class="col-md-4">
                    <label class="form-label">Количество</label>
                    <input type="number" class="form-control modal-input" @bind="currentItem.Quantity" min="1" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Единица</label>
                    <select class="form-control modal-input" @bind="currentItem.Unit">
                        <option value="шт.">шт.</option>
                        <option value="кг">кг</option>
                        <option value="г">г</option>
                        <option value="л">л</option>
                        <option value="упак.">упак.</option>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Цена (~)</label>
                    <input type="number" class="form-control modal-input" @bind="currentItem.EstimatedPrice" min="0" />
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label">Категория</label>
                <select class="form-control modal-input" @bind="currentItem.Category">
                    <option value="Бакалея">🌾 Бакалея</option>
                    <option value="Молочные">🥛 Молочные</option>
                    <option value="Мясо и рыба">🥩 Мясо и рыба</option>
                    <option value="Овощи и фрукты">🥬 Овощи и фрукты</option>
                    <option value="Напитки">🥤 Напитки</option>
                    <option value="Заморозка">❄️ Заморозка</option>
                    <option value="Другое">📦 Другое</option>
                </select>
            </div>

            <div class="form-check mb-4">
                <input type="checkbox" class="form-check-input" @bind="currentItem.IsOnSale" />
                <label class="form-check-label" style="color: #666; font-size: 13px;">Товар по акции</label>
            </div>

            <div class="d-flex gap-2">
                <button class="btn-modal-save" @onclick="SaveItem">Сохранить</button>
                <button class="btn-modal-cancel" @onclick="CloseModal">Отмена</button>
            </div>
        </div>
    </div>
}

