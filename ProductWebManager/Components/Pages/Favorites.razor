    }

    .empty-icon {
        font-size: 72px;
        opacity: 0.25;
    }
</style>

@code {
    private List<FavoriteRecipe> favoriteRecipes = new();
    private HashSet<int> fridgeProductIds = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadFavorites();
    }

    private async Task LoadFavorites()
    {
        try
        {
            favoriteRecipes = await DbContext.FavoriteRecipes
                .Include(f => f.Recipe)
                    .ThenInclude(r => r.RecipeIngredients)
                        .ThenInclude(ri => ri.Product)
                .Where(f => f.UserId == AuthService.CurrentUserId)
                .ToListAsync();

            fridgeProductIds = (await DbContext.FridgeItems
                .Where(f => f.UserId == 1 && f.Quanity > 0)
                .Select(f => f.ProductId)
                .ToListAsync())
                .ToHashSet();

            StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки избранного: {ex.Message}");
        }
    }

    private async Task RemoveFromFavorites(FavoriteRecipe item)
    {
        try
        {
            DbContext.FavoriteRecipes.Remove(item);
            await DbContext.SaveChangesAsync();
            await LoadFavorites();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка удаления из избранного: {ex.Message}");
        }
    }

    private async Task ClearAllFavorites()
    {
        try
        {
            var all = await DbContext.FavoriteRecipes
                .Where(f => f.UserId == AuthService.CurrentUserId)
                .ToListAsync();

            DbContext.FavoriteRecipes.RemoveRange(all);
            await DbContext.SaveChangesAsync();
            await LoadFavorites();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка очистки избранного: {ex.Message}");
        }
    }

    private void GoToRecipes() => Navigation.NavigateTo("/recipes");

    private string GetRecipeWord(int count)
    {
        if (count % 10 == 1 && count % 100 != 11) return "рецепт";
        if (count % 10 >= 2 && count % 10 <= 4 && (count % 100 < 10 || count % 100 >= 20)) return "рецепта";
        return "рецептов";
    }

    private string GetRecipeGradient(int id) => (id % 8) switch
    {
        0 => "linear-gradient(135deg, #ff6b6b, #ff8e8e)",
        1 => "linear-gradient(135deg, #ffa502, #ffbe76)",
        2 => "linear-gradient(135deg, #a29bfe, #6c5ce7)",
        3 => "linear-gradient(135deg, #fd79a8, #e84393)",
        4 => "linear-gradient(135deg, #00b894, #55efc4)",
        5 => "linear-gradient(135deg, #fdcb6e, #ffeaa7)",
        6 => "linear-gradient(135deg, #74b9ff, #0984e3)",
        _ => "linear-gradient(135deg, #e17055, #d63031)"
    };

    private string GetDifficultyClass(int time) => time switch
    {
        <= 30 => "easy",
        <= 60 => "medium",
        _ => "hard"
    };

    private string GetDifficultyText(int time) => time switch
    {
        <= 30 => "Легко",
        <= 60 => "Средне",
        _ => "Сложно"
    };
}