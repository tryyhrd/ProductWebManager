@page "/favorites"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>Избранное</PageTitle>

<div class="container-fluid p-4">
    <!-- Верхняя панель -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold m-0" style="color: #1a1a2e;">⭐ Избранные рецепты</h2>
            <small style="color: #888;">@favoriteRecipes.Count @GetRecipeWord(favoriteRecipes.Count) в избранном</small>
        </div>
    </div>

    <!-- Список избранного -->
    @if (favoriteRecipes.Any())
    {
        <div class="row">
            @foreach (var recipe in favoriteRecipes)
            {
                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="favorite-card">
                        <!-- Изображение -->
                        <div class="favorite-image" style="background: @GetRecipeGradient(recipe.Category);">
                            <button class="btn-remove-favorite" @onclick="() => RemoveFromFavorites(recipe)" title="Удалить из избранного">
                                ✕
                            </button>
                            <div class="favorite-badge">❤️</div>
                        </div>

                        <!-- Информация -->
                        <div class="favorite-info">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="recipe-name">@recipe.Name</h6>
                                    <span class="recipe-category">@GetCategoryDisplay(recipe.Category)</span>
                                </div>
                            </div>

                            <p class="recipe-desc">@recipe.Description</p>

                            <div class="recipe-stats">
                                <span class="stat-item">⏱️ @recipe.CookingTime мин</span>
                                <span class="stat-item">🔥 @recipe.Calories ккал</span>
                            </div>

                            <!-- Ингредиенты -->
                            <div class="ingredients-preview mt-2">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="availability-bar">
                                        <div class="availability-fill"
                                             style="width: @GetAvailabilityPercent(recipe)%; background: @GetAvailabilityColor(recipe);">
                                        </div>
                                    </div>
                                    <span class="availability-text" style="color: @GetAvailabilityColor(recipe);">
                                        @GetAvailableCount(recipe)/@recipe.Ingredients.Count инг.
                                    </span>
                                </div>
                            </div>

                            <!-- Дата добавления -->
                            <div class="added-date mt-2">
                                Добавлен @recipe.AddedToFavorites.ToString("dd.MM.yyyy")
                            </div>

                            <!-- Кнопки -->
                            <div class="d-flex gap-2 mt-3">
                                <a href="@($"/recipe/{recipe.Id}")"
                                   class="btn-recipe-view flex-grow-1 text-center text-decoration-none">
                                    Открыть
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <!-- Действия -->
        <div class="d-flex gap-2 justify-content-center mt-4">
            <button class="btn btn-menu" @onclick="ExportFavorites">
                Экспорт списка
            </button>
            <button class="btn btn-menu" @onclick="ClearAllFavorites">
                Очистить всё
            </button>
        </div>
    }
    else
    {
        <!-- Пустое состояние -->
        <div class="empty-state">
            <div class="empty-icon">⭐</div>
            <h4 style="color: #555; margin-top: 16px;">Нет избранных рецептов</h4>
            <p style="color: #999; margin-bottom: 16px;">
                Добавляйте рецепты в избранное, нажимая на ❤️
            </p>
            <div class="d-flex gap-2 justify-content-center">
                <button class="btn btn-add" @* @onclick="() => Navigation.NavigateTo('/recipes')" *@>
                    📖 Найти рецепты
                </button>
                <button class="btn btn-menu" @onclick="RefreshFavorites">
                    🔄 Обновить
                </button>
            </div>
        </div>
    }

    @if (showDeleteConfirm)
    {
        <div class="modal-overlay" @onclick="CancelDelete">
            <div class="modal-dialog" @onclick:stopPropagation="true" style="max-width: 380px;">
                <h4 style="color: #1a1a2e; margin-bottom: 16px; font-weight: 600;">🗑️ Подтверждение</h4>
                <p style="color: #666; margin-bottom: 20px;">
                    Удалить <strong style="color: #e74c3c;">@recipeToDelete?.Name</strong> из избранного?
                </p>
                <div class="d-flex gap-2">
                    <button class="btn-modal-delete" @onclick="ConfirmDelete">Удалить</button>
                    <button class="btn-modal-cancel" @onclick="CancelDelete">Отмена</button>
                </div>
            </div>
        </div>
    }
</div>

