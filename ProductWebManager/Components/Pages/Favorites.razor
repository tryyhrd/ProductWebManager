        border: none;
        border-radius: 8px;
        background: #6c5ce7;
        color: white;
        font-weight: 500;
        font-size: 13px;
        cursor: pointer;
        box-shadow: 0 2px 6px rgba(108, 92, 231, 0.3);
        transition: all 0.2s;
    }

        .btn-add:hover {
            background: #5a4bd1;
        }

    .btn-menu {
        padding: 8px 18px;
        border: 1px solid #ddd;
        border-radius: 8px;
        background: white;
        color: #555;
        font-weight: 500;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-menu:hover {
            background: #f8f8fa;
            border-color: #ccc;
        }

    .favorite-card {
        background: white;
        border: 1px solid #eee;
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
        height: 100%;
    }

        .favorite-card:hover {
            box-shadow: 0 8px 24px rgba(0,0,0,0.1);
            transform: translateY(-4px);
        }

    .favorite-image {
        height: 140px;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .btn-remove-favorite {
        position: absolute;
        top: 12px;
        right: 12px;
        background: rgba(0,0,0,0.5);
        border: none;
        border-radius: 50%;
        width: 28px;
        height: 28px;
        color: white;
        font-size: 14px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: all 0.2s;
        backdrop-filter: blur(4px);
    }

        .btn-remove-favorite:hover {
            background: rgba(231, 76, 60, 0.8);
        }

    .favorite-badge {
        font-size: 48px;
        filter: drop-shadow(0 2px 4px rgba(0,0,0,0.3));
    }

    .favorite-info {
        padding: 16px;
    }

    .recipe-name {
        color: #1a1a2e;
        font-size: 15px;
        font-weight: 600;
        margin-bottom: 2px;
    }

    .recipe-desc {
        color: #999;
        font-size: 12px;
        margin: 8px 0;
        line-height: 1.4;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .difficulty-badge {
        padding: 2px 8px;
        border-radius: 10px;
        font-size: 10px;
        font-weight: 500;
    }

        .difficulty-badge.easy {
            background: #e8f5e9;
            color: #27ae60;
        }

        .difficulty-badge.medium {
            background: #fff8e1;
