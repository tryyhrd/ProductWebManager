                    new() { Name = "Молоко", IsAvailable = true }
                }
            },
            new()
            {
                Id = 3,
                Name = "Греческий салат",
                Description = "Свежий салат с помидорами, огурцами и фетой",
                Category = "salad",
                Difficulty = "easy",
                CookingTime = 15,
                Calories = 180,
                Servings = 2,
                AddedToFavorites = DateTime.Now.AddDays(-10),
                Ingredients = new List<Ingredient>
                {
                    new() { Name = "Помидоры", IsAvailable = true },
