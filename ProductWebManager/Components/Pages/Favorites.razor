    private void RefreshFavorites()
    {
        // TODO: Обновить из БД
    }

    private void OpenRecipe(FavoriteRecipe recipe)
    {
        Navigation.NavigateTo($"/recipe/{1}");
        StateHasChanged();
    }

    private void CookRecipe(FavoriteRecipe recipe)
    {
        Navigation.NavigateTo($"/recipe/{recipe.Id}");
    }

    private void RemoveFromFavorites(FavoriteRecipe recipe)
    {
        recipeToDelete = recipe;
        showDeleteConfirm = true;
    }

    private void CancelDelete()
    {
        showDeleteConfirm = false;
        recipeToDelete = null;
    }

    private void ConfirmDelete()
    {
        if (recipeToDelete != null)
        {
            favoriteRecipes.Remove(recipeToDelete);
        }
        CancelDelete();
    }

    private void ClearAllFavorites()
    {
        favoriteRecipes.Clear();
        // TODO: Очистить в БД
    }

    private void ExportFavorites()
    {
        // TODO: Экспорт в PDF/текст
    }

    private string GetRecipeWord(int count)
    {
        if (count % 10 == 1 && count % 100 != 11) return "рецепт";
        if (count % 10 >= 2 && count % 10 <= 4 && (count % 100 < 10 || count % 100 >= 20)) return "рецепта";
        return "рецептов";
    }

    private string GetRecipeGradient(string category) => category switch
    {
        "breakfast" => "linear-gradient(135deg, #fdcb6e, #ffeaa7)",
        "lunch" => "linear-gradient(135deg, #74b9ff, #0984e3)",
        "dinner" => "linear-gradient(135deg, #ff6b6b, #ff8e8e)",
        "dessert" => "linear-gradient(135deg, #fd79a8, #e84393)",
        "snack" => "linear-gradient(135deg, #a29bfe, #6c5ce7)",
        "salad" => "linear-gradient(135deg, #00b894, #55efc4)",
        "soup" => "linear-gradient(135deg, #e17055, #d63031)",
        _ => "linear-gradient(135deg, #636e72, #b2bec3)"
    };

    private string GetCategoryDisplay(string category) => category switch
    {
        "breakfast" => "🌅 Завтрак",
        "lunch" => "🌞 Обед",
        "dinner" => "🌙 Ужин",
        "dessert" => "🍰 Десерт",
        "snack" => "🥨 Перекус",
        "salad" => "🥗 Салат",
        "soup" => "🍜 Суп",
        _ => "📦 Другое"
    };

    private string GetDifficultyText(string difficulty) => difficulty switch
    {
        "easy" => "Легко",
        "medium" => "Средне",
        "hard" => "Сложно",
        _ => "Легко"
    };

    private int GetAvailableCount(FavoriteRecipe recipe) => recipe.Ingredients.Count(i => i.IsAvailable);

    private double GetAvailabilityPercent(FavoriteRecipe recipe) =>
        recipe.Ingredients.Count > 0 ? (double)GetAvailableCount(recipe) / recipe.Ingredients.Count * 100 : 0;

    private string GetAvailabilityColor(FavoriteRecipe recipe)
    {
        var percent = GetAvailabilityPercent(recipe);
        if (percent >= 80) return "#27ae60";
        if (percent >= 50) return "#f39c12";
        return "#e74c3c";
    }
}