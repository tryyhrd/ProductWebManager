@page "/favorites"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ProductWebManager.Data.ProductManagerContext DbContext
@inject ProductWebManager.Services.AuthService AuthService
@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Models

<PageTitle>Избранное</PageTitle>

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold m-0" style="color: #1a1a2e;">⭐ Избранные рецепты</h2>
            <small style="color: #888;">@favoriteRecipes.Count @GetRecipeWord(favoriteRecipes.Count) в избранном</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-add" @onclick="GoToRecipes">
                Все рецепты
            </button>
        </div>
    </div>

    @if (favoriteRecipes.Any())
    {
        <div class="row">
            @foreach (var item in favoriteRecipes)
            {
                var recipe = item.Recipe;
                if (recipe == null) continue;

                var availableCount = recipe.RecipeIngredients?.Count(ri => fridgeProductIds.Contains(ri.ProductId)) ?? 0;
                var totalCount = recipe.RecipeIngredients?.Count ?? 0;
                var availabilityPercent = totalCount > 0 ? (double)availableCount / totalCount * 100 : 0;
                var availabilityColor = availabilityPercent >= 80 ? "#27ae60" : availabilityPercent >= 50 ? "#f39c12" : "#e74c3c";
                var prepTime = (recipe.PrepTime ?? 0) + (recipe.CookTime ?? 0);

                <div class="col-md-6 col-lg-4 mb-3">
                    <div class="favorite-card">
                        <div class="favorite-image" style="background: @GetRecipeGradient(item.Id);">
                            <button class="btn-remove-favorite" @onclick="() => RemoveFromFavorites(item)" title="Удалить из избранного">
                                ✕
                            </button>
                            <div class="favorite-badge">❤️</div>
                        </div>

                        <div class="favorite-info">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="recipe-name">@(recipe.Title ?? "Без названия")</h6>
                                </div>
                                <span class="difficulty-badge @GetDifficultyClass(prepTime)">
                                    @GetDifficultyText(prepTime)
                                </span>
                            </div>

                            <p class="recipe-desc">@(recipe.Description ?? "Описание отсутствует")</p>

                            <div class="recipe-stats">
                                <span class="stat-item">⏱️ @prepTime мин</span>
                                <span class="stat-item">🔥 @(recipe.Calories ?? 0) ккал</span>
                            </div>

                            @if (totalCount > 0)
                            {
                                <div class="ingredients-preview mt-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="availability-bar">
                                            <div class="availability-fill" style="width: @availabilityPercent%; background: @availabilityColor;"></div>
                                        </div>
                                        <span class="availability-text" style="color: @availabilityColor;">
                                            @availableCount/@totalCount инг.
                                        </span>
                                    </div>
                                </div>
                            }

                            <div class="d-flex gap-2 mt-3">
                                <a href="@($"/recipe/{recipe.Id}")"
                                   class="btn-recipe-view flex-grow-1 text-center text-decoration-none">
                                    Открыть
                                </a>
                                <button class="btn-recipe-cook" @onclick="() => RemoveFromFavorites(item)" title="Удалить из избранного">
                                    💔
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="d-flex gap-2 justify-content-center mt-4">
            <button class="btn btn-menu" @onclick="ClearAllFavorites">
                Очистить всё
            </button>
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">⭐</div>
            <h4 style="color: #555; margin-top: 16px;">Нет избранных рецептов</h4>
            <p style="color: #999; margin-bottom: 16px;">
                Добавляйте рецепты в избранное, нажимая на ❤️
            </p>
            <button class="btn btn-add" @onclick="GoToRecipes">
                Найти рецепты
            </button>
        </div>
    }
</div>

<style>
