@page "/profile"
@rendermode InteractiveServer

@inject ProductWebManager.Services.AuthService AuthService
@inject IDbContextFactory<ProductWebManager.Data.ProductManagerContext> DbContextFactory
@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Models
@using System.Globalization

<PageTitle>Профиль</PageTitle>

<div class="max-w-[1440px] mx-auto p-6 lg:p-10 font-sans text-slate-800">

    <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-10 border-b border-slate-100 pb-6">
        <div>
            <h1 class="text-4xl font-black text-slate-900 tracking-tighter">Профиль</h1>
            <p class="text-slate-500 font-medium mt-1">Управление аккаунтом, физическими параметрами и ограничениями в еде</p>
        </div>
    </header>

    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-start">

        <div class="lg:col-span-7 bg-white border border-slate-100 rounded-[2rem] shadow-sm p-6 lg:p-8 space-y-6">
            <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2">
                <i class="fas fa-calculator text-indigo-500 text-sm"></i>
                <span>Физические параметры</span>
            </h2>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Вес (кг)</label>
                    <input type="number" @bind="userWeight" @bind:after="UpdateCaloriesAndSave"
                           class="w-full bg-slate-50 text-xs font-semibold px-4 py-3 rounded-xl border border-slate-100 focus:outline-none focus:border-indigo-500 focus:bg-white transition-all" />
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Рост (см)</label>
                    <input type="number" @bind="userHeight" @bind:after="UpdateCaloriesAndSave"
                           class="w-full bg-slate-50 text-xs font-semibold px-4 py-3 rounded-xl border border-slate-100 focus:outline-none focus:border-indigo-500 focus:bg-white transition-all" />
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Возраст (лет)</label>
                    <input type="number" @bind="userAge" @bind:after="UpdateCaloriesAndSave"
                           class="w-full bg-slate-50 text-xs font-semibold px-4 py-3 rounded-xl border border-slate-100 focus:outline-none focus:border-indigo-500 focus:bg-white transition-all" />
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Пол</label>
                    <select value="@genderString" @onchange="OnGenderChanged"
                            class="w-full bg-slate-50 text-xs font-semibold px-4 py-3 rounded-xl border border-slate-100 focus:outline-none focus:border-indigo-500 focus:bg-white transition-all">
                        <option value="Male">Мужской</option>
                        <option value="Female">Женский</option>
                    </select>
                </div>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Уровень активности</label>
                    <select value="@activityString" @onchange="OnActivityChanged"
                            class="w-full bg-slate-50 text-xs font-semibold px-4 py-3 rounded-xl border border-slate-100 focus:outline-none focus:border-indigo-500 focus:bg-white transition-all">
                        <option value="Low">Низкая (сидячий образ жизни)</option>
                        <option value="Medium">Средняя (тренировки 3-5 раз в неделю)</option>
                        <option value="High">Высокая (тяжелые нагрузки ежедневно)</option>
                    </select>
                </div>
                <div>
                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-1.5">Цель питания</label>
                    <select value="@goalString" @onchange="OnGoalChanged"
                            class="w-full bg-slate-50 text-xs font-semibold px-4 py-3 rounded-xl border border-slate-100 focus:outline-none focus:border-indigo-500 focus:bg-white transition-all">
                        <option value="Maintain">Поддержание веса</option>
                        <option value="LoseWeight">Похудение</option>
                        <option value="GainWeight">Набор массы</option>
                    </select>
                </div>
            </div>

            <div class="mt-8 bg-indigo-50/50 border border-indigo-100/50 rounded-2xl p-6 flex flex-col sm:flex-row items-center justify-between gap-4">
                <div>
                    <h3 class="text-xs font-bold text-indigo-900 uppercase tracking-wide">Ваша суточная норма</h3>
                    <p class="text-slate-500 text-[11px] mt-0.5">Автоматически пересчитано и сохранено на основе формулы Миффлина-Сан Жеора</p>
                </div>
                <div class="text-3xl font-black text-indigo-600 tracking-tight">
                    @targetCalories <span class="text-xs font-bold text-indigo-400 uppercase ml-1">ккал / день</span>
                </div>
            </div>
        </div>

        <div class="lg:col-span-5 bg-white border border-slate-100 rounded-[2rem] shadow-sm p-6 lg:p-8 space-y-6">
            <div>
                <h2 class="text-lg font-bold text-slate-900 flex items-center gap-2">
                    <i class="fas fa-exclamation-triangle text-amber-500 text-sm"></i>
                    <span>Аллергия и исключения</span>
                </h2>
                <p class="text-slate-400 text-[11px] mt-0.5">Блюда с выбранными компонентами будут исключены из генерации плана</p>
            </div>

            <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
                @foreach (var allergen in allergens)
                {
                    <button @onclick="() => ToggleAllergen(allergen)"
                            class="flex items-center justify-between p-3.5 rounded-xl border font-bold text-xs transition-all text-left
                                   @(allergen.Selected
                                       ? "bg-rose-50 border-rose-200 text-rose-700 shadow-sm shadow-rose-100"
                                       : "bg-slate-50/50 border-slate-100 text-slate-600 hover:bg-slate-50 hover:border-slate-200")">
                        <div class="flex items-center gap-3">
                            <span class="text-lg">@GetAllergenIcon(allergen.Name)</span>
                            <span>@allergen.Name</span>
                        </div>
                        @if (allergen.Selected)
                        {
                            <i class="fas fa-check-circle text-rose-500"></i>
                        }
                    </button>
                }
            </div>
        </div>

    </div>
</div>

@code {
    private double userWeight = 70;
    private double userHeight = 175;
    private int userAge = 25;
    private double targetCalories = 2000;

    // Строки для стабильного связывания с HTML-элементами <select>
    private string genderString = "Male";
    private string activityString = "Low";
    private string goalString = "Maintain";

    private List<AllergenViewModel> allergens = new();

    protected override async Task OnInitializedAsync()
    {
        await LoadProfileAndAllergens();
    }

    private async Task LoadProfileAndAllergens()
    {
        await using var context = await DbContextFactory.CreateDbContextAsync();
        var userId = AuthService.CurrentUserId;

        // 1. Загрузка параметров профиля строго по вашей модели
        var profile = await context.UserProfiles.FirstOrDefaultAsync(x => x.UserId == userId);
        if (profile != null)
        {
            userWeight = profile.Weight;
            userHeight = profile.Height;
            userAge = profile.Age;
            targetCalories = profile.TargetCalories;

            // Преобразуем Enums из базы в строки для Select-контролов
            genderString = profile.Gender.ToString();
            activityString = profile.ActivityLevel.ToString();
            goalString = profile.Goal.ToString();
        }
        else
        {
            RecalculateCalories();
        }

        // 2. Загрузка аллергенов
        var allAllergies = await context.Allergies.ToListAsync();
        var userAllergyIds = await context.UserAllergies
            .Where(x => x.UserId == userId)
            .Select(x => x.AllergyId)
            .ToListAsync();

        allergens = allAllergies.Select(x => new AllergenViewModel
            {
                Id = x.Id,
                Name = x.Name,
                Selected = userAllergyIds.Contains(x.Id)
            }).ToList();
    }

    private async Task OnGenderChanged(ChangeEventArgs e)
    {
        genderString = e.Value?.ToString() ?? "Male";
        await UpdateCaloriesAndSave();
    }

    private async Task OnActivityChanged(ChangeEventArgs e)
    {
        activityString = e.Value?.ToString() ?? "Low";
        await UpdateCaloriesAndSave();
    }

    private async Task OnGoalChanged(ChangeEventArgs e)
    {
        goalString = e.Value?.ToString() ?? "Maintain";
        await UpdateCaloriesAndSave();
    }

    private void RecalculateCalories()
    {
        if (userWeight <= 0 || userHeight <= 0 || userAge <= 0)
        {
            targetCalories = 2000;
            return;
        }

        // Коэффициенты на базе ActivityLevel Enum
        double activityMultiplier = activityString switch
        {
            "Low" => 1.2,
            "Medium" => 1.55,
            "High" => 1.725,
            _ => 1.2
        };

        // Расчет BMR (Миффлин-Сан Жеор)
        double bmr = (10 * userWeight) + (6.25 * userHeight) - (5 * userAge);
        bmr = (genderString == "Male") ? (bmr + 5) : (bmr - 161);

        double totalCalories = bmr * activityMultiplier;

        // Коррекция калорий в зависимости от выбранного GoalType
        totalCalories = goalString switch
        {
            "LoseWeight" => totalCalories - 400, // Дефицит для похудения
            "GainWeight" => totalCalories + 400, // Профицит для набора массы
            _ => totalCalories
        };

        targetCalories = Math.Round(totalCalories);
    }

    private async Task UpdateCaloriesAndSave()
    {
        // 1. Выполняем расчет
        RecalculateCalories();

        // 2. Сохраняем все поля, приводя типы к структуре БД
        try
        {
            await using var context = await DbContextFactory.CreateDbContextAsync();
            var userId = AuthService.CurrentUserId;
            var profile = await context.UserProfiles.FirstOrDefaultAsync(x => x.UserId == userId);

            // Конвертируем строки обратно в Enum типы модели
            Enum.TryParse<Gender>(genderString, out var parsedGender);
            Enum.TryParse<ActivityLevel>(activityString, out var parsedActivity);
            Enum.TryParse<GoalType>(goalString, out var parsedGoal);

            if (profile != null)
            {
                profile.Weight = userWeight;
                profile.Height = userHeight;
                profile.Age = userAge;
                profile.Gender = parsedGender;
                profile.ActivityLevel = parsedActivity;
                profile.Goal = parsedGoal;
                profile.TargetCalories = targetCalories;
            }
            else
            {
                var newProfile = new UserProfile
                    {
                        UserId = userId,
                        Weight = userWeight,
                        Height = userHeight,
                        Age = userAge,
                        Gender = parsedGender,
                        ActivityLevel = parsedActivity,
                        Goal = parsedGoal,
                        TargetCalories = targetCalories
                    };
                context.UserProfiles.Add(newProfile);
            }

            await context.SaveChangesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка сохранения в базу данных: {ex.Message}");
        }
    }

    private async Task ToggleAllergen(AllergenViewModel allergen)
    {
        try
        {
            await using var context = await DbContextFactory.CreateDbContextAsync();
            var userId = AuthService.CurrentUserId;

            if (allergen.Selected)
            {
                var userAllergy = await context.UserAllergies
                    .FirstOrDefaultAsync(x => x.UserId == userId && x.AllergyId == allergen.Id);
                if (userAllergy != null) context.UserAllergies.Remove(userAllergy);
                allergen.Selected = false;
            }
            else
            {
                context.UserAllergies.Add(new UserAllergy { UserId = userId, AllergyId = allergen.Id });
                allergen.Selected = true;
            }
            await context.SaveChangesAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка изменения аллергена: {ex.Message}");
        }
    }

    private string GetAllergenIcon(string name) => name switch
    {
        "Лактоза" => "🥛",
        "Глютен" => "🌾",
        "Орехи" => "🥜",
        "Морепродукты" => "🦐",
        "Рыба" => "🐟",
        "Яйца" => "🥚",
        _ => "🍽️"
    };

    public class AllergenViewModel
    {
        public int Id { get; set; }
        public string Name { get; set; } = "";
        public bool Selected { get; set; }
    }
}