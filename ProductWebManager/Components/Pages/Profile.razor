@page "/profile"
@rendermode InteractiveServer

@inject ProductWebManager.Services.AuthService AuthService
@inject ProductWebManager.Data.ProductManagerContext DbContext

@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Models

<PageTitle>Профиль</PageTitle>

<div class="profile-page">

    <div class="profile-container">

        <!-- HEADER -->
        <div class="page-header">

            <div>
                <h1 class="page-title">
                    Профиль
                </h1>

                <div class="page-subtitle">
                    Управление аккаунтом и персональными настройками
                </div>
            </div>

        </div>

        <div class="row g-4">

            <!-- LEFT -->
            <div class="col-lg-4">

                <div class="content-card soft-card">

                    <div class="profile-top">

                        <div class="avatar-circle">
                            @GetFirstLetter()
                        </div>

                        <div>

                            <div class="profile-name">
                                @AuthService.CurrentUserName
                            </div>

                            <div class="profile-role">
                                Пользователь системы
                            </div>

                        </div>

                    </div>

                    <div class="profile-stats">

                        <div class="mini-stat">
                            <div class="mini-stat-value">
                                @allergens.Count(x => x.Selected)
                            </div>

                            <div class="mini-stat-label">
                                Аллергенов
                            </div>
                        </div>

                        <div class="mini-stat">
                            <div class="mini-stat-value">
                                @generatedMenusCount
                            </div>

                            <div class="mini-stat-label">
                                Планов питания
                            </div>
                        </div>

                    </div>

                </div>

                <!-- PROFILE SETTINGS -->
                <div class="content-card soft-card mt-4">

                    <div class="section-header">

                        <div>
                            <h3 class="section-title">
                                Параметры
                            </h3>

                            <div class="section-subtitle">
                                Используются при расчёте меню
                            </div>
                        </div>

                    </div>

                    <div class="form-grid">

                        <div class="form-group">
                            <label>Возраст</label>

                            <input type="number"
                                   class="soft-input"
                                   @bind="profile.Age" />
                        </div>

                        <div class="form-group">
                            <label>Рост (см)</label>

                            <input type="number"
                                   class="soft-input"
                                   @bind="profile.Height" />
                        </div>

                        <div class="form-group">
                            <label>Вес (кг)</label>

                            <input type="number"
                                   class="soft-input"
                                   @bind="profile.Weight" />
                        </div>

                        <div class="form-group">
                            <label>Пол</label>

                            <select class="soft-input"
                                    @bind="profile.Gender">

                                <option value="@Gender.Male">
                                    Мужской
                                </option>

                                <option value="@Gender.Female">
                                    Женский
                                </option>

                            </select>
                        </div>

                        <div class="form-group">
                            <label>Активность</label>

                            <select class="soft-input"
                                    @bind="profile.ActivityLevel">

                                <option value="@ActivityLevel.Low">
                                    Низкая
                                </option>

                                <option value="@ActivityLevel.Medium">
                                    Средняя
                                </option>

                                <option value="@ActivityLevel.High">
                                    Высокая
                                </option>

                            </select>
                        </div>

                        <div class="form-group">
                            <label>Цель</label>

                            <select class="soft-input"
                                    @bind="profile.Goal">

                                <option value="@GoalType.Maintain">
                                    Поддержание веса
                                </option>

                                <option value="@GoalType.LoseWeight">
                                    Похудение
                                </option>

                                <option value="@GoalType.GainWeight">
                                    Набор массы
                                </option>

                            </select>
                        </div>

                    </div>

                    <div class="calories-card">

                        <div>
                            <div class="calories-title">
                                Рекомендуемая калорийность
                            </div>

                            <div class="calories-subtitle">
                                Автоматически рассчитывается
                            </div>
                        </div>

                        <div class="calories-value">
                            @profile.TargetCalories.ToString("0")
                            ккал
                        </div>

                    </div>

                    <button class="save-btn"
                            @onclick="SaveProfile">

                        Сохранить профиль
                    </button>

                </div>

            </div>

            <!-- RIGHT -->
            <div class="col-lg-8">

                <div class="content-card soft-card">

                    <div class="section-header">

                        <div>

                            <h3 class="section-title">
                                Аллергены
                            </h3>

                            <div class="section-subtitle">
                                Эти продукты будут исключаться
                                из рекомендаций и рецептов
                            </div>

                        </div>

                    </div>

                    <div class="allergens-grid">

                        @foreach (var allergen in allergens)
                        {
                            <div class="allergen-card @(allergen.Selected ? "selected" : "")"
                                 @onclick="async () => await ToggleAllergen(allergen)">

                                <div class="allergen-top">

                                    <div class="allergen-icon">
                                        @GetAllergenIcon(allergen.Name)
                                    </div>

                                    @if (allergen.Selected)
                                    {
                                        <div class="allergen-check">
                                            ✓
                                        </div>
                                    }

                                </div>

                                <div class="allergen-name">
                                    @allergen.Name
                                </div>

                                <div class="allergen-status">
                                    @(allergen.Selected
                                        ? "Исключён"
                                        : "Разрешён")
                                </div>

                            </div>
                        }

                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<style>

