</style>

@code {

    private List<AllergenViewModel> allergens = new();

    private UserProfile profile = new();

    private int generatedMenusCount;

    public class AllergenViewModel
    {
        public int Id { get; set; }

        public string Name { get; set; } = "";

        public bool Selected { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        var currentUser = await DbContext.Users

            .Include(x => x.UserAllergies)
                .ThenInclude(x => x.Allergy)

            .Include(x => x.Profile)

            .FirstOrDefaultAsync(x =>
                x.Id == AuthService.CurrentUserId);

        if (currentUser == null)
            return;

        if (currentUser.Profile == null)
        {
            currentUser.Profile = new UserProfile
                {
                    UserId = currentUser.Id,
                    Age = 20,
                    Height = 170,
                    Weight = 70,
                    Gender = Gender.Male,
                    ActivityLevel = ActivityLevel.Medium,
                    Goal = GoalType.Maintain,
                    TargetCalories = 2200
                };

            DbContext.UserProfiles.Add(currentUser.Profile);

            await DbContext.SaveChangesAsync();
        }

        profile = currentUser.Profile;

        CalculateCalories();

        var dbAllergens = await DbContext.Allergies
            .ToListAsync();

        allergens = dbAllergens

            .Select(x => new AllergenViewModel
                {
                    Id = x.Id,

                    Name = x.Name,

                    Selected = currentUser.UserAllergies
                        .Any(a => a.AllergyId == x.Id)
                })

            .ToList();

        generatedMenusCount = await DbContext.MealPlans

            .CountAsync(x =>
                x.UserId == currentUser.Id);
    }

    private async Task SaveProfile()
    {
        CalculateCalories();

        DbContext.UserProfiles.Update(profile);

        await DbContext.SaveChangesAsync();
    }

    private void CalculateCalories()
    {
        double bmr;

        if (profile.Gender == Gender.Male)
        {
            bmr =
                10 * profile.Weight +
                6.25 * profile.Height -
                5 * profile.Age + 5;
        }
        else
        {
            bmr =
                10 * profile.Weight +
                6.25 * profile.Height -
                5 * profile.Age - 161;
        }

        double activity = profile.ActivityLevel switch
        {
            ActivityLevel.Low => 1.2,
            ActivityLevel.Medium => 1.55,
            ActivityLevel.High => 1.8,
            _ => 1.2
        };

        double calories = bmr * activity;

        calories = profile.Goal switch
        {
            GoalType.LoseWeight => calories - 300,
            GoalType.GainWeight => calories + 300,
            _ => calories
        };

        profile.TargetCalories = calories;
    }

    private async Task ToggleAllergen(
        AllergenViewModel allergen)
    {
        var currentUser = await DbContext.Users

            .Include(x => x.UserAllergies)

            .FirstOrDefaultAsync(x =>
                x.Id == AuthService.CurrentUserId);

        if (currentUser == null)
            return;

        var existing = currentUser.UserAllergies

            .FirstOrDefault(x =>
                x.AllergyId == allergen.Id);

        if (existing != null)
        {
            DbContext.UserAllergies.Remove(existing);

            allergen.Selected = false;
        }
        else
        {
            currentUser.UserAllergies.Add(new UserAllergy
                {
                    UserId = currentUser.Id,
                    AllergyId = allergen.Id
                });

            allergen.Selected = true;
        }

        await DbContext.SaveChangesAsync();
    }

    private string GetFirstLetter()
    {
        if (string.IsNullOrWhiteSpace(AuthService.CurrentUserName))
            return "U";

        return AuthService.CurrentUserName
            .Substring(0, 1)
            .ToUpper();
    }

    private string GetAllergenIcon(string name)
    {
        return name switch
        {
            "Лактоза" => "🥛",
            "Глютен" => "🌾",
            "Орехи" => "🥜",
            "Яйца" => "🥚",
            "Мёд" => "🍯",
            "Морепродукты" => "🦐",
            _ => "⚠️"
        };
    }

}