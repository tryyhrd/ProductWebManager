    private int GetMissingIngredientsCount()
    {
        return recipe?.RecipeIngredients
            .Count(i =>
                !fridgeProductIds.Contains(i.ProductId))
            ?? 0;
    }

    private double GetRecipeCalories()
    {
        if (recipe?.RecipeIngredients == null)
            return 0;

        return recipe.RecipeIngredients
            .Sum(GetIngredientCalories);
    }

    private double GetRecipeProteins()
    {
        if (recipe?.RecipeIngredients == null)
            return 0;

        return recipe.RecipeIngredients
            .Sum(GetIngredientProteins);
    }

    private double GetRecipeFats()
    {
        if (recipe?.RecipeIngredients == null)
            return 0;

        return recipe.RecipeIngredients
            .Sum(GetIngredientFats);
    }

    private double GetRecipeCarbs()
    {
        if (recipe?.RecipeIngredients == null)
            return 0;

        return recipe.RecipeIngredients
            .Sum(GetIngredientCarbs);
    }

    private double GetMacroPercent(double value)
    {
        var max = Math.Max(
            GetRecipeProteins(),
            Math.Max(
                GetRecipeFats(),
                GetRecipeCarbs()));

        if (max <= 0)
            return 0;

        return Math.Min(100,
            (value / max) * 100);
    }

    // =========================================
    // UI HELPERS
    // =========================================

    private string CleanStepText(string step)
    {
        var text = step.Trim();

        int index = 0;

        while (index < text.Length &&
               char.IsDigit(text[index]))
        {
            index++;
        }

        while (index < text.Length &&
               (text[index] == '.'
                || text[index] == ')'
                || text[index] == '-'
                || char.IsWhiteSpace(text[index])))
        {
            index++;
        }

        return index >= text.Length
            ? text
            : text.Substring(index).Trim();
    }

