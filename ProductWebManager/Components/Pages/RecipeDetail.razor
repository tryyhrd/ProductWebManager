@page "/recipe/{id:int}"
@rendermode InteractiveServer
@inject NavigationManager Navigation

<PageTitle>@recipe.Name</PageTitle>

<div class="container-fluid p-4">
    <!-- Верхняя панель с возвратом -->
    <div class="d-flex align-items-center mb-4">
        <button class="btn-back" @onclick="GoBack">
            ← Назад
        </button>
        <h2 class="fw-bold m-0 ms-3" style="color: #1a1a2e;">@recipe.Name</h2>
        <div class="ms-auto d-flex gap-2">
            <button class="btn btn-add" @onclick="AddToShoppingList">
                В список покупок
            </button>
            <button class="btn-favorite @(recipe.IsFavorite ? "active" : "")" @onclick="ToggleFavorite">
                @(recipe.IsFavorite ? "❤️" : "🤍") В избранное
            </button>
        </div>
    </div>

    <div class="row">
        <!-- Левая колонка - Изображение и основная информация -->
        <div class="col-lg-8">
            <!-- Изображение -->
            <div class="recipe-hero" style="background: linear-gradient(135deg, #6c5ce7, #a29bfe);">
                <div class="recipe-hero-content">
                    <div class="d-flex gap-2 mb-3">
                        <span class="recipe-badge">⏱️ @recipe.CookingTime мин</span>
                        <span class="recipe-badge">🔥 @recipe.Calories ккал</span>
                        <span class="recipe-badge @GetDifficultyClass(recipe.Difficulty)">📊 @GetDifficultyText(recipe.Difficulty)</span>
                    </div>
                </div>
            </div>

            <!-- Описание -->
            <div class="content-card mt-3">
                <h4 class="section-title">Описание</h4>
                <p class="recipe-description">@recipe.Description</p>
            </div>

            <!-- Ингредиенты -->
            <div class="content-card mt-3">
                <h4 class="section-title">🧂 Ингредиенты</h4>
                
                <div class="ingredients-list">
                    @foreach (var ingredient in recipe.Ingredients)
                    {
                        <div class="ingredient-row @(ingredient.IsAvailable ? "available" : "missing")">
                            <div class="d-flex align-items-center">
                                <span class="ingredient-status">
                                    @if (ingredient.IsAvailable)
                                    {
                                        <span class="text-success">✅</span>
                                    }
                                    else
                                    {
                                        <span class="text-danger">❌</span>
                                    }
                                </span>
                                <span class="ingredient-name">@ingredient.Name</span>
                            </div>
                            <div class="d-flex align-items-center gap-3">
                                <span class="ingredient-amount">@ingredient.Quantity @ingredient.Unit</span>
                                @if (!ingredient.IsAvailable)
                                {
                                    <button class="btn-add-missing" @onclick="() => AddToShoppingListIngredient(ingredient)">
                                        🛒
                                    </button>
                                }
                            </div>
                        </div>
                    }
                </div>

                <!-- Прогресс наличия -->
                <div class="availability-summary mt-3">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="text-muted-custom">Доступность ингредиентов</span>
                        <span class="fw-semibold" style="color: @GetAvailabilityColor();">
                            @GetAvailableCount() из @recipe.Ingredients.Count
                        </span>
                    </div>
                    <div class="progress-bar-bg">
                        <div class="progress-bar-fill" style="width: @GetAvailabilityPercent()%; background: @GetAvailabilityColor();"></div>
                    </div>
                </div>
            </div>

            <!-- Пошаговая инструкция -->
            <div class="content-card mt-3">
                <h4 class="section-title">👨‍🍳 Приготовление</h4>
                
                <div class="steps-list">
                    @for (int i = 0; i < recipe.Instructions.Count; i++)
                    {
                        <div class="step-row">
                            <div class="step-number">@(i + 1)</div>
                            <div class="step-content">
                                <p class="step-text">@recipe.Instructions[i]</p>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Правая колонка - Дополнительная информация -->
        <div class="col-lg-4">
            <!-- Быстрые действия -->
            <div class="side-card">
                <h5 class="side-card-title">Действия</h5>
                <div class="d-grid gap-2">
                    <button class="btn-action-primary" @onclick="CookRecipe">
                        Начать готовить
                    </button>
                </div>
            </div>

            <!-- Пищевая ценность -->
            <div class="side-card mt-3">
                <h5 class="side-card-title">Пищевая ценность</h5>
                <div class="nutrition-grid">
                    <div class="nutrition-item">
                        <div class="nutrition-value" style="color: #6c5ce7;">@recipe.Calories</div>
                        <div class="nutrition-label">Калории</div>
                    </div>
                    <div class="nutrition-item">
                        <div class="nutrition-value" style="color: #27ae60;">@recipe.Proteins г</div>
                        <div class="nutrition-label">Белки</div>
                    </div>
                    <div class="nutrition-item">
                        <div class="nutrition-value" style="color: #f39c12;">@recipe.Fats г</div>
                        <div class="nutrition-label">Жиры</div>
                    </div>
                    <div class="nutrition-item">
                        <div class="nutrition-value" style="color: #e74c3c;">@recipe.Carbs г</div>
                        <div class="nutrition-label">Углеводы</div>
                    </div>
                </div>
            </div>

            <!-- Информация -->
            <div class="side-card mt-3">
                <h5 class="side-card-title">ℹ️ Информация</h5>
                <div class="info-list">
                    <div class="info-row">
                        <span>Время приготовления</span>
                        <span class="fw-semibold">@recipe.CookingTime мин</span>
                    </div>
                    <div class="info-row">
                        <span>Сложность</span>
                        <span class="fw-semibold">@GetDifficultyText(recipe.Difficulty)</span>
                    </div>
                    <div class="info-row">
                        <span>Категория</span>
                        <span class="fw-semibold">@GetCategoryText(recipe.Category)</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

