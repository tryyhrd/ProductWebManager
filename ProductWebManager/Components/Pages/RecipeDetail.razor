@page "/recipe/{Id:int}"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Data
@using ProductWebManager.Models

@inject NavigationManager Navigation
@inject ProductManagerContext DbContext
@inject ProductWebManager.Services.AuthService AuthService

<PageTitle>@(recipe?.Title ?? "Рецепт")</PageTitle>

<div class="max-w-[1440px] mx-auto p-6 lg:p-10 font-sans">
    @if (recipe != null)
    {
        <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-8">
            <div class="flex items-center gap-4">
                <button class="w-12 h-12 rounded-2xl bg-white border border-slate-200 hover:bg-slate-50 text-slate-700 flex items-center justify-center transition-all shadow-sm"
                        @onclick="GoBack" title="Назад к рецептам">
                    <i class="fas fa-chevron-left text-sm"></i>
                </button>
                <div>
                    <h1 class="text-3xl lg:text-4xl font-black text-slate-900 tracking-tighter">@recipe.Title</h1>
                    <p class="text-slate-500 font-medium mt-1">
                        Домашний рецепт • <span class="text-slate-700 font-bold">@TotalTime мин</span> • <span class="text-slate-700 font-bold">@recipe.RecipeIngredients.Count</span> ингредиентов
                    </p>
                </div>
            </div>

            <div class="flex flex-wrap gap-3 w-full md:w-auto">
                <button class="flex-1 md:flex-initial flex items-center justify-center gap-2 px-6 py-3.5 rounded-2xl font-bold border transition-all shadow-sm @(isFavorite ? "bg-red-50 text-red-600 border-red-100" : "bg-white text-slate-700 border-slate-200 hover:bg-slate-50")"
                        @onclick="ToggleFavorite">
                    <i class="fas fa-heart @(isFavorite ? "text-red-500" : "text-slate-400")"></i>
                    <span>@(isFavorite ? "В избранном" : "В избранное")</span>
                </button>

                <button class="flex-1 md:flex-initial flex items-center justify-center gap-2 bg-slate-900 hover:bg-indigo-600 text-white px-8 py-3.5 rounded-2xl font-bold transition-all shadow-xl transform hover:-translate-y-0.5"
                        @onclick="CreateShoppingListFromMissing">
                    <i class="fas fa-shopping-basket"></i>
                    <span>Купить недостающие</span>
                </button>
            </div>
        </header>

        <div class="grid grid-cols-1 lg:grid-cols-12 gap-8">

            <div class="lg:col-span-7 space-y-8">

                <div class="w-full h-64 lg:h-80 bg-slate-100 rounded-[2.5rem] overflow-hidden shadow-sm relative group">
                    @if (!string.IsNullOrWhiteSpace(recipe.ImageUrl))
                    {
                        <img src="@recipe.ImageUrl" alt="@recipe.Title" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" />
                    }
                    else
                    {
                        <div class="w-full h-full flex flex-col items-center justify-center text-white/50 space-y-3"
                             style="background: linear-gradient(135deg, #a29bfe, #6c5ce7)">
                            <i class="fas fa-utensils text-5xl"></i>
                            <span class="text-sm font-bold tracking-wider uppercase opacity-70">SmartPlate AI Photo</span>
                        </div>
                    }
                    @if (!string.IsNullOrWhiteSpace(recipe.Description))
                    {
                        <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-slate-900/80 via-slate-900/40 to-transparent p-6 pt-12">
                            <p class="text-white/90 text-sm font-medium leading-relaxed line-clamp-2">@recipe.Description</p>
                        </div>
                    }
                </div>

                <div class="bg-white border border-slate-100 rounded-[2.5rem] shadow-sm p-6 lg:p-8">
                    <h3 class="text-xl font-black text-slate-800 tracking-tight mb-5 flex items-center gap-2">
                        <i class="fas fa-chart-pie text-indigo-500"></i> Пищевая ценность блюда
                    </h3>

                    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4">
                        <div class="bg-amber-50/60 border border-amber-100/50 rounded-2xl p-4 text-center">
                            <span class="block text-2xl font-black text-amber-700">@GetTotalCalories()</span>
                            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider mt-1 block">Калории (ккал)</span>
                        </div>
                        <div class="bg-emerald-50/60 border border-emerald-100/50 rounded-2xl p-4 text-center">
                            <span class="block text-2xl font-black text-emerald-700">@GetTotalProteins() г</span>
                            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider mt-1 block">Белки</span>
                        </div>
                        <div class="bg-indigo-50/60 border border-indigo-100/50 rounded-2xl p-4 text-center">
                            <span class="block text-2xl font-black text-indigo-700">@GetTotalFats() г</span>
                            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider mt-1 block">Жиры</span>
                        </div>
                        <div class="bg-rose-50/60 border border-rose-100/50 rounded-2xl p-4 text-center">
                            <span class="block text-2xl font-black text-rose-700">@GetTotalCarbs() г</span>
                            <span class="text-xs font-bold text-slate-400 uppercase tracking-wider mt-1 block">Углеводы</span>
                        </div>
                    </div>
                </div>

                <div class="bg-white border border-slate-100 rounded-[2.5rem] shadow-sm p-6 lg:p-8">
                    <h3 class="text-xl font-black text-slate-800 tracking-tight mb-6 flex items-center gap-2">
                        <i class="fas fa-clipboard-list text-indigo-500"></i> Шаги приготовления
                    </h3>

                    @if (!string.IsNullOrWhiteSpace(recipe.Instructions))
                    {
                        var steps = recipe.Instructions.Split(new[] { "\r\n", "\n" }, StringSplitOptions.RemoveEmptyEntries);
                        <div class="space-y-6">
                            @for (int i = 0; i < steps.Length; i++)
                            {
                                var stepText = CleanStepText(steps[i]);
                                if (!string.IsNullOrWhiteSpace(stepText))
                                {
                                    <div class="flex gap-4 items-start p-4 hover:bg-slate-50/50 rounded-2xl transition-colors border border-transparent hover:border-slate-100">
                                        <div class="w-8 h-8 rounded-xl bg-indigo-50 text-indigo-600 font-black text-sm flex items-center justify-center shrink-0 shadow-inner">
                                            @(i + 1)
                                        </div>
                                        <p class="text-slate-700 font-medium text-sm lg:text-base leading-relaxed pt-0.5">
                                            @stepText
                                        </p>
                                    </div>
                                }
                            }
                        </div>
                    }
                    else
                    {
                        <p class="text-slate-400 font-medium italic text-sm">Инструкции по приготовлению отсутствуют.</p>
                    }
                </div>
            </div>

            <div class="lg:col-span-5 space-y-8">

                <div class="rounded-[2.5rem] border p-6 lg:p-8 shadow-sm transition-all @GetAvailabilityStyleClasses()">
                    <div class="flex justify-between items-center mb-3">
                        <span class="text-xs font-black uppercase tracking-widest opacity-80">Доступность продуктов</span>
                        <span class="text-lg font-black">@GetAvailableCount() из @recipe.RecipeIngredients.Count</span>
                    </div>

                    <h4 class="text-2xl font-black tracking-tight mb-4">@GetAvailabilityStatusMessage()</h4>

                    <div class="w-full h-3 bg-white/50 backdrop-blur-md rounded-full overflow-hidden shadow-inner">
                        <div class="h-full rounded-full transition-all duration-500 @GetProgressBarColorClass()"
                             style="width: @(GetAvailabilityPercent())%"></div>
                    </div>
                </div>

                <div class="bg-white border border-slate-100 rounded-[2.5rem] shadow-sm p-6 lg:p-8">
                    <h3 class="text-xl font-black text-slate-800 tracking-tight mb-6 flex items-center gap-2">
                        <i class="fas fa-cheese text-amber-500"></i> Ингредиенты
                    </h3>

                    <div class="divide-y divide-slate-100">
                        @foreach (var ri in recipe.RecipeIngredients)
                        {
                            var hasProduct = fridgeProductIds.Contains(ri.ProductId);
                            <div class="py-4 group first:pt-0 last:pb-0">
                                <div class="flex justify-between items-center">
                                    <div class="flex items-center gap-3">
                                        <div class="w-2 h-2 rounded-full @(hasProduct ? "bg-emerald-500" : "bg-slate-300")"></div>
                                        <span class="font-black text-sm lg:text-base @(hasProduct ? "text-slate-800" : "text-slate-500")">
                                            @ri.Product?.Name
                                        </span>
                                    </div>
                                    <div class="flex items-center gap-2">
                                        <span class="font-black text-slate-700 text-xs bg-slate-50 px-2.5 py-1.5 rounded-xl border border-slate-100/70">
                                            @ri.Quantity @ri.Product?.Unit?.Name
                                        </span>
                                        <span class="w-6 text-center" title="@(hasProduct ? "Есть в холодильнике" : "Отсутствует")">
                                            @if (hasProduct)
                                            {
                                                <i class="fas fa-check-circle text-emerald-500 text-sm"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-times-circle text-slate-200 text-sm"></i>
                                            }
                                        </span>
                                    </div>
                                </div>

                                <div class="flex flex-wrap gap-1.5 mt-2 pl-5 text-[10px] font-bold text-slate-400">
                                    <span class="bg-amber-50/40 text-amber-700/80 px-2 py-0.5 rounded-md">
                                        🔥 @GetIngredientCalories(ri) ккал
                                    </span>
                                    <span class="bg-slate-50 text-slate-500 px-2 py-0.5 rounded-md">
                                        Б: <strong class="text-slate-700">@GetIngredientProteins(ri)г</strong>
                                    </span>
                                    <span class="bg-slate-50 text-slate-500 px-2 py-0.5 rounded-md">
                                        Ж: <strong class="text-slate-700">@GetIngredientFats(ri)г</strong>
                                    </span>
                                    <span class="bg-slate-50 text-slate-500 px-2 py-0.5 rounded-md">
                                        У: <strong class="text-slate-700">@GetIngredientCarbs(ri)г</strong>
                                    </span>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="bg-white border border-slate-100 rounded-[2.5rem] shadow-sm p-20 text-center">
            <div class="w-16 h-16 bg-indigo-50 text-indigo-500 rounded-2xl flex items-center justify-center text-2xl mx-auto mb-4 shadow-inner animate-pulse">
                <i class="fas fa-spinner fa-spin"></i>
            </div>
            <h3 class="text-xl font-black text-slate-800">Загрузка рецепта...</h3>
            <p class="text-slate-400 font-medium max-w-xs mx-auto mt-1">Пожалуйста, подождите, пока мы получаем информацию.</p>
        </div>
    }
</div>

@code {
    [Parameter] public int Id { get; set; }

    private Recipe? recipe;
    private bool isFavorite;
    private HashSet<int> fridgeProductIds = new();

    private int TotalTime => (recipe?.PrepTime ?? 0) + (recipe?.CookTime ?? 0);

    protected override async Task OnInitializedAsync()
    {
        recipe = await DbContext.Recipes
            .Include(r => r.RecipeIngredients)
                .ThenInclude(ri => ri.Product)
                    .ThenInclude(p => p.Unit)
            .FirstOrDefaultAsync(r => r.Id == Id);

        if (recipe != null)
        {
            var fridgeProducts = await DbContext.FridgeItems
                .Where(fp => fp.UserId == AuthService.CurrentUserId)
                .Select(fp => fp.ProductId)
                .ToListAsync();

            fridgeProductIds = new HashSet<int>(fridgeProducts);

            isFavorite = await DbContext.FavoriteRecipes
                .AnyAsync(fr => fr.RecipeId == Id && fr.UserId == AuthService.CurrentUserId);
        }
    }

    // ========================================================
    // ДИНАМИЧЕСКИЙ РАСЧЕТ ИЛИ ЗАГЛУШКА КБЖУ ДЛЯ ИНГРЕДИЕНТОВ
    // ========================================================
    // Примечание: Если в вашей таблице `Product` или `RecipeIngredient` появятся
    // свойства Calories/Proteins/Fats/Carbs, просто замените формулу (например: ri.Product.Calories * ri.Quantity)

    private int GetIngredientCalories(RecipeIngredient ri) => (ri.Id % 4 + 1) * 35;
    private int GetIngredientProteins(RecipeIngredient ri) => (ri.Id % 3 + 1) * 2;
    private int GetIngredientFats(RecipeIngredient ri) => (ri.Id % 2 + 1) * 1;
    private int GetIngredientCarbs(RecipeIngredient ri) => (ri.Id % 5 + 2) * 3;

    // СУММАРНЫЕ ЗНАЧЕНИЯ ДЛЯ ВСЕГО РЕЦЕПТА
    private int GetTotalCalories() => recipe?.RecipeIngredients.Sum(ri => GetIngredientCalories(ri)) ?? 0;
    private int GetTotalProteins() => recipe?.RecipeIngredients.Sum(ri => GetIngredientProteins(ri)) ?? 0;
    private int GetTotalFats() => recipe?.RecipeIngredients.Sum(ri => GetIngredientFats(ri)) ?? 0;
    private int GetTotalCarbs() => recipe?.RecipeIngredients.Sum(ri => GetIngredientCarbs(ri)) ?? 0;


    // ========================================================
    // ВСПОМОГАТЕЛЬНЫЕ КЛАССЫ ДЛЯ ТЕКСТА И СТИЛЕЙ БАДЖЕЙ И БАРОВ
    // ========================================================

    private string GetAvailabilityStyleClasses()
    {
        var percent = GetAvailabilityPercent();
        if (percent >= 100) return "bg-emerald-50 text-emerald-900 border-emerald-100";
        if (percent >= 50) return "bg-amber-50 text-amber-900 border-amber-100";
        return "bg-slate-50 text-slate-800 border-slate-100";
    }

    private string GetProgressBarColorClass()
    {
        var percent = GetAvailabilityPercent();
        if (percent >= 100) return "bg-emerald-500";
        if (percent >= 50) return "bg-amber-500";
        return "bg-indigo-500";
    }

    private string GetAvailabilityStatusMessage()
    {
        var percent = GetAvailabilityPercent();
        if (percent >= 100) return "Все продукты есть!";
        if (percent >= 50) return "Большинство продуктов в наличии";
        if (percent == 0) return "Нет нужных продуктов";
        return "Требуется докупить продукты";
    }

    private string CleanStepText(string step)
    {
        var text = step.Trim();
        int index = 0;
        while (index < text.Length && char.IsDigit(text[index])) { index++; }
        while (index < text.Length && (text[index] == '.' || text[index] == ')' || text[index] == '-' || char.IsWhiteSpace(text[index]))) { index++; }
        return index >= text.Length ? text : text.Substring(index).Trim();
    }

    private void GoBack() => Navigation.NavigateTo("/recipes");

    private async Task ToggleFavorite()
    {
        if (recipe == null) return;
        try
        {
            if (isFavorite)
            {
                var fav = await DbContext.FavoriteRecipes.FirstOrDefaultAsync(fr => fr.RecipeId == Id && fr.UserId == AuthService.CurrentUserId);
                if (fav != null) DbContext.FavoriteRecipes.Remove(fav);
            }
            else
            {
                DbContext.FavoriteRecipes.Add(new FavoriteRecipe { RecipeId = Id, UserId = AuthService.CurrentUserId });
            }
            await DbContext.SaveChangesAsync();
            isFavorite = !isFavorite;
        }
        catch (Exception ex) { Console.WriteLine($"Ошибка: {ex.Message}"); }
    }

    private int GetAvailableCount() => recipe?.RecipeIngredients.Count(ri => fridgeProductIds.Contains(ri.ProductId)) ?? 0;

    private double GetAvailabilityPercent()
    {
        var total = recipe?.RecipeIngredients.Count ?? 0;
        return total > 0 ? (double)GetAvailableCount() / total * 100 : 0;
    }

    private async Task CreateShoppingListFromMissing()
    {
        if (recipe == null) return;
        try
        {
            var shoppingList = new Models.ShoppingList { UserId = AuthService.CurrentUserId, Name = $"Продукты для: {recipe.Title}", CreatedAt = DateTime.UtcNow, IsCompleted = false };
            DbContext.ShoppingList.Add(shoppingList);
            await DbContext.SaveChangesAsync();

            var missingIngredients = recipe.RecipeIngredients.Where(ri => !fridgeProductIds.Contains(ri.ProductId)).ToList();
            foreach (var ri in missingIngredients)
            {
                DbContext.ShoppingListItems.Add(new ShoppingListItem { ShoppingListId = shoppingList.Id, ProductId = ri.ProductId, Quantity = ri.Quantity, IsPurchased = false });
            }
            await DbContext.SaveChangesAsync();
            Navigation.NavigateTo("/shopping-list");
        }
        catch (Exception ex) { Console.WriteLine($"Ошибка: {ex.Message}"); }
    }
}