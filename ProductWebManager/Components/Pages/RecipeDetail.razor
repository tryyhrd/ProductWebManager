@page "/recipe/{Id:int}"
@rendermode InteractiveServer

@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Data
@using ProductWebManager.Models

@inject NavigationManager Navigation
@inject ProductManagerContext DbContext
@inject ProductWebManager.Services.AuthService AuthService

<PageTitle>@recipe?.Title</PageTitle>

<div class="recipe-page">

    @if (recipe != null)
    {
        <div class="recipe-container">

            <div class="recipe-header">

                <div class="header-left">
                    <button class="btn-back" @onclick="GoBack">
                        ← Назад
                    </button>

                    <div>
                        <h1 class="recipe-title">@recipe.Title</h1>

                        <div class="recipe-subtitle">
                            Домашний рецепт • @TotalTime мин • @recipe.RecipeIngredients.Count ингредиентов
                        </div>
                    </div>
                </div>

                <div class="header-actions">
                    <button class="btn-outline" @onclick="ToggleFavorite">
                        @(isFavorite ? "❤️ В избранном" : "🤍 В избранное")
                    </button>

                    <button class="btn-primary" @onclick="CreateShoppingListFromMissing">
                        🛒 Купить недостающие
                    </button>
                </div>

            </div>

            <div class="recipe-hero">
                @if (!string.IsNullOrWhiteSpace(recipe.ImageUrl))
                {
                    <img src="@recipe.ImageUrl" class="recipe-image" alt="@recipe.Title" />
                }
                else
                {
                    <div class="recipe-placeholder">
                        <div class="placeholder-content">
                            <div class="placeholder-icon">🍳</div>
                            <div class="placeholder-title">Изображение рецепта</div>
                            <div class="placeholder-subtitle">Пока здесь заглушка, позже появится фото блюда</div>
                        </div>
                    </div>
                }

                <div class="hero-overlay"></div>

                <div class="hero-content">
                    <div class="hero-badge">⭐ Рецепт дня</div>
                    <h2 class="hero-title">@recipe.Title</h2>
                    <p class="hero-description">
                        @(string.IsNullOrWhiteSpace(recipe.Description) ? "Описание рецепта отсутствует." : recipe.Description)
                    </p>
                </div>
            </div>

            <div class="row g-4 mt-1">

                <div class="col-xl-8">

                    <div class="content-card">
                        <div class="card-top">
                            <div>
                                <h3 class="section-title">🧂 Ингредиенты</h3>
                                <div class="section-subtitle">
                                    Нажмите на ингредиент, чтобы увидеть его БЖУ и калории
                                </div>
                            </div>

                            <div class="availability-box">
                                <div class="availability-value" style="color:@GetAvailabilityColor()">
                                    @GetAvailableCount() / @recipe.RecipeIngredients.Count
                                </div>
                                <div class="availability-label">Есть дома</div>
                            </div>
                        </div>

                        <div class="availability-progress">
                            <div class="availability-progress-fill"
                                 style="width:@GetAvailabilityPercent()%; background:@GetAvailabilityColor()">
                            </div>
                        </div>

                        <div class="ingredients-list">
                            @foreach (var ingredient in recipe.RecipeIngredients)
                            {
                                var isAvailable = fridgeProductIds.Contains(ingredient.ProductId);
                                var isExpanded = expandedIngredientId == ingredient.ProductId;

                                <div class="ingredient-card @(isAvailable ? "available" : "missing")">
                                    <div class="ingredient-main" @onclick="() => ToggleIngredient(ingredient.ProductId)">
                                        <div class="ingredient-left">
                                            <div class="ingredient-status">
                                                @if (isAvailable)
                                                {
                                                    <span>✅</span>
                                                }
                                                else
                                                {
                                                    <span>🛒</span>
                                                }
                                            </div>

                                            <div>
                                                <div class="ingredient-name">@ingredient.Product?.Name</div>
                                                <div class="ingredient-meta">
                                                    @ingredient.Quantity @(ingredient.Product?.Unit?.Name ?? "")
                                                </div>
                                            </div>
                                        </div>

                                        <div class="ingredient-actions">
                                            @if (!isAvailable)
                                            {
                                                <button class="btn-add-mini"
                                                        @onclick:stopPropagation="true"
                                                        @onclick="() => AddSingleIngredientToShoppingList(ingredient)">
                                                    Добавить
                                                </button>
                                            }

                                            <div class="expand-icon">
                                                @(isExpanded ? "−" : "+")
                                            </div>
                                        </div>
                                    </div>

                                    @if (isExpanded)
                                    {
                                        <div class="ingredient-details">
                                            <div class="nutrition-mini-grid">
                                                <div class="nutrition-mini-card">
                                                    <div class="nutrition-mini-label">Калории</div>
                                                    <div class="nutrition-mini-value">@GetIngredientCalories(ingredient).ToString("0.#")</div>
                                                </div>

                                                <div class="nutrition-mini-card">
                                                    <div class="nutrition-mini-label">Белки</div>
                                                    <div class="nutrition-mini-value">@GetIngredientProteins(ingredient).ToString("0.#") г</div>
                                                </div>

                                                <div class="nutrition-mini-card">
                                                    <div class="nutrition-mini-label">Жиры</div>
                                                    <div class="nutrition-mini-value">@GetIngredientFats(ingredient).ToString("0.#") г</div>
                                                </div>

                                                <div class="nutrition-mini-card">
                                                    <div class="nutrition-mini-label">Углеводы</div>
                                                    <div class="nutrition-mini-value">@GetIngredientCarbs(ingredient).ToString("0.#") г</div>
                                                </div>
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    </div>

                    @if (!string.IsNullOrWhiteSpace(recipe.Instructions))
                    {
                        <div class="content-card mt-4">
                            <h3 class="section-title mb-4">👨‍🍳 Приготовление</h3>

                            <div class="steps-list">
                                @{
                                    var steps = recipe.Instructions
                                    .Split('\n', StringSplitOptions.RemoveEmptyEntries);

                                    for (int i = 0; i < steps.Length; i++)
                                    {
                                        var cleanStep = CleanStepText(steps[i]);

                                        <div class="step-card">
                                            <div class="step-number">@(i + 1)</div>
                                            <div class="step-text">@cleanStep</div>
                                        </div>
                                    }
                                }
                            </div>
                        </div>
                    }

                </div>

                <div class="col-xl-4">

                    <div class="side-card nutrition-card">
                        <div class="nutrition-header">
                            <div>
                                <div class="nutrition-title">📊 Пищевая ценность</div>
                                <div class="nutrition-subtitle">На весь рецепт</div>
                            </div>

                            <div class="calories-circle">
                                <div class="calories-value">@GetRecipeCalories().ToString("0.#")</div>
                                <div class="calories-label">ккал</div>
                            </div>
                        </div>

                        <div class="nutrition-bars">
                            <div class="nutrition-row">
                                <div class="nutrition-row-top">
                                    <span>Белки</span>
                                    <strong>@GetRecipeProteins().ToString("0.#") г</strong>
                                </div>
                                <div class="nutrition-bar">
                                    <div class="nutrition-fill protein-fill"
                                         style="width:@GetMacroPercent(GetRecipeProteins())%"></div>
                                </div>
                            </div>

                            <div class="nutrition-row">
                                <div class="nutrition-row-top">
                                    <span>Жиры</span>
                                    <strong>@GetRecipeFats().ToString("0.#") г</strong>
                                </div>
                                <div class="nutrition-bar">
                                    <div class="nutrition-fill fat-fill"
                                         style="width:@GetMacroPercent(GetRecipeFats())%"></div>
                                </div>
                            </div>

                            <div class="nutrition-row">
                                <div class="nutrition-row-top">
                                    <span>Углеводы</span>
                                    <strong>@GetRecipeCarbs().ToString("0.#") г</strong>
                                </div>
                                <div class="nutrition-bar">
                                    <div class="nutrition-fill carbs-fill"
                                         style="width:@GetMacroPercent(GetRecipeCarbs())%"></div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="side-card mt-4">
                        <h3 class="side-title">ℹ️ Информация</h3>

                        <div class="info-list">
                            <div class="info-item">
                                <span>Подготовка</span>
                                <strong>@(recipe.PrepTime ?? 0) мин</strong>
                            </div>

                            <div class="info-item">
                                <span>Готовка</span>
                                <strong>@(recipe.CookTime ?? 0) мин</strong>
                            </div>

                            <div class="info-item">
                                <span>Общее время</span>
                                <strong>@TotalTime мин</strong>
                            </div>

                            <div class="info-item">
                                <span>Недостающих</span>
                                <strong>@GetMissingIngredientsCount()</strong>
                            </div>
                        </div>
                    </div>

                </div>

            </div>

        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">🍳</div>
            <h3>Рецепт не найден</h3>
            <button class="btn-primary mt-3" @onclick="GoBack">
                ← Назад
            </button>
        </div>
    }

</div>

