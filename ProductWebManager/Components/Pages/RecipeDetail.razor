    private int GetAvailableCount()
    {
        return recipe?.RecipeIngredients
            .Count(ri =>
                fridgeProductIds.Contains(ri.ProductId))
            ?? 0;
    }

    private double GetAvailabilityPercent()
    {
        var total = recipe?.RecipeIngredients.Count ?? 0;

        return total > 0
            ? (double)GetAvailableCount() / total * 100
            : 0;
    }

    private string GetAvailabilityColor()
    {
        var percent = GetAvailabilityPercent();

        if (percent >= 80)
            return "#22c55e";

        if (percent >= 50)
            return "#f59e0b";

        return "#ef4444";
    }
