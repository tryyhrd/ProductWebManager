        display: flex;
        flex-direction: column;
        gap: 8px;
    }

    .info-row {
        display: flex;
        justify-content: space-between;
        color: #666;
        font-size: 13px;
    }

    .empty-state {
        text-align: center;
        padding: 80px 20px;
    }
</style>

@code {
    [Parameter]
    public int Id { get; set; }

    private Recipe? recipe;
    private HashSet<int> fridgeProductIds = new();
    private bool isFavorite;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecipe();
    }

    private async Task LoadRecipe()
    {
        try
        {
            recipe = await DbContext.Recipes
                .Include(r => r.RecipeIngredients)
                    .ThenInclude(ri => ri.Product)
                        .ThenInclude(p => p.Unit)
                .FirstOrDefaultAsync(r => r.Id == Id);

            if (recipe != null)
            {
                fridgeProductIds = (await DbContext.FridgeItems
                    .Where(f => f.UserId == 1 && f.Quanity > 0)
                    .Select(f => f.ProductId)
                    .ToListAsync())
                    .ToHashSet();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки рецепта: {ex.Message}");
        }
    }

    private void GoBack() => Navigation.NavigateTo("/recipes");

    private void ToggleFavorite()
    {
        isFavorite = !isFavorite;
        StateHasChanged();
    }

    private void AddToShoppingList()
    {
        Navigation.NavigateTo("/shopping-list");
    }

    private void AddToShoppingListIngredient(RecipeIngredient ingredient)
    {
        Navigation.NavigateTo("/shopping-list");
    }

    private int GetAvailableCount() =>
        recipe?.RecipeIngredients?.Count(ri => fridgeProductIds.Contains(ri.ProductId)) ?? 0;

    private double GetAvailabilityPercent()
    {
        var total = recipe?.RecipeIngredients?.Count ?? 0;
        return total > 0 ? (double)GetAvailableCount() / total * 100 : 0;
    }

    private string GetAvailabilityColor()
    {
        var percent = GetAvailabilityPercent();
        if (percent >= 80) return "#27ae60";
        if (percent >= 50) return "#f39c12";
        return "#e74c3c";
    }
}