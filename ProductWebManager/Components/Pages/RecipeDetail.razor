@page "/recipe/{id:int}"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ProductWebManager.Data.ProductManagerContext DbContext
@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Models

<PageTitle>@recipe?.Title</PageTitle>

<div class="container-fluid p-4">
    @if (recipe != null)
    {
        <!-- Верхняя панель -->
        <div class="d-flex align-items-center mb-4">
            <button class="btn-back" @onclick="GoBack">← Назад</button>
            <h2 class="fw-bold m-0 ms-3" style="color: #1a1a2e;">@recipe.Title</h2>
            <div class="ms-auto d-flex gap-2">
                <button class="btn btn-add" @onclick="AddToShoppingList">
                    🛒 В список покупок
                </button>
                <button class="btn-favorite @(isFavorite ? "active" : "")" @onclick="ToggleFavorite">
                    @(isFavorite ? "❤️" : "🤍") В избранное
                </button>
            </div>
        </div>

        <div class="row">
            <div class="col-lg-8">
                <!-- Изображение -->
                <div class="recipe-hero" style="background: linear-gradient(135deg, #6c5ce7, #a29bfe);">
                    <div class="recipe-hero-content">
                        <div class="d-flex gap-2 mb-3">
                            <span class="recipe-badge">⏱️ @((recipe.PrepTime ?? 0) + (recipe.CookTime ?? 0)) мин</span>
                            <span class="recipe-badge">🔥 @(recipe.Calories ?? 0) ккал</span>
                        </div>
                    </div>
                </div>

                <!-- Описание -->
                <div class="content-card mt-3">
                    <h4 class="section-title">📝 Описание</h4>
                    <p class="recipe-description">@(recipe.Description ?? "Описание отсутствует")</p>
                </div>

                <!-- Ингредиенты -->
                <div class="content-card mt-3">
                    <h4 class="section-title">🧂 Ингредиенты</h4>

                    <div class="ingredients-list">
                        @foreach (var ingredient in recipe.RecipeIngredients)
                        {
                            var isAvailable = fridgeProductIds.Contains(ingredient.ProductId);
                            <div class="ingredient-row @(isAvailable ? "available" : "missing")">
                                <div class="d-flex align-items-center">
                                    <span class="ingredient-status">
                                        @if (isAvailable)
                                        {
                                            <span class="text-success">✅</span>
                                        }
                                        else
                                        {
                                            <span class="text-danger">❌</span>
                                        }
                                    </span>
                                    <span class="ingredient-name">@ingredient.Product?.Name</span>
                                </div>
                                <div class="d-flex align-items-center gap-3">
                                    <span class="ingredient-amount">@ingredient.Quantity @(ingredient.Product?.Unit?.Name ?? "")</span>
                                    @if (!isAvailable)
                                    {
                                        <button class="btn-add-missing" @onclick="() => AddToShoppingListIngredient(ingredient)">
                                            🛒
                                        </button>
                                    }
                                </div>
                            </div>
                        }
                    </div>

                    <div class="availability-summary mt-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span class="text-muted-custom">Доступность ингредиентов</span>
                            <span class="fw-semibold" style="color: @GetAvailabilityColor();">
                                @GetAvailableCount() из @recipe.RecipeIngredients.Count
                            </span>
                        </div>
                        <div class="progress-bar-bg">
                            <div class="progress-bar-fill" style="width: @GetAvailabilityPercent()%; background: @GetAvailabilityColor();"></div>
                        </div>
                    </div>
                </div>

                <!-- Инструкция -->
                @if (!string.IsNullOrEmpty(recipe.Instructions))
                {
                    <div class="content-card mt-3">
                        <h4 class="section-title">👨‍🍳 Приготовление</h4>
                        <div class="steps-list">
                            @{
                                var steps = recipe.Instructions.Split('\n', StringSplitOptions.RemoveEmptyEntries);
                                for (int i = 0; i < steps.Length; i++)
                                {
                                    <div class="step-row">
                                        <div class="step-number">@(i + 1)</div>
                                        <div class="step-content">
                                            <p class="step-text">@steps[i]</p>
                                        </div>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                }
            </div>

            <div class="col-lg-4">
                <div class="side-card">
                    <h5 class="side-card-title">⚡ Действия</h5>
                    <div class="d-grid gap-2">
                        <button class="btn-action-primary" @onclick="AddToShoppingList">
                            🛒 В список покупок
                        </button>
                    </div>
                </div>

                <div class="side-card mt-3">
                    <h5 class="side-card-title">📊 Пищевая ценность</h5>
                    <div class="nutrition-grid">
                        <div class="nutrition-item">
                            <div class="nutrition-value" style="color: #6c5ce7;">@(recipe.Calories ?? 0)</div>
                            <div class="nutrition-label">Калории</div>
                        </div>
                        <div class="nutrition-item">
                            <div class="nutrition-value" style="color: #27ae60;">-</div>
                            <div class="nutrition-label">Белки</div>
                        </div>
                        <div class="nutrition-item">
                            <div class="nutrition-value" style="color: #f39c12;">-</div>
                            <div class="nutrition-label">Жиры</div>
                        </div>
                        <div class="nutrition-item">
                            <div class="nutrition-value" style="color: #e74c3c;">-</div>
                            <div class="nutrition-label">Углеводы</div>
                        </div>
                    </div>
                </div>

                <div class="side-card mt-3">
                    <h5 class="side-card-title">ℹ️ Информация</h5>
                    <div class="info-list">
                        <div class="info-row">
                            <span>⏱️ Время</span>
                            <span class="fw-semibold">@((recipe.PrepTime ?? 0) + (recipe.CookTime ?? 0)) мин</span>
                        </div>
                        <div class="info-row">
                            <span>🔥 Калории</span>
                            <span class="fw-semibold">@(recipe.Calories ?? 0) ккал</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="empty-state">
            <h4 style="color: #555;">Рецепт не найден</h4>
            <button class="btn btn-add mt-3" @onclick="GoBack">← Назад</button>
        </div>
    }
</div>

