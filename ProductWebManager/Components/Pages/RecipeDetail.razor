        border: 1px solid #e0e0e4;
        border-radius: 10px;
        background: white;
        color: #666;
        font-weight: 500;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-favorite:hover {
            background: #fff5f5;
            border-color: #ff6b6b;
        }

        .btn-favorite.active {
            background: #fff5f5;
            border-color: #e74c3c;
            color: #e74c3c;
        }

    .recipe-hero {
        border-radius: 16px;
        padding: 40px;
        min-height: 200px;
        display: flex;
        align-items: flex-end;
        box-shadow: 0 4px 20px rgba(108, 92, 231, 0.2);
    }

    .recipe-badge {
        background: rgba(255,255,255,0.2);
        color: white;
        padding: 6px 14px;
        border-radius: 20px;
        font-size: 12px;
        font-weight: 500;
