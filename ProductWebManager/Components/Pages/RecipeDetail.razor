@code
{
    [Parameter]
    public int Id { get; set; }

    private Recipe? recipe;

    private HashSet<int> fridgeProductIds = new();

    private bool isFavorite;

    private int? expandedIngredientId;

    private int TotalTime =>
        (recipe?.PrepTime ?? 0) + (recipe?.CookTime ?? 0);

    private double TotalProteins =>
        recipe?.RecipeIngredients?.Sum(GetIngredientProteins) ?? 0;

    private double TotalFats =>
        recipe?.RecipeIngredients?.Sum(GetIngredientFats) ?? 0;

    private double TotalCarbs =>
        recipe?.RecipeIngredients?.Sum(GetIngredientCarbs) ?? 0;

    protected override async Task OnInitializedAsync()
    {
        await LoadRecipe();
    }

    private async Task LoadRecipe()
    {
        recipe = await DbContext.Recipes
            .Include(r => r.RecipeIngredients)
                .ThenInclude(ri => ri.Product)
                    .ThenInclude(p => p.Unit)
            .Include(r => r.RecipeIngredients)
                .ThenInclude(ri => ri.Product)
                    .ThenInclude(p => p.Category)
            .FirstOrDefaultAsync(r => r.Id == Id);

        if (recipe != null)
        {
            fridgeProductIds = (await DbContext.FridgeItems
                .Where(f =>
                    f.UserId == AuthService.CurrentUserId &&
                    f.Quantity > 0)
                .Select(f => f.ProductId)
                .ToListAsync())
                .ToHashSet();
        }
    }

    private void ToggleIngredient(int productId)
    {
        expandedIngredientId = expandedIngredientId == productId
            ? null
            : productId;
    }

    private async Task CreateShoppingListFromMissing()
    {
        if (recipe == null)
            return;

        var missingIngredients = recipe.RecipeIngredients
            .Where(i => !fridgeProductIds.Contains(i.ProductId))
            .ToList();

        if (!missingIngredients.Any())
        {
            Navigation.NavigateTo("/shopping-list");
            return;
        }

        var shoppingList = new Models.ShoppingList
            {
                UserId = AuthService.CurrentUserId,
                Name = $"Для рецепта: {recipe.Title}",
                CreatedAt = DateTime.UtcNow,
                IsCompleted = false
            };

        DbContext.ShoppingList.Add(shoppingList);
        await DbContext.SaveChangesAsync();

        var items = missingIngredients.Select(i => new ShoppingListItem
            {
                ShoppingListId = shoppingList.Id,
                ProductId = i.ProductId,
                Quantity = i.Quantity
            });

        DbContext.ShoppingListItems.AddRange(items);
        await DbContext.SaveChangesAsync();

        Navigation.NavigateTo("/shopping-list");
    }

    private async Task AddSingleIngredientToShoppingList(RecipeIngredient ingredient)
    {
        var shoppingList = await DbContext.ShoppingList
            .FirstOrDefaultAsync(s =>
                s.UserId == AuthService.CurrentUserId &&
                !s.IsCompleted);

        if (shoppingList == null)
        {
            shoppingList = new Models.ShoppingList
                {
                    UserId = AuthService.CurrentUserId,
                    Name = "Список покупок",
                    CreatedAt = DateTime.UtcNow,
                    IsCompleted = false
                };

            DbContext.ShoppingList.Add(shoppingList);
            await DbContext.SaveChangesAsync();
        }

        var existingItem = await DbContext.ShoppingListItems
            .FirstOrDefaultAsync(x =>
                x.ShoppingListId == shoppingList.Id &&
                x.ProductId == ingredient.ProductId);

        if (existingItem != null)
        {
            existingItem.Quantity += ingredient.Quantity;
        }
        else
        {
            DbContext.ShoppingListItems.Add(new ShoppingListItem
                {
                    ShoppingListId = shoppingList.Id,
                    ProductId = ingredient.ProductId,
                    Quantity = ingredient.Quantity
                });
        }

        await DbContext.SaveChangesAsync();
    }

    // =========================================
    // НОВЫЙ БЛОК РАСЧЁТА КБЖУ
    // =========================================

    private bool IsPieceUnit(Product? product)
    {
        if (product?.Unit == null)
            return false;

        var unit = product.Unit.Name
            .Trim()
            .ToLower();

        return unit == "шт"
            || unit == "шт."
            || unit == "piece"
            || unit == "pieces";
    }

    private double CalculateNutrition(
        RecipeIngredient ingredient,
        Func<Product, double> selector)
    {
        if (ingredient.Product == null)
            return 0;

        var product = ingredient.Product;

        var value = selector(product);

        if (value <= 0)
            return 0;

        // Для штучных продуктов:
        // 75 ккал × 4 яйца = 300
        if (IsPieceUnit(product))
        {
            return value * ingredient.Quantity;
        }

        // Для граммов/мл:
        // 120 ккал на 100г × 200г / 100
        return (value * ingredient.Quantity) / 100.0;
    }

