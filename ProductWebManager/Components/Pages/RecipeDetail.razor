    }

    .step-number {
        width: 32px;
        height: 32px;
        min-width: 32px;
        border: 2px solid #6c5ce7;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #6c5ce7;
