@page "/menu"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ProductWebManager.Data.ProductManagerContext DbContext
@inject ProductWebManager.Services.AuthService AuthService
@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Models

<PageTitle>Меню на неделю</PageTitle>

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold m-0" style="color: #1a1a2e;">План питания</h2>
            <small style="color: #888;">@GetWeekRange()</small>
        </div>
        <div class="d-flex gap-2">
            @if (isGenerating)
            {
                <button class="btn btn-add" disabled>
                    <span class="spinner-border spinner-border-sm me-2"></span>Генерация...
                </button>
            }
            else
            {
                <button class="btn btn-danger" @onclick="ClearWeek">
                    Очистить меню
                </button>
                <button class="btn btn-add" @onclick="GenerateMenu" disabled="@(!fridgeItems.Any())">
                    Сгенерировать меню через ИИ
                </button>
            }
        </div>
    </div>

    @if (!string.IsNullOrEmpty(generationStatus))
    {
        <div class="alert @(generationStatus.StartsWith("✅") ? "alert-success" : generationStatus.StartsWith("❌") ? "alert-danger" : "alert-info") mb-3" style="font-size: 13px; padding: 10px 16px;">
            @generationStatus
        </div>
    }

    <div class="row">
        <div class="col-lg-3 mb-4">
            <div class="side-card">
                <h5 class="side-card-title">Настройки</h5>
                <div class="mb-4">
                    <label class="form-label">Дней: <strong>@daysToGenerate</strong></label>
                    <input type="range" class="form-range" min="1" max="7" step="1"
                           @bind="daysToGenerate" @bind:event="oninput"
                           style="accent-color: #6c5ce7;" />
                </div>
                <div class="mb-4">
                    <label class="form-label">Калории: <strong>@targetCalories ккал</strong></label>
                    <input type="range" class="form-range" min="1200" max="3500" step="100"
                           @bind="targetCalories" @bind:event="oninput"
                           style="accent-color: #6c5ce7;" />
                </div>
            </div>

            <div class="side-card mt-3">
                <h5 class="side-card-title">Холодильник (@fridgeItems.Count)</h5>
                <div class="fridge-products-list">
                    @if (fridgeItems.Any())
                    {
                        @foreach (var item in fridgeItems)
                        {
                            <div class="fridge-product-item">
                                <span class="product-name-small">@item.Product?.Name</span>
                                <span class="product-qty">@item.Quanity @item.Product?.Unit?.Name</span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="text-center py-3">
                            <p class="text-muted-custom mt-2">Пусто</p>
                            <a href="/fridge" class="btn btn-sm btn-add">Добавить</a>
                        </div>
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-9">
            @if (weeklyPlan.Any())
            {
                @foreach (var day in weeklyPlan)
                {
                    <div class="day-card mb-3">
                        <div class="day-header" @onclick="() => ToggleDay(day)">
                            <div class="d-flex align-items-center gap-2">
                                <span class="collapse-icon">@(day.IsExpanded ? "▼" : "▶")</span>
                                <h5 class="day-title">@day.DayName</h5>
                                <span class="day-date">@day.Date.ToString("dd MMMM, ddd")</span>
                            </div>
                            <span class="day-calories">
                                🔥 @day.Meals.Sum(m => m.Recipe?.Calories ?? 0) ккал
                            </span>
                        </div>

                        @if (day.IsExpanded)
                        {
                            <div class="meals-grid">
                                @foreach (var meal in day.Meals)
                                {
                                    <div class="meal-slot @(meal.Recipe != null ? "filled" : "")">
                                        <div class="meal-type">
                                            @GetMealTypeIcon(meal.Type) @GetMealTypeName(meal.Type)
                                        </div>

                                        @if (meal.Recipe != null)
                                        {
                                            <div class="meal-recipe">
                                                <div class="recipe-name-small">@meal.Recipe.Title</div>
                                                <div class="recipe-stats-small">
                                                    ⏱️ @((meal.Recipe.PrepTime ?? 0) + (meal.Recipe.CookTime ?? 0)) мин
                                                    • 🔥 @(meal.Recipe.Calories ?? 0) ккал
                                                </div>
                                                <div class="d-flex gap-2 mt-2">
                                                    <button class="btn-recipe-view btn-sm"
                                                            @onclick="() => ViewRecipe(meal.Recipe!)">
                                                        Открыть
                                                    </button>
                                                    <button class="btn-recipe-delete btn-sm"
                                                            @onclick="() => RemoveMeal(day, meal)">
                                                        Удалить
                                                    </button>
                                                </div>
                                            </div>
                                        }
                                        else
                                        {
                                            <div class="meal-empty">
                                                <span class="empty-meal-icon">🍽️</span>
                                                <p>Пусто</p>
                                                <a href="/recipes" class="btn-add-meal">＋</a>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </div>
                }
            }
            else
            {
                <div class="empty-state">
                    <h4 style="color: #555; margin-top: 16px;">Меню не составлено</h4>
                    <p style="color: #999; margin-bottom: 16px;">
                        @if (!fridgeItems.Any())
                        {
                            <span>Добавьте продукты в холодильник</span>
                        }
                        else
                        {
                            <span>Нажмите кнопку для генерации меню</span>
                        }
                    </p>
                    <button class="btn btn-add" @onclick="GenerateMenu" disabled="@(!fridgeItems.Any())">
                        Сгенерировать меню
                    </button>
                </div>
            }
        </div>
    </div>
</div>

<style>
