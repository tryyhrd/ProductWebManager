@code {
    private int daysToGenerate = 3;
    private int targetCalories = 2000;
    private List<FridgeItem> fridgeItems = new();
    private List<DayPlan> weeklyPlan = new();
    private bool isGenerating = false;
    private string generationStatus = "";

    public class DayPlan
    {
        public string DayName { get; set; } = "";
        public DateTime Date { get; set; }
        public bool IsExpanded { get; set; }
        public List<MealSlot> Meals { get; set; } = new();
    }

    public class MealSlot
    {
        public string Type { get; set; } = "";
        public Recipe? Recipe { get; set; }
    }

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            fridgeItems = await DbContext.FridgeItems
                .Include(f => f.Product).ThenInclude(p => p.Unit)
                .Include(f => f.Product).ThenInclude(p => p.Category)
                .Where(f => f.UserId == 1 && f.Quanity > 0)
                .ToListAsync();

            var existingMenu = await DbContext.Menus
                .Include(m => m.Items).ThenInclude(mi => mi.Recipe)
                .FirstOrDefaultAsync(m => m.UserId == 1);

            if (existingMenu?.Items?.Any() == true)
                await LoadGeneratedMenu(existingMenu.Id);
            else
                GenerateEmptyWeek();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
            GenerateEmptyWeek();
        }
    }

    private async Task LoadGeneratedMenu(int menuId)
    {
        var menu = await DbContext.Menus
            .Include(m => m.Items).ThenInclude(mi => mi.Recipe)
            .FirstOrDefaultAsync(m => m.Id == menuId);

        if (menu?.Items?.Any() == true)
        {
            var dates = menu.Items.Select(mi => mi.Date.Date).Distinct().OrderBy(d => d);
            daysToGenerate = dates.Count();
            var today = DateTime.Now.Date;

            weeklyPlan.Clear();
            var dayNames = new[] { "Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Вс" };
            var russianTypes = new[] { "Завтрак", "Обед", "Ужин" };
            var englishTypes = new[] { "breakfast", "lunch", "dinner" };

            foreach (var date in dates)
            {
                var day = new DayPlan
                    {
                        DayName = dayNames[(int)date.DayOfWeek == 0 ? 6 : (int)date.DayOfWeek - 1],
                        Date = date,
                        IsExpanded = date == today,
                        Meals = new List<MealSlot>()
                    };

                for (int i = 0; i < russianTypes.Length; i++)
                {
                    var menuItem = menu.Items.FirstOrDefault(mi =>
                        mi.Date.Date == date.Date &&
                        (mi.MealType == russianTypes[i] || mi.MealType == englishTypes[i]));
                    day.Meals.Add(new MealSlot { Type = englishTypes[i], Recipe = menuItem?.Recipe });
                }
                weeklyPlan.Add(day);
            }
            StateHasChanged();
        }
    }

    private void GenerateEmptyWeek()
    {
        var today = DateTime.Now;
        var dayNames = new[] { "Пн", "Вт", "Ср", "Чт", "Пт", "Сб", "Вс" };
        var mealTypes = new[] { "breakfast", "lunch", "dinner" };
        weeklyPlan.Clear();
        for (int i = 0; i < daysToGenerate; i++)
        {
            var date = today.AddDays(i);
            weeklyPlan.Add(new DayPlan
                {
                    DayName = dayNames[(int)date.DayOfWeek == 0 ? 6 : (int)date.DayOfWeek - 1],
                    Date = date,
                    IsExpanded = i == 0,
                    Meals = mealTypes.Select(type => new MealSlot { Type = type }).ToList()
                });
        }
        StateHasChanged();
    }

    private void ToggleDay(DayPlan day) { day.IsExpanded = !day.IsExpanded; StateHasChanged(); }

    private async Task GenerateMenu()
    {
        if (!fridgeItems.Any()) return;
        isGenerating = true;
        generationStatus = "Генерация меню через ИИ... Это может занять до минуты.";
        StateHasChanged();

        try
        {
            var generatedMenu = await GigaChatHelper.GenerateAndParseMenuAsync(fridgeItems, daysToGenerate);

            if (generatedMenu == null || !generatedMenu.Items.Any())
            {
                generationStatus = "Не удалось сгенерировать меню.";
                isGenerating = false;
                StateHasChanged();
                return;
            }

            var oldMenu = await DbContext.Menus.Include(m => m.Items).FirstOrDefaultAsync(m => m.UserId == 1);
            if (oldMenu != null) { DbContext.MenuItems.RemoveRange(oldMenu.Items); DbContext.Menus.Remove(oldMenu); await DbContext.SaveChangesAsync(); }

            var newMenu = new Models.Menu
                {
                    UserId = 1,
                    Name = generatedMenu.MenuName,
                    CreatedAt = DateTime.UtcNow,
                    Items = new List<MenuItem>()
                };

            var today = DateTime.Now;
            var ingredientCache = new Dictionary<string, Product>();

            foreach (var itemDto in generatedMenu.Items)
            {
                var recipe = new Recipe
                    {
                        Title = itemDto.Recipe.Title,
                        Description = itemDto.Recipe.Description,
                        Instructions = string.Join("\n", itemDto.Recipe.Instructions),
                        Calories = itemDto.Recipe.Calories,
                        PrepTime = itemDto.Recipe.PrepTime,
                        CookTime = itemDto.Recipe.CookTime,
                        RecipeIngredients = new List<RecipeIngredient>()
                    };

                foreach (var ingDto in itemDto.Recipe.Ingredients)
                {
                    var ingKey = ingDto.Name.Trim().ToLower();
                    if (!ingredientCache.ContainsKey(ingKey))
                    {
                        var product = await DbContext.Products.Include(p => p.Unit).Include(p => p.Category).FirstOrDefaultAsync(p => p.Name == ingDto.Name.Trim());
                        if (product == null)
                        {
                            var category = await DbContext.Categories.FirstOrDefaultAsync(c => c.Name == ingDto.Category);
                            if (category == null && !string.IsNullOrEmpty(ingDto.Category)) { category = new Category { Name = ingDto.Category }; DbContext.Categories.Add(category); }
                            var unit = await DbContext.Units.FirstOrDefaultAsync(u => u.Name == ingDto.Unit);
                            if (unit == null && !string.IsNullOrEmpty(ingDto.Unit)) { unit = new Unit { Name = ingDto.Unit }; DbContext.Units.Add(unit); }
                            product = new Product { Name = ingDto.Name.Trim(), Unit = unit, Category = category };
                            DbContext.Products.Add(product);
                        }
                        ingredientCache[ingKey] = product;
                    }
                    recipe.RecipeIngredients.Add(new RecipeIngredient { Product = ingredientCache[ingKey], Quantity = (double)ingDto.Quantity });
                }

                newMenu.Items.Add(new MenuItem
                    {
                        Date = today.AddDays(itemDto.DayNumber - 1),
                        MealType = itemDto.MealType switch { "Завтрак" => "Завтрак", "Обед" => "Обед", "Ужин" => "Ужин", _ => itemDto.MealType },
                        Recipe = recipe
                    });
            }

            DbContext.Menus.Add(newMenu);
            await DbContext.SaveChangesAsync();
            await LoadGeneratedMenu(newMenu.Id);

            generationStatus = "✅ Меню сгенерировано!";
            isGenerating = false;
            StateHasChanged();

            _ = Task.Run(async () => { await Task.Delay(5000); generationStatus = ""; await InvokeAsync(StateHasChanged); });
        }
        catch (Exception ex) { generationStatus = $"❌ Ошибка: {ex.Message}"; isGenerating = false; StateHasChanged(); }
    }

    private async Task ClearWeek()
    {
        try
        {
            var oldMenu = await DbContext.Menus.Include(m => m.Items).FirstOrDefaultAsync(m => m.UserId == 1);
            if (oldMenu != null) { DbContext.MenuItems.RemoveRange(oldMenu.Items); DbContext.Menus.Remove(oldMenu); await DbContext.SaveChangesAsync(); }
            GenerateEmptyWeek();
        }
        catch (Exception ex) { Console.WriteLine($"Ошибка: {ex.Message}"); }
    }

    private async Task RemoveMeal(DayPlan day, MealSlot meal)
    {
        try
        {
            var menu = await DbContext.Menus.Include(m => m.Items).FirstOrDefaultAsync(m => m.UserId == 1);
            if (menu != null)
            {
                var russianTypes = new[] { "Завтрак", "Обед", "Ужин" };
                var englishTypes = new[] { "breakfast", "lunch", "dinner" };
                var idx = Array.IndexOf(englishTypes, meal.Type);
                var menuItem = menu.Items.FirstOrDefault(mi => mi.Date.Date == day.Date.Date && (mi.MealType == russianTypes[idx] || mi.MealType == englishTypes[idx]));
                if (menuItem != null) { DbContext.MenuItems.Remove(menuItem); await DbContext.SaveChangesAsync(); }
            }
            meal.Recipe = null; StateHasChanged();
        }
        catch (Exception ex) { Console.WriteLine($"Ошибка: {ex.Message}"); }
    }

    private void ViewRecipe(Recipe recipe) => Navigation.NavigateTo($"/recipe/{recipe.Id}");
    private string GetWeekRange() { var today = DateTime.Now; return $"{today:dd.MM} - {today.AddDays(daysToGenerate - 1):dd.MM.yyyy}"; }
    private string GetMealTypeIcon(string type) => type switch { "breakfast" => "🌅", "lunch" => "🌞", "dinner" => "🌙", _ => "🍽️" };
    private string GetMealTypeName(string type) => type switch { "breakfast" => "Завтрак", "lunch" => "Обед", "dinner" => "Ужин", _ => "Приём пищи" };
}