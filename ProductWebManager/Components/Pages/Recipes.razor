        padding: 8px 18px;
        border: none;
        border-radius: 8px;
        background: #6c5ce7;
        color: white;
        font-weight: 500;
        font-size: 13px;
        cursor: pointer;
        box-shadow: 0 2px 6px rgba(108, 92, 231, 0.3);
