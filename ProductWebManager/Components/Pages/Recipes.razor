                            <div class="availability-bar">
                                <div class="availability-fill" style="width: 75%; background: #27ae60;"></div>
                            </div>
                            <span class="availability-text" style="color: #27ae60;">3/4 есть</span>
                        </div>
                    </div>

                    <div class="recipe-stats">
                        <div class="stat-item">
                            <span>🔥</span> 220 ккал
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button class="btn-recipe-view flex-grow-1">
