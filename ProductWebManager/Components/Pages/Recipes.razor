@page "/recipes"
@rendermode InteractiveServer

@inject NavigationManager Navigation
@inject IDbContextFactory<ProductWebManager.Data.ProductManagerContext> DbContextFactory
@inject ProductWebManager.Services.AuthService AuthService
@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Models

<PageTitle>SmartPlate AI — Рецепты</PageTitle>

<div class="max-w-[1440px] mx-auto px-4 py-4 sm:p-6 lg:p-10 font-sans">

    <header class="flex flex-col md:flex-row justify-between items-start md:items-center gap-4 mb-6 sm:mb-10">
        <div>
            <h1 class="text-2xl sm:text-4xl font-black text-slate-900 tracking-tighter">Рецепты</h1>
            <p class="text-slate-500 font-medium mt-1 text-sm sm:text-base">Найдите идеальное блюдо для вашего рациона</p>
        </div>
    </header>

    <div class="space-y-4 pb-3 sm:pb-5 mb-6 sm:mb-8 border-b border-slate-100">

        <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4">

            <div class="flex items-center gap-3 sm:gap-6 text-sm font-medium border-b sm:border-none border-slate-100 pb-2 sm:pb-0 overflow-x-auto scrollbar-none">
                <button @onclick='() => SetFilterType("all")'
                        class="pb-2 sm:py-1 transition-all relative @(activeFilter == "all" ? "text-slate-900 font-semibold after:absolute after:bottom-0 after:left-0 after:right-0 after:h-[2px] after:bg-slate-900" : "text-slate-400 hover:text-slate-600")">
                    Все рецепты
                </button>

                <button @onclick='() => SetFilterType("favorites")'
                        class="pb-2 sm:py-1 transition-all relative flex items-center gap-1.5 @(activeFilter == "favorites" ? "text-rose-600 font-semibold after:absolute after:bottom-0 after:left-0 after:right-0 after:h-[2px] after:bg-rose-500" : "text-slate-400 hover:text-slate-600")">
                    <span>Избранное</span>
                    <span class="text-[10px] px-1.5 py-0.5 rounded-full bg-slate-50 text-slate-500 font-normal border border-slate-100">@favoriteIds.Count</span>
                </button>

                <button @onclick='() => SetFilterType("byIngredients")'
                        class="pb-2 sm:py-1 transition-all relative @(activeFilter == "byIngredients" ? "text-indigo-600 font-semibold after:absolute after:bottom-0 after:left-0 after:right-0 after:h-[2px] after:bg-indigo-600" : "text-slate-400 hover:text-slate-600")">
                    По наличию продуктов
                </button>
            </div>

            <div class="flex items-center gap-2 text-xs text-slate-400 self-start sm:self-center">
                <span>Время готовки:</span>
                <select class="bg-transparent font-medium text-slate-700 focus:outline-none cursor-pointer border-none p-0 pr-4 text-xs"
                        value="@filterTime" @onchange="OnFilterTimeChanged">
                    <option value="0">Любое</option>
                    <option value="15">До 15 мин</option>
                    <option value="30">До 30 мин</option>
                    <option value="45">До 45 мин</option>
                    <option value="60">До 1 часа</option>
                </select>
            </div>
        </div>

        <div class="relative w-full max-w-md">
            <input type="text"
                   class="w-full bg-slate-50 text-xs px-3 py-2 rounded-lg border border-slate-100 focus:outline-none focus:border-slate-200 focus:bg-white placeholder-slate-400 transition-all"
                   placeholder="Поиск рецептов по названию..."
                   value="@searchQuery"
                   @oninput="OnSearchInput" />

            @if (!string.IsNullOrEmpty(searchQuery))
            {
                <button @onclick="async () => { searchQuery = string.Empty; RefreshFilters(); }"
                        class="absolute right-2.5 top-2.5 text-slate-400 hover:text-slate-600 text-xs">
                    <i class="fas fa-times"></i>
                </button>
            }
        </div>
    </div>

    @if (!filteredRecipes.Any())
    {
        <div class="bg-white border border-slate-100 rounded-[2.5rem] shadow-sm p-20 text-center">
            <div class="w-16 h-16 bg-slate-50 text-slate-400 rounded-2xl flex items-center justify-center text-2xl mx-auto mb-4 shadow-inner">
                <i class="fas fa-cookie-bite"></i>
            </div>
            <h3 class="text-xl font-black text-slate-800">Ничего не найдено</h3>
            <p class="text-slate-400 font-medium max-w-xs mx-auto mt-1">Попробуйте изменить параметры фильтров или поисковый запрос.</p>
        </div>
    }
    else
    {
        <div class="grid grid-cols-2 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 sm:gap-6">
            @foreach (var recipe in filteredRecipes)
            {
                var isFav = favoriteIds.Contains(recipe.Id);
                var totalTime = (recipe.PrepTime ?? 0) + (recipe.CookTime ?? 0);

                <div @onclick="() => ViewRecipe(recipe.Id)"
                     class="group bg-white border border-slate-100 rounded-3xl overflow-hidden shadow-sm hover:shadow-xl hover:shadow-slate-200/40 hover:-translate-y-1 transition-all duration-300 flex flex-col justify-between relative cursor-pointer select-none">

                    <button @onclick="() => ToggleFavorite(recipe.Id)" @onclick:stopPropagation="true"
                            class="absolute top-3 right-3 z-10 w-9 h-9 rounded-full backdrop-blur-md flex items-center justify-center transition-all shadow-sm @(isFav ? "bg-red-500 text-white scale-110" : "bg-white/80 text-slate-400 hover:text-red-500 hover:bg-white")">
                        <i class="fas fa-heart text-xs @(isFav ? "scale-105" : "")"></i>
                    </button>

                    <div>
                        <div class="h-36 w-full overflow-hidden bg-slate-100 relative flex items-center justify-center transition-transform duration-500 group-hover:scale-[1.02]">
                            @if (!string.IsNullOrWhiteSpace(recipe.ImageUrl))
                            {
                                <img src="@recipe.ImageUrl" alt="@recipe.Title" class="w-full h-full object-cover" />
                            }
                            else
                            {
                                <div class="w-full h-full opacity-85 group-hover:opacity-100 transition-opacity flex items-center justify-center text-white/40 group-hover:text-white/60"
                                     style="background: @GetRecipeGradient(recipe.Id)">
                                    <i class="fas fa-utensils text-3xl transition-transform group-hover:scale-110 duration-300"></i>
                                </div>
                            }
                        </div>

                        <div class="p-4 sm:p-5">
                            <div class="flex items-center gap-1.5 text-[11px] font-bold text-slate-400 mb-2">
                                <i class="far fa-clock"></i>
                                <span>@totalTime мин</span>
                                
                                @if (recipe.RecipeIngredients != null && recipe.RecipeIngredients.Any())
                                {
                                    var availableCount = recipe.RecipeIngredients.Count(ri => fridgeProductIds.Contains(ri.ProductId));
                                    <div class="ml-auto flex items-center gap-1 px-2 py-0.5 rounded-lg @(availableCount == recipe.RecipeIngredients.Count ? "bg-emerald-50 text-emerald-600" : (availableCount > 0 ? "bg-amber-50 text-amber-600" : "bg-slate-50 text-slate-400"))">
                                        <i class="fas fa-shopping-basket text-[9px]"></i>
                                        <span>@availableCount / @recipe.RecipeIngredients.Count</span>
                                    </div>
                                }
                            </div>

                            <h3 class="font-black text-base text-slate-800 line-clamp-2 leading-tight group-hover:text-indigo-600 transition-colors mb-2" title="@recipe.Title">
                                @recipe.Title
                            </h3>

                            <p class="text-xs text-slate-400 line-clamp-2 font-medium leading-relaxed">
                                @(string.IsNullOrWhiteSpace(recipe.Description) ? "Рецепт содержит подробные пошаговые инструкции приготовления." : recipe.Description)
                            </p>
                        </div>
                    </div>

                    <div class="p-4 pt-0 flex justify-end items-center text-xs font-bold text-slate-300 group-hover:text-indigo-500 transition-colors">
                        <span class="mr-1 opacity-0 group-hover:opacity-100 group-hover:translate-x-0 -translate-x-1 transition-all">Открыть</span>
                        <i class="fas fa-chevron-right text-[10px]"></i>
                    </div>

                </div>
            }
        </div>
    }
</div>

@code {
    private List<Recipe> allRecipes = new();
    private List<Recipe> filteredRecipes = new();
    private HashSet<int> favoriteIds = new();
    private HashSet<int> fridgeProductIds = new();

    private string searchQuery = "";
    private int filterTime = 0;
    private string activeFilter = "all"; // "all", "favorites", "byIngredients"

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        try
        {
            await using var context = await DbContextFactory.CreateDbContextAsync();

            allRecipes = await context.Recipes
                .Include(r => r.RecipeIngredients)
                .ToListAsync();

            var favorites = await context.FavoriteRecipes
                .Where(f => f.UserId == AuthService.CurrentUserId)
                .Select(f => f.RecipeId)
                .ToListAsync();

            var fridgeItems = await context.FridgeItems
                .Where(f => f.UserId == AuthService.CurrentUserId)
                .Select(f => f.ProductId)
                .ToListAsync();

            favoriteIds = new HashSet<int>(favorites);
            fridgeProductIds = new HashSet<int>(fridgeItems);

            RefreshFilters();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка загрузки данных: {ex.Message}");
        }
    }

    private void SetFilterType(string filterType)
    {
        activeFilter = filterType;
        RefreshFilters();
    }

    private void OnFilterTimeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int time))
        {
            filterTime = time;
            RefreshFilters();
        }
    }

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchQuery = e.Value?.ToString() ?? "";
        RefreshFilters();
    }

    private void RefreshFilters()
    {
        var query = allRecipes.AsEnumerable();

        if (activeFilter == "favorites")
        {
            query = query.Where(r => favoriteIds.Contains(r.Id));
        }

        if (!string.IsNullOrWhiteSpace(searchQuery))
        {
            query = query.Where(r => r.Title != null && r.Title.Contains(searchQuery, StringComparison.OrdinalIgnoreCase));
        }

        if (filterTime > 0)
        {
            query = query.Where(r => ((r.PrepTime ?? 0) + (r.CookTime ?? 0)) <= filterTime);
        }

        if (activeFilter == "byIngredients")
        {
            // Сортируем по количеству продуктов, которые есть в холодильнике (по убыванию)
            // А при равном количестве - по наименьшему общему количеству требуемых продуктов (чтобы процент был выше)
            query = query.OrderByDescending(r => r.RecipeIngredients?.Count(ri => fridgeProductIds.Contains(ri.ProductId)) ?? 0)
                         .ThenBy(r => r.RecipeIngredients?.Count ?? 0);
        }

        filteredRecipes = query.ToList();
        StateHasChanged();
    }

    private async Task ToggleFavorite(int recipeId)
    {
        try
        {
            await using var context = await DbContextFactory.CreateDbContextAsync();

            if (favoriteIds.Contains(recipeId))
            {
                var favorite = await context.FavoriteRecipes
                    .FirstOrDefaultAsync(f => f.RecipeId == recipeId && f.UserId == AuthService.CurrentUserId);

                if (favorite != null)
                {
                    context.FavoriteRecipes.Remove(favorite);
                    favoriteIds.Remove(recipeId);
                }
            }
            else
            {
                var favorite = new FavoriteRecipe
                    {
                        RecipeId = recipeId,
                        UserId = AuthService.CurrentUserId
                    };
                context.FavoriteRecipes.Add(favorite);
                favoriteIds.Add(recipeId);
            }

            await context.SaveChangesAsync();

            if (activeFilter == "favorites")
                RefreshFilters();
            else
                StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка избранного: {ex.Message}");
        }
    }

    private void ViewRecipe(int recipeId)
    {
        Navigation.NavigateTo($"/recipe/{recipeId}");
    }

    private string GetRecipeGradient(int id)
    {
        return (id % 8) switch
        {
            0 => "linear-gradient(135deg, #ff6b6b, #ff8e8e)",
            1 => "linear-gradient(135deg, #ffa502, #ffbe76)",
            2 => "linear-gradient(135deg, #a29bfe, #6c5ce7)",
            3 => "linear-gradient(135deg, #fd79a8, #e84393)",
            4 => "linear-gradient(135deg, #2ed573, #7bed9f)",
            5 => "linear-gradient(135deg, #1e90ff, #70a1ff)",
            6 => "linear-gradient(135deg, #2f3542, #57606f)",
            _ => "linear-gradient(135deg, #f10555, #f15233)"
        };
    }
}