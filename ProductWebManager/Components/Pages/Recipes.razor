</style>

@code {
    private List<Recipe> recipes = new();
    private List<Recipe> filteredRecipes = new();
    private HashSet<int> fridgeProductIds = new();
    private HashSet<int> favoriteIds = new();
    private string searchQuery = "";
    private string filterCategory = "";
    private string filterTime = "0";
    private string filterDifficulty = "";
    private string activeFilter = "all";

    protected override async Task OnInitializedAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        recipes = await DbContext.Recipes
            .Include(r => r.RecipeIngredients)
            .ToListAsync();

        fridgeProductIds = (await DbContext.FridgeItems
            .Where(f => f.UserId == AuthService.CurrentUserId)
            .Select(f => f.ProductId)
            .ToListAsync())
            .Where(id => id > 0)
            .ToHashSet();

        favoriteIds = (await DbContext.FavoriteRecipes
            .Where(f => f.UserId == AuthService.CurrentUserId)
            .Select(f => f.RecipeId)
            .ToListAsync())
            .ToHashSet();

        RefreshFilters();
    }

    private async Task ForceReload() => await LoadData();

    private void RefreshFilters()
    {
        var query = recipes.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(searchQuery))
            query = query.Where(r => r.Title?.Contains(searchQuery, StringComparison.OrdinalIgnoreCase) == true);

        if (activeFilter == "available")
            query = query.Where(r => r.RecipeIngredients != null &&
                                     r.RecipeIngredients.Any() &&
                                     r.RecipeIngredients.All(ri => fridgeProductIds.Contains(ri.ProductId)));

        if (activeFilter == "favorites")
            query = query.Where(r => favoriteIds.Contains(r.Id));

        if (int.TryParse(filterTime, out int maxTime) && maxTime > 0)
            query = query.Where(r => (r.PrepTime ?? 0) + (r.CookTime ?? 0) <= maxTime);

        if (!string.IsNullOrEmpty(filterDifficulty))
        {
            query = filterDifficulty switch
            {
                "easy" => query.Where(r => (r.PrepTime ?? 0) + (r.CookTime ?? 0) <= 30),
                "medium" => query.Where(r => (r.PrepTime ?? 0) + (r.CookTime ?? 0) > 30 && (r.PrepTime ?? 0) + (r.CookTime ?? 0) <= 60),
                "hard" => query.Where(r => (r.PrepTime ?? 0) + (r.CookTime ?? 0) > 60),
                _ => query
            };
        }

        filteredRecipes = query.ToList();
        StateHasChanged();
    }

    private void ShowAll()
    {
        activeFilter = "all";
        RefreshFilters();
    }

    private void ShowAvailable()
    {
        activeFilter = "available";
        RefreshFilters();
    }

    private void ShowFavorites()
    {
        activeFilter = "favorites";
        RefreshFilters();
    }

    private async Task ToggleFavorite(int recipeId)
    {
        try
        {
            var existing = await DbContext.FavoriteRecipes
                .FirstOrDefaultAsync(f => f.RecipeId == recipeId && f.UserId == AuthService.CurrentUserId);

            if (existing != null)
            {
                DbContext.FavoriteRecipes.Remove(existing);
                favoriteIds.Remove(recipeId);
            }
            else
            {
                var favorite = new FavoriteRecipe
                    {
                        RecipeId = recipeId,
                        UserId = AuthService.CurrentUserId
                    };
                DbContext.FavoriteRecipes.Add(favorite);
                favoriteIds.Add(recipeId);
            }

            await DbContext.SaveChangesAsync();

            // Если активен фильтр "Избранное" — обновляем список
            if (activeFilter == "favorites")
                RefreshFilters();
            else
                StateHasChanged();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка избранного: {ex.Message}");
        }
    }

    private bool IsFavorite(int recipeId) => favoriteIds.Contains(recipeId);

    private void ViewRecipe(int recipeId) => Navigation.NavigateTo($"/recipe/{recipeId}");
    private void GoToMenu() => Navigation.NavigateTo("/menu");

    private string GetRecipeGradient(int id) => (id % 8) switch
    {
        0 => "linear-gradient(135deg, #ff6b6b, #ff8e8e)",
        1 => "linear-gradient(135deg, #ffa502, #ffbe76)",
        2 => "linear-gradient(135deg, #a29bfe, #6c5ce7)",
        3 => "linear-gradient(135deg, #fd79a8, #e84393)",
        4 => "linear-gradient(135deg, #00b894, #55efc4)",
        5 => "linear-gradient(135deg, #fdcb6e, #ffeaa7)",
        6 => "linear-gradient(135deg, #74b9ff, #0984e3)",
        _ => "linear-gradient(135deg, #e17055, #d63031)"
    };
}