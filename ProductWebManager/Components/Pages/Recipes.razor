    .filter-input {
        background: #f8f8fa;
        border: 1px solid #e0e0e4;
        padding: 8px 12px;
        color: #333;
        font-size: 13px;
        width: 100%;
        border-radius: 8px;
    }

        .filter-input:focus {
            border-color: #6c5ce7;
            box-shadow: 0 0 0 3px rgba(108, 92, 231, 0.1);
            outline: none;
        }

    .btn-filter {
        padding: 6px 16px;
        border: 1px solid #e0e0e4;
        border-radius: 20px;
        background: white;
        color: #666;
        font-size: 12px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-filter:hover {
            background: #f5f3ff;
            border-color: #6c5ce7;
            color: #6c5ce7;
        }

        .btn-filter.active {
            background: #6c5ce7;
            color: white;
            border-color: #6c5ce7;
        }

    .recipe-card {
        background: white;
        border: 1px solid #eee;
        border-radius: 16px;
        overflow: hidden;
        transition: all 0.3s;
        box-shadow: 0 2px 8px rgba(0,0,0,0.04);
