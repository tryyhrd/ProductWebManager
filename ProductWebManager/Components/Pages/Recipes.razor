@page "/recipes"
@rendermode InteractiveServer
@inject NavigationManager Navigation
@inject ProductWebManager.Data.ProductManagerContext DbContext
@inject ProductWebManager.Services.AuthService AuthService
@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Models

<PageTitle>Рецепты</PageTitle>

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold m-0" style="color: #1a1a2e;">Рецепты</h2>
            <small style="color: #888;">Найдите идеальное блюдо</small>
        </div>
    </div>

    <div class="filter-bar">
        <div class="row g-3">
            <div class="col-md-5">
                <input type="text" class="form-control filter-input"
                       placeholder="🔍 Поиск рецептов..."
                       @bind="searchQuery"
                       @bind:event="oninput"
                       @bind:after="RefreshFilters" />
            </div>
            @* <div class="col-md-3">
                <select class="form-control filter-input" @bind="filterCategory" @bind:after="RefreshFilters">
                    <option value="">🗂️ Все категории</option>
                    <option value="breakfast">🌅 Завтрак</option>
                    <option value="lunch">🌞 Обед</option>
                    <option value="dinner">🌙 Ужин</option>
                    <option value="dessert">🍰 Десерт</option>
                    <option value="snack">🥨 Перекус</option>
                    <option value="salad">🥗 Салат</option>
                    <option value="soup">🍜 Суп</option>
                </select>
            </div> *@
            <div class="col-md-2">
                <select class="form-control filter-input" @bind="filterTime" @bind:after="RefreshFilters">
                    <option value="0">⏱️ Время</option>
                    <option value="15">До 15 мин</option>
                    <option value="30">До 30 мин</option>
                    <option value="60">До 1 часа</option>
                    <option value="120">До 2 часов</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-control filter-input" @bind="filterDifficulty" @bind:after="RefreshFilters">
                    <option value="">📊 Сложность</option>
                    <option value="easy">Легко</option>
                    <option value="medium">Средне</option>
                    <option value="hard">Сложно</option>
                </select>
            </div>
        </div>

        <div class="d-flex gap-2 mt-3 flex-wrap">
            <button class="btn-filter @(activeFilter == "all" ? "active" : "")" @onclick="ShowAll">Все</button>
            <button class="btn-filter @(activeFilter == "available" ? "active" : "")" @onclick="ShowAvailable">Можно приготовить</button>
            <button class="btn-filter @(activeFilter == "favorites" ? "active" : "")" @onclick="ShowFavorites">Избранное</button>
        </div>
    </div>

    @if (filteredRecipes.Any())
    {
        <div class="row">
            @foreach (var recipe in filteredRecipes)
            {
                var availableCount = recipe.RecipeIngredients?.Count(ri => fridgeProductIds.Contains(ri.ProductId)) ?? 0;
                var totalCount = recipe.RecipeIngredients?.Count ?? 0;
                var availabilityPercent = totalCount > 0 ? (double)availableCount / totalCount * 100 : 0;
                var availabilityColor = availabilityPercent >= 80 ? "#27ae60" : availabilityPercent >= 50 ? "#f39c12" : "#e74c3c";
                var prepTime = (recipe.PrepTime ?? 0) + (recipe.CookTime ?? 0);
                var isFav = favoriteIds.Contains(recipe.Id);

                <div class="col-md-6 col-lg-4 col-xl-3 mb-3">
                    <div class="recipe-card">
                        <div class="recipe-image" style="background: @GetRecipeGradient(recipe.Id);">
                            <div class="recipe-image-overlay">
                                <button class="btn-favorite @(isFav ? "active" : "")"
                                        @onclick="() => ToggleFavorite(recipe.Id)">
                                    <span class="heart-icon">@(isFav ? "❤️" : "🤍")</span>
                                </button>
                                @if (prepTime > 0)
                                {
                                    <span class="recipe-time-badge">⏱️ @prepTime мин</span>
                                }
                            </div>
                        </div>

                        <div class="recipe-info">
                            <div class="d-flex justify-content-between align-items-start mb-2">
                                <div>
                                    <h6 class="recipe-name">@(recipe.Title ?? "Без названия")</h6>
                                </div>
                                @if (prepTime <= 30 && prepTime > 0)
                                {
                                    <span class="difficulty-badge easy">Легко</span>
                                }
                                else if (prepTime <= 60)
                                {
                                    <span class="difficulty-badge medium">Средне</span>
                                }
                                else if (prepTime > 0)
                                {
                                    <span class="difficulty-badge hard">Сложно</span>
                                }
                            </div>
                            <p class="recipe-desc">@(recipe.Description ?? "Описание отсутствует")</p>
                            @if (totalCount > 0)
                            {
                                <div class="ingredients-availability mb-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <div class="availability-bar">
                                            <div class="availability-fill" style="width: @availabilityPercent%; background: @availabilityColor;"></div>
                                        </div>
                                        <span class="availability-text" style="color: @availabilityColor;">@availableCount/@totalCount есть</span>
                                    </div>
                                </div>
                            }
                            @* <div class="recipe-stats">
                                @if (recipe.Calories.HasValue)
                                {
                                    <div class="stat-item">🔥 @recipe.Calories ккал</div>
                                }
                            </div> *@
                            <div class="d-flex gap-2 mt-3">
                                <button class="btn-recipe-view flex-grow-1" @onclick="() => ViewRecipe(recipe.Id)">Смотреть</button>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="empty-state">
            <div class="empty-icon">📖</div>
            <h4 style="color: #555; margin-top: 16px;">Рецепты не найдены</h4>
            <p style="color: #999; margin-bottom: 16px;">Попробуйте изменить фильтры</p>
            <button class="btn btn-add" @onclick="ForceReload">Обновить</button>
        </div>
    }
</div>

<style>
