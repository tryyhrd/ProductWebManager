@page "/recipes"
@inject NavigationManager Navigation

<PageTitle>Рецепты</PageTitle>

<div class="container-fluid p-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h2 class="fw-bold m-0" style="color: #1a1a2e;">Рецепты</h2>
            <small style="color: #888;">Найдите идеальное блюдо</small>
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-add" @* @onclick="() => Navigation.NavigateTo('/menu')" *@>
                В меню
            </button>
        </div>
    </div>

    <div class="filter-bar">
        <div class="row g-3">
            <div class="col-md-5">
                <div class="input-group">
                    @* <span class="input-group-text filter-icon">🔍</span> *@
                    <input type="text" class="form-control filter-input" placeholder="Поиск рецептов..." />
                </div>
            </div>
            <div class="col-md-3">
                <select class="form-control filter-input">
                    <option value="">🗂️ Все категории</option>
                    <option value="breakfast">🌅 Завтрак</option>
                    <option value="lunch">🌞 Обед</option>
                    <option value="dinner">🌙 Ужин</option>
                    <option value="dessert">🍰 Десерт</option>
                    <option value="snack">🥨 Перекус</option>
                    <option value="salad">🥗 Салат</option>
                    <option value="soup">🍜 Суп</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-control filter-input">
                    <option value="">⏱️ Время</option>
                    <option value="15">До 15 мин</option>
                    <option value="30">До 30 мин</option>
                    <option value="60">До 1 часа</option>
                    <option value="120">До 2 часов</option>
                </select>
            </div>
            <div class="col-md-2">
                <select class="form-control filter-input">
                    <option value="">📊 Сложность</option>
                    <option value="easy">Легко</option>
                    <option value="medium">Средне</option>
                    <option value="hard">Сложно</option>
                </select>
            </div>
        </div>

        <div class="d-flex gap-2 mt-3 flex-wrap">
            <button class="btn-filter active">Все</button>
            <button class="btn-filter">Можно приготовить</button>
            <button class="btn-filter">Избранное</button>
            <button class="btn-filter">Популярное</button>
            <button class="btn-filter">Новое</button>
        </div>
    </div>

    <!-- Сетка рецептов -->
    <div class="row">
        <!-- Карточка рецепта 1 -->
        <div class="col-md-6 col-lg-4 col-xl-3 mb-3">
            <div class="recipe-card">
                <!-- Изображение -->
                <div class="recipe-image" style="background: linear-gradient(135deg, #ff6b6b, #ff8e8e);">
                    <div class="recipe-image-overlay">
                        <button class="btn-favorite">
                            <span class="heart-icon">🤍</span>
                        </button>
                        <span class="recipe-time-badge">⏱️ 25 мин</span>
                    </div>
                </div>

                <!-- Информация -->
                <div class="recipe-info">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h6 class="recipe-name">Паста Карбонара</h6>
                            <span class="recipe-category">🍝 Ужин</span>
                        </div>
                        <span class="difficulty-badge easy">Легко</span>
                    </div>

                    <p class="recipe-desc">Классическая итальянская паста с беконом и сливочным соусом</p>

                    <!-- Ингредиенты -->
                    <div class="ingredients-availability mb-2">
                        <div class="d-flex align-items-center gap-2">
                            <div class="availability-bar">
                                <div class="availability-fill" style="width: 80%; background: #27ae60;"></div>
                            </div>
                            <span class="availability-text" style="color: #27ae60;">4/5 есть</span>
                        </div>
                    </div>

                    <!-- Характеристики -->
                    <div class="recipe-stats">
                        <div class="stat-item">
                            <span>🔥</span> 450 ккал
                        </div>
                    </div>

                    <!-- Кнопки -->
                    <div class="d-flex gap-2 mt-3">
                        <button class="btn-recipe-view flex-grow-1">
                            Смотреть
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Карточка рецепта 2 -->
        <div class="col-md-6 col-lg-4 col-xl-3 mb-3">
            <div class="recipe-card">
                <div class="recipe-image" style="background: linear-gradient(135deg, #ffa502, #ffbe76);">
                    <div class="recipe-image-overlay">
                        <button class="btn-favorite">
                            <span class="heart-icon active">❤️</span>
                        </button>
                        <span class="recipe-time-badge">⏱️ 40 мин</span>
                    </div>
                </div>

                <div class="recipe-info">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        <div>
                            <h6 class="recipe-name">Куриный суп</h6>
                            <span class="recipe-category">🍜 Суп</span>
                        </div>
                        <span class="difficulty-badge medium">Средне</span>
                    </div>

                    <p class="recipe-desc">Наваристый суп с курицей, лапшой и овощами</p>

                    <div class="ingredients-availability mb-2">
                        <div class="d-flex align-items-center gap-2">
                            <div class="availability-bar">
                                <div class="availability-fill" style="width: 50%; background: #f39c12;"></div>
                            </div>
                            <span class="availability-text" style="color: #f39c12;">3/6 есть</span>
                        </div>
                    </div>

                    <div class="recipe-stats">
                        <div class="stat-item">
                            <span>🔥</span> 320 ккал
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-3">
                        <button class="btn-recipe-view flex-grow-1">
                            Смотреть
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <!-- Карточка рецепта 3 -->
