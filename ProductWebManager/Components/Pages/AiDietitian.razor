@page "/ai-dietitian"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using ProductWebManager.Classes.AI
@using ProductWebManager.Models
@using Microsoft.AspNetCore.Components.Forms
@inject GigaChatHelper GigaChat
@inject ProductWebManager.Services.AuthService AuthService
@inject IDbContextFactory<ProductWebManager.Data.ProductManagerContext> DbContextFactory
@inject NavigationManager Navigation

<PageTitle>SmartPlate AI — ИИ Диетолог</PageTitle>

<div class="max-w-4xl mx-auto px-4 py-6 sm:p-8 font-sans h-[calc(100vh-80px)] flex flex-col">
    <header class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6 shrink-0">
        <div class="flex items-center gap-4">
            <div class="w-14 h-14 bg-indigo-100 text-indigo-600 rounded-2xl flex items-center justify-center text-2xl shadow-inner">
                <i class="fas fa-robot"></i>
            </div>
            <div class="flex items-center gap-4">
                <h1 class="text-2xl sm:text-4xl font-black text-slate-900 tracking-tighter">Ваш ИИ-Диетолог</h1>
                <span class="bg-indigo-100 text-indigo-700 text-xs font-bold px-3 py-1 rounded-full uppercase tracking-wide">Beta</span>
            </div>
        </div>
        <button @onclick="ClearHistoryAsync" class="text-sm font-bold text-red-500 hover:text-red-700 bg-red-50 hover:bg-red-100 px-4 py-2 rounded-xl transition-colors mt-4 sm:mt-0">
            <i class="fas fa-trash-alt mr-2"></i> Очистить историю
        </button>
    </header>

    <div class="bg-white rounded-[2rem] border border-slate-200 shadow-sm flex-1 flex flex-col overflow-hidden">
        <!-- Messages Area -->
        <div class="flex-1 overflow-y-auto p-4 sm:p-6 space-y-6" id="chat-container">
            @if (!messages.Any())
            {
                <div class="flex flex-col items-center justify-center h-full text-center p-8">
                    <div class="w-20 h-20 bg-indigo-50 text-indigo-400 rounded-full flex items-center justify-center text-4xl mb-4">
                        <i class="fas fa-magic"></i>
                    </div>
                    <h3 class="text-xl font-black text-slate-800 mb-2">Чем я могу помочь?</h3>
                    <p class="text-slate-500 max-w-sm mb-6">Спросите меня о питании, попросите составить меню или задайте вопрос о продуктах.</p>
                    <div class="flex flex-wrap justify-center gap-2">
                        <button @onclick="@(() => SetPresetQuery("Что приготовить на ужин из курицы и риса?"))" class="bg-slate-50 hover:bg-slate-100 text-slate-700 px-4 py-2 rounded-xl text-sm font-bold transition-colors border border-slate-200">Ужин из курицы</button>
                        <button @onclick="@(() => SetPresetQuery("Какие продукты богаты белком?"))" class="bg-slate-50 hover:bg-slate-100 text-slate-700 px-4 py-2 rounded-xl text-sm font-bold transition-colors border border-slate-200">Продукты с белком</button>
                        <button @onclick="@(() => SetPresetQuery("Что приготовить из продуктов в моем холодильнике?"))" class="bg-slate-50 hover:bg-slate-100 text-slate-700 px-4 py-2 rounded-xl text-sm font-bold transition-colors border border-slate-200">Рецепт из холодильника</button>
                    </div>
                </div>
            }
            else
            {
                @foreach (var msg in messages)
                {
                    <div class="flex @(msg.IsUser ? "justify-end" : "justify-start") animate-fade-in">
                        <div class="max-w-[85%] sm:max-w-[75%] @(msg.IsUser ? "bg-indigo-600 text-white rounded-t-2xl rounded-l-2xl" : "bg-slate-100 text-slate-800 rounded-t-2xl rounded-r-2xl") p-4 sm:p-5 shadow-sm">
                            @if (!msg.IsUser)
                            {
                                <div class="flex items-center gap-2 mb-2 opacity-70 text-[10px] font-black uppercase tracking-widest">
                                    <i class="fas fa-robot"></i> SmartPlate AI
                                </div>
                            }
                            <div class="text-sm sm:text-base leading-relaxed whitespace-pre-line font-medium">@msg.Text</div>
                        </div>
                    </div>
                }
                @if (isLoading)
                {
                    <div class="flex justify-start animate-fade-in">
                        <div class="bg-slate-100 text-slate-500 rounded-t-2xl rounded-r-2xl p-4 shadow-sm flex gap-2">
                            <div class="w-2 h-2 bg-indigo-400 rounded-full animate-bounce"></div>
                            <div class="w-2 h-2 bg-indigo-400 rounded-full animate-bounce" style="animation-delay: 0.1s"></div>
                            <div class="w-2 h-2 bg-indigo-400 rounded-full animate-bounce" style="animation-delay: 0.2s"></div>
                        </div>
                    </div>
                }
            }
        </div>

        <!-- Input Area -->
        <div class="p-4 sm:p-6 bg-slate-50 border-t border-slate-100 shrink-0">
            <form @onsubmit="SendMessageAsync" class="flex gap-2 sm:gap-4 items-end relative">
                <div class="flex-1 bg-white border border-slate-200 rounded-2xl p-2 flex items-end gap-2 shadow-sm focus-within:border-indigo-500 focus-within:ring-2 focus-within:ring-indigo-200 transition-all">
                    <textarea @bind="currentInput" 
                              @bind:event="oninput"
                              placeholder="Задайте вопрос диетологу..." 
                              class="flex-1 max-h-32 min-h-[40px] resize-none border-none outline-none bg-transparent py-2 px-1 text-sm sm:text-base font-medium text-slate-700" 
                              rows="1"
                              @onkeydown="HandleKeyDown"></textarea>
                </div>
                <button type="submit" disabled="@(string.IsNullOrWhiteSpace(currentInput) || isLoading)"
                        class="w-14 h-14 bg-indigo-600 hover:bg-indigo-700 disabled:bg-slate-300 disabled:cursor-not-allowed text-white rounded-2xl flex items-center justify-center text-lg shadow-md transition-all shrink-0">
                    @if (isLoading)
                    {
                        <i class="fas fa-spinner fa-spin"></i>
                    }
                    else
                    {
                        <i class="fas fa-paper-plane"></i>
                    }
                </button>
            </form>
            <div class="mt-3 text-center">
                <span class="text-[10px] font-black text-slate-400 uppercase tracking-widest">Powered by GigaChat</span>
            </div>
        </div>
    </div>
</div>

@code {
    private string currentInput = string.Empty;
    private bool isLoading = false;
    private List<AiChatMessage> messages = new();
    
    private string userContextProfile = string.Empty;
    private string userContextFridge = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        if (AuthService.IsAuthenticated)
        {
            await LoadContextAndHistoryAsync();
        }
    }

    private async Task LoadContextAndHistoryAsync()
    {
        try
        {
            await using var context = await DbContextFactory.CreateDbContextAsync();
            var userId = AuthService.CurrentUserId;
            
            messages = await context.AiChatMessages
                .Where(m => m.UserId == userId)
                .OrderBy(m => m.CreatedAt)
                .ToListAsync();

            var user = await context.Users
                .Include(u => u.Profile)
                .Include(u => u.UserAllergies).ThenInclude(ua => ua.Allergy)
                .FirstOrDefaultAsync(u => u.Id == userId);
                
            if (user?.Profile != null)
            {
                var p = user.Profile;
                userContextProfile = $"Пользователь: {p.Gender}, {p.Age} лет, {p.Weight} кг, {p.Height} см. Цель: {p.Goal}. Активность: {p.ActivityLevel}. Целевые калории: {p.TargetCalories} ккал.";
                if (user.UserAllergies.Any())
                {
                    userContextProfile += $" Аллергии: {string.Join(", ", user.UserAllergies.Select(x => x.Allergy.Name))}.";
                }
            }

            var fridgeItems = await context.FridgeItems
                .Include(f => f.Product).ThenInclude(p => p.Unit)
                .Where(f => f.UserId == userId)
                .ToListAsync();

            if (fridgeItems.Any())
            {
                userContextFridge = "Продукты в холодильнике: " + 
                    string.Join(", ", fridgeItems.Select(f => $"{f.Product.Name} ({f.Quantity} {f.Product.Unit.Name})"));
            }
        }
        catch (Exception) { }
    }

    private async Task ClearHistoryAsync()
    {
        try
        {
            await using var context = await DbContextFactory.CreateDbContextAsync();
            var history = await context.AiChatMessages.Where(m => m.UserId == AuthService.CurrentUserId).ToListAsync();
            context.AiChatMessages.RemoveRange(history);
            await context.SaveChangesAsync();
            messages.Clear();
            StateHasChanged();
        }
        catch (Exception) { }
    }

    private void SetPresetQuery(string query)
    {
        currentInput = query;
    }

    private async Task HandleKeyDown(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SendMessageAsync();
        }
    }

    private async Task SendMessageAsync()
    {
        if (string.IsNullOrWhiteSpace(currentInput) || isLoading) return;

        var query = currentInput;
        currentInput = string.Empty;
        isLoading = true;
        StateHasChanged();

        var userId = AuthService.CurrentUserId;
        var userMsg = new AiChatMessage 
        { 
            UserId = userId,
            Text = query, 
            IsUser = true,
            CreatedAt = DateTime.UtcNow
        };
        messages.Add(userMsg);

        try
        {
            await using var context = await DbContextFactory.CreateDbContextAsync();
            context.AiChatMessages.Add(userMsg);
            await context.SaveChangesAsync();

            var systemPrompt = $"Ты профессиональный диетолог. Помогаешь пользователю с вопросами о питании, калориях, рецептах и здоровом образе жизни. Отвечай кратко, по делу и доброжелательно. Учитывай данные профиля:\n{userContextProfile}\n\n{userContextFridge}";
            
            var historyStr = string.Join("\n\n", messages.Where(m => !string.IsNullOrEmpty(m.Text)).Select(m => (m.IsUser ? "Пользователь: " : "Диетолог: ") + m.Text));
            var fullQuery = $"История диалога:\n{historyStr}\n\nНовое сообщение пользователя:\n{query}";

            var aiResponse = await GigaChat.SendPromptAsync(systemPrompt, fullQuery); 
            if (string.IsNullOrEmpty(aiResponse)) 
            {
                aiResponse = "Не удалось получить ответ от ИИ.";
            }

            var botMsg = new AiChatMessage
            {
                UserId = userId,
                Text = aiResponse,
                IsUser = false,
                CreatedAt = DateTime.UtcNow
            };
            
            context.AiChatMessages.Add(botMsg);
            await context.SaveChangesAsync();
            
            messages.Add(botMsg);
        }
        catch (Exception)
        {
            messages.Add(new AiChatMessage { Text = "Произошла ошибка сети.", IsUser = false, CreatedAt = DateTime.UtcNow });
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }
}
