@inherits LayoutComponentBase
@inject AuthService AuthService
@inject NavigationManager Navigation

<AuthorizeView>
    <Authorized>
        <div class="premium-app-wrapper">
            <header class="main-header">
                <div class="header-container">
                    <div class="logo-section">
                        <div class="logo-icon">S</div>
                        <span class="logo-text">SmartPlate</span>
                    </div>

                    <nav class="top-navigation">
                        <NavMenu />
                    </nav>

                    <div class="user-section">
                        <div class="user-info-chip">
                            <span class="u-name">@context.User.Identity?.Name</span>
                            <button class="btn-exit" @onclick="HandleLogout" title="Выйти">
                                <i class="fas fa-sign-out-alt"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </header>

            <main class="main-viewport">
                <section class="page-content">
                    @Body
                </section>
            </main>

            <nav class="mobile-bottom-nav">
                <div class="mobile-nav-links">
                    <NavLink class="mobile-nav-item" href="fridge" Match="NavLinkMatch.All">
                        <i class="fas fa-box-open"></i>
                        <span>Продукты</span>
                    </NavLink>
                    <NavLink class="mobile-nav-item" href="recipes">
                        <i class="fas fa-book-open"></i>
                        <span>Рецепты</span>
                    </NavLink>
                    <NavLink class="mobile-nav-item" href="meal-plan">
                        <i class="fas fa-magic"></i>
                        <span>План</span>
                    </NavLink>
                    <NavLink class="mobile-nav-item" href="shopping-list">
                        <i class="fas fa-shopping-cart"></i>
                        <span>Покупки</span>
                    </NavLink>
                    <NavLink class="mobile-nav-item" href="profile">
                        <i class="fas fa-user-circle"></i>
                        <span>Профиль</span>
                    </NavLink>
                </div>
            </nav>
        </div>
    </Authorized>
    <NotAuthorized>
        <div class="auth-container">
            @Body
        </div>
    </NotAuthorized>
</AuthorizeView>

@code {
    private async Task HandleLogout()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/login");
    }
}