@namespace ProductWebManager.Components.Layout
@inherits LayoutComponentBase
@rendermode InteractiveServer
@using Microsoft.AspNetCore.Components.Authorization

<div class="page">
    <AuthorizeView>
        <Authorized>
            @* Боковое меню видят только вошедшие пользователи *@
            <div class="sidebar">
                <NavMenu />
            </div>
        </Authorized>
    </AuthorizeView>

    <main>
        <AuthorizeView>
            <Authorized>
                <div class="top-row px-4">
                    <div class="d-flex align-items-center gap-3">
                        <span style="color: #888; font-size: 14px;">@context.User.Identity?.Name</span>
                        <button class="btn-logout" @onclick="HandleLogout">
                            Выйти
                        </button>
                    </div>
                </div>
            </Authorized>
        </AuthorizeView>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<style>
    .btn-logout {
        padding: 6px 16px;
        border: 1px solid #e0e0e4;
        border-radius: 8px;
        background: #f8f8fa;
        color: #666;
        font-size: 13px;
        cursor: pointer;
        transition: all 0.2s;
    }

        .btn-logout:hover {
            background: #f0edff;
            border-color: #d5ccff;
            color: #6c5ce7;
        }
</style>

@code {
    [Inject] private ProductWebManager.Services.AuthService AuthService { get; set; } = default!;
    [Inject] private NavigationManager Navigation { get; set; } = default!;

    private async Task HandleLogout()
    {
        await AuthService.Logout();
        Navigation.NavigateTo("/login");
    }
}
